@page "/"
@page "/filesorter"

@using ITMartinFileSorter.Domain.Helpers
@implements IDisposable

@inject DuplicateService DuplicateService
@inject IFileScanner FileScanner
@inject ProgressService Progress
@inject NavigationManager Navigation
@inject IConfiguration Configuration
<PageLayout Title="📂 Scan & Organize Files">
    <div class="filesorter-app">

        <ContentCard CssClass="scan-hero-card">
            <p class="hero-text">
                Scan photos, videos, audio and documents.
            </p>

            <FolderInputPanel
                Value="@FolderPath"
                ValueChanged="OnFolderPathChanged"
                ButtonText="@(IsScanning ? "Scanning..." : "Scan Folder")"
                Disabled="@IsScanning"
                OnAction="ScanFolder" />
        </ContentCard>

        @if (ShowScanning)
        {
            <ProgressPanel
                Title="@Progress.Info.Stage"
                Current="@Progress.Info.WorkDone"
                Total="@Progress.Info.TotalWork"
                Percent="@ProgressPercent"
                CurrentItem="@CurrentFileName"
                LoadingText="Scanning files..."
                Icon="📂" />
        }

        @if (ShowSummary)
        {
            <SectionTitle Title="File Summary" />

            <div class="main-category-row mt-3">
                @foreach (var cat in CategoryOrder)
                {
                    var filesInCat = DuplicateService.AllFiles
                        .Where(f => CategoryHelper.GetCategory(f) == cat);
                    
                    var allFiles = filesInCat.ToList();

                    var needsReview = allFiles.Count(f =>
                        f.RequiresReview &&
                        f.Status == MediaFileStatus.Initial);

                    var processedCount = allFiles.Count(f =>
                        f.Status == MediaFileStatus.ToKeep ||
                        f.Status == MediaFileStatus.ToDelete);

                    var total = allFiles.Count;

                    var totalSize = allFiles
                        .Where(f => f.Status != MediaFileStatus.ToDelete)
                        .Sum(f => f.SizeBytes);

                    var isAuto = cat is "Screenshots" or "Memes";

                    <CategorySummaryCard
                        Title="@(isAuto ? $"{cat} (Auto)" : cat)"
                        ReviewCount="@needsReview"
                        ProcessedCount="@processedCount"
                        Total="@total"
                        SizeText="@FormatSize(totalSize)"
                        CssClass="@GetCategoryCssClass(cat)"
                        OnClick="@(e => OpenCategory(cat))" />
                }
            </div>

            <ActionButtonBar CssClass="bottom export-bar">

                <div class="export-status">
                    @if (!IsCompleted)
                    {
                        <span class="text-muted">
                            Complete all categories to enable export
                        </span>
                    }
                    else
                    {
                        <span class="text-success">
                            ✔ All files processed — ready to export
                        </span>
                    }
                </div>

                <span class="spacer"></span>

                <button class="btn btn-success btn-lg"
                        disabled="@(!IsCompleted)"
                        @onclick="GoToExport">
                    📦 Export Files
                </button>

            </ActionButtonBar>
        }
    </div>
</PageLayout>

@code {

    string FolderPath
    {
        get => DuplicateService.FolderPath;
        set => DuplicateService.FolderPath = value;
    }

    bool IsScanning = false;
    string CurrentFileName = "";
    int FilesDiscovered = 0;

    bool IsCompleted =>
        DuplicateService.AllFiles
            .Any(f => f.RequiresReview && f.Status == MediaFileStatus.Initial) == false;

    int ProgressPercent =>
        Progress.Info.TotalWork == 0
            ? 1
            : (int)((double)Progress.Info.WorkDone / Progress.Info.TotalWork * 100);

    bool ShowScanning =>
        IsScanning || Progress.Info.WorkDone > 0;

    bool ShowSummary =>
        !IsScanning && DuplicateService.AllFiles.Any();

    protected override void OnInitialized()
    {
        var source = Configuration["MediaSettings:SourceRoot"];

        if (!string.IsNullOrWhiteSpace(source))
        {
            DuplicateService.FolderPath = source;
        }
    }

    void HandleProgressChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Progress.OnChange -= HandleProgressChanged;
    }

    void OnFolderPathChanged(string value)
    {
        FolderPath = value;
    }

    // ✅ FIXED CSS mapping
    string GetCategoryCssClass(string cat) => cat switch
    {
        "Audio" => "category-audio",
        "Documents" => "category-document",
        "Images" => "category-image",
        "Videos" => "category-video",
        "Screenshots" => "category-auto",
        "Memes" => "category-auto",
        _ => ""
    };

    async Task ScanFolder()
    {
        if (IsScanning) return;

        var path = FolderPath;
        if (string.IsNullOrWhiteSpace(path) || !Directory.Exists(path))
            return;

        IsScanning = true;
        await InvokeAsync(StateHasChanged);

        CurrentFileName = "";
        FilesDiscovered = 0;

        DuplicateService.Reset();
        DuplicateService.FolderPath = path;

        var bag = new System.Collections.Concurrent.ConcurrentBag<MediaFile>();

        var allPaths = FileScanner.EnumerateFiles(path).ToList();

        Progress.Start("Scanning files...", allPaths.Count);

        var lastRender = DateTime.UtcNow;

        await Parallel.ForEachAsync(allPaths, new ParallelOptions
        {
            MaxDegreeOfParallelism = Environment.ProcessorCount
        },
        async (filePath, ct) =>
        {
            try
            {
                var file = FileScanner.ProcessFile(filePath);
                if (file == null) return;

                file.RequiresReview = true;
                file.Status = MediaFileStatus.Initial;

                if (file.SubCategory is MediaSubCategory.Meme or MediaSubCategory.Screenshot)
                {
                    file.RequiresReview = false;
                    file.Status = MediaFileStatus.ToKeep;
                }

                bag.Add(file);

                Interlocked.Increment(ref FilesDiscovered);
                Progress.Increment();

                await InvokeAsync(() =>
                {
                    CurrentFileName = Path.GetFileName(filePath);

                    if ((DateTime.UtcNow - lastRender).TotalMilliseconds > 100)
                    {
                        lastRender = DateTime.UtcNow;
                        StateHasChanged();
                    }
                });
            }
            catch { }
        });

        DuplicateService.AllFiles = bag.ToList();

        Progress.SetStage("Removing duplicates...");
        await Task.Run(() => DuplicateService.BuildDuplicateGroups());

        foreach (var file in DuplicateService.AllFiles)
        {
            bool isAuto = file.SubCategory is MediaSubCategory.Meme or MediaSubCategory.Screenshot;

            if (file.Status == MediaFileStatus.ToDelete)
                continue;

            if (isAuto)
            {
                file.RequiresReview = false;
                file.Status = MediaFileStatus.ToKeep;
            }
            else if (file.Status == MediaFileStatus.ToKeep && file.RequiresReview == false)
            {
                file.RequiresReview = true;
                file.Status = MediaFileStatus.Initial;
            }
        }

        Progress.Complete();
        IsScanning = false;

        await InvokeAsync(StateHasChanged);
    }

    void OpenCategory(string cat)
    {
        if (cat == "Screenshots" || cat == "Memes")
            return;

        var mapped = cat switch
        {
            "Images" => MediaMainCategory.Image,
            "Videos" => MediaMainCategory.Video,
            "Documents" => MediaMainCategory.Document,
            "Audio" => MediaMainCategory.Audio,
            _ => (MediaMainCategory?)null
        };

        if (mapped == null)
            return;

        Navigation.NavigateTo($"/category-step/{mapped}");
    }

    void GoToExport()
    {
        Navigation.NavigateTo("/export");
    }

    string FormatSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double len = bytes;
        int order = 0;

        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }

        return $"{len:0.#} {sizes[order]}";
    }
    readonly string[] CategoryOrder =
    [
        "Audio",
        "Documents",
        "Images",
        "Videos",
        "Screenshots",
        "Memes"
    ];
}