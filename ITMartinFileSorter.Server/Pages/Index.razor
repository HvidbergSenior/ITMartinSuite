@page "/"
@page "/filesorter"

@inject DuplicateService DuplicateService
@inject IFileScanner FileScanner
@inject ProgressService Progress
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@inject FolderPathInfoService FolderPathInfoService
@inject ImageCategorizer ImageCategorizer
@inject VideoCategorizer VideoCategorizer
@inject DocumentCategorizer DocumentCategorizer
@inject AudioCategorizer AudioCategorizer
<div class="index-page">

    <SectionTitle Title="🎬 Scan & Organize Files" />

    <ContentCard CssClass="scan-hero-card">
        <p class="hero-text">
            Scan photos, videos, audio and documents.
            Start by selecting a folder to organize and detect duplicates.
        </p>

        <FolderInputPanel
            Value="@FolderPath"
            ValueChanged="OnFolderPathChanged"
            ButtonText="@(IsScanning ? "Scanning..." : "Scan Folder")"
            Disabled="@IsScanning"
            OnAction="ScanFolder" />
    </ContentCard>

    @if (!string.IsNullOrWhiteSpace(PathInfo))
    {
        <ContentCard Title="Folder Info">
            @foreach (var line in PathInfo.Split('\n'))
            {
                <div>@line</div>
            }
        </ContentCard>
    }

    @if (ShowScanning)
    {
        <ProgressPanel
            Title="@Progress.Info.Stage"
            Current="@Progress.Info.WorkDone"
            Total="@Progress.Info.TotalWork"
            Percent="@ProgressPercent"
            CurrentItem="@CurrentFileName" />
    }

    @if (ShowDuplicateWarning)
    {
        <ContentCard Title="Attention">
            <EmptyState
                Message="⚠ You must handle duplicates before continuing"
                Type="warning" />

            <div class="mt-3">
                <button class="btn btn-warning"
                        @onclick="GoToDuplicates">
                    Go to Duplicates
                </button>
            </div>
        </ContentCard>
    }

    @if (ShowSummary)
    {
        <SectionTitle Title="File Summary" />

        <div class="main-category-row mt-3">
            @foreach (var cat in CategoryOrder)
            {
                var filesInCat = cat switch
                {
                    "Screenshots" => DuplicateService.AllFiles
                        .Where(f => f.SubCategory == MediaSubCategory.Screenshot)
                        .ToList(),

                    "Memes" => DuplicateService.AllFiles
                        .Where(f => f.SubCategory == MediaSubCategory.Meme)
                        .ToList(),

                    _ => DuplicateService.AllFiles
                        .Where(f => f.MainCategory.ToString() == cat)
                        .ToList()
                };

                var total = filesInCat.Count;

                var remaining = cat is "Screenshots" or "Memes"
                    ? 0
                    : filesInCat.Count(f =>
                        f.Status == MediaFileStatus.Initial &&
                        !DuplicateService.DuplicateGroups.Any(g => g.Contains(f)));

                var kept = cat is "Screenshots" or "Memes"
                    ? total
                    : filesInCat.Count(f =>
                        f.Status == MediaFileStatus.ToKeep);

                var isAutoHandled = cat is "Screenshots" or "Memes";
                var isLocked = isAutoHandled || total == 0;

                <CategorySummaryCard
                    Title="@(isAutoHandled ? $"{cat} (Auto)" : cat)"
                    Remaining="@remaining"
                    Kept="@kept"
                    Total="@total"
                    SizeText="@FormatSize(filesInCat.Sum(f => f.SizeBytes))"
                    CssClass="@GetCategoryCssClass(cat)"
                    IsLocked="@isLocked"
                    OnClick="@(() => OnCategoryCardClicked(cat, isLocked))" />
            }
        </div>
    }

    @if (CanExport)
    {
        <ContentCard Title="Export Ready" CssClass="export-ready-card">
            <div class="alert alert-success mb-3">
                ✔ Ready for export
            </div>

            <button class="btn btn-success"
                    @onclick="GoToExport">
                Export Organized Files
            </button>
        </ContentCard>
    }

    <ContentCard CssClass="library-secondary-card">
        <div class="library-row">
            <div>
                <strong>Already scanned files?</strong>
                <div class="text-muted">
                    Browse previously organized files
                </div>
            </div>

            <button class="btn btn-outline-light"
                    @onclick="GoToLibrary">
                Open Library
            </button>
        </div>
    </ContentCard>

</div>

@code {
    string FolderPath
    {
        get => DuplicateService.FolderPath;
        set => DuplicateService.FolderPath = value;
    }

    bool IsScanning = false;
    string CurrentFileName = "";
    int FilesDiscovered = 0;
    string? PathInfo;

    int ProgressPercent =>
        Progress.Info.TotalWork == 0
            ? 0
            : (int)((double)Progress.Info.WorkDone / Progress.Info.TotalWork * 100);

    readonly string[] CategoryOrder =
    {
        "Audio",
        "Document",
        "Image",
        "Video",
        "Screenshots",
        "Memes"
    };

    bool ShowScanning => IsScanning;

    bool ShowDuplicateWarning =>
        !IsScanning &&
        DuplicateService.AllFiles.Any() &&
        !DuplicateService.DuplicatesHandled;

    bool ShowSummary =>
        !IsScanning &&
        DuplicateService.AllFiles.Any() &&
        DuplicateService.DuplicatesHandled;

    bool CanExport =>
        !IsScanning &&
        DuplicateService.AllFiles.Any() &&
        DuplicateService.DuplicatesHandled &&
        !DuplicateService.AllFiles.Any(f =>
            f.Status == MediaFileStatus.Initial &&
            !DuplicateService.DuplicateGroups.Any(g => g.Contains(f)));

    void GoToDuplicates() => Navigation.NavigateTo("/duplicates");
    void GoToExport() => Navigation.NavigateTo("/export");
    void GoToLibrary() => Navigation.NavigateTo("/library");

    void OnCategoryCardClicked(string cat, bool isLocked)
    {
        if (isLocked)
            return;

        Navigation.NavigateTo($"/category-step/{cat.ToLower()}");
    }

    string GetCategoryCssClass(string cat) => cat switch
    {
        "Audio" => "category-audio",
        "Document" => "category-document",
        "Image" => "category-image",
        "Video" => "category-video",
        "Screenshots" => "category-auto",
        "Memes" => "category-auto",
        _ => ""
    };

    void OnFolderPathChanged(string value)
    {
        FolderPath = value;
    }

    void CheckSelectedFolder(string selectedFolder)
    {
        var defaultPath = Configuration["MediaSettings:LibraryRoot"];

        PathInfo = FolderPathInfoService.GetPathInfo(
            defaultPath,
            selectedFolder);
    }

    string FormatSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double len = bytes;
        int order = 0;

        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }

        return $"{len:0.#} {sizes[order]}";
    }

    async Task ScanFolder()
    {
        if (IsScanning) return;

        var path = FolderPath;

        if (string.IsNullOrWhiteSpace(path) || !Directory.Exists(path))
            return;

        CheckSelectedFolder(path);

        IsScanning = true;
        FilesDiscovered = 0;
        CurrentFileName = "";

        DuplicateService.Reset();
        DuplicateService.FolderPath = path;

        var allPaths = Directory.GetFiles(path, "*", SearchOption.AllDirectories);

        Progress.Info.TotalWork = allPaths.Length;
        Progress.Info.WorkDone = 0;
        Progress.SetStage("Scanning files...");

        await InvokeAsync(StateHasChanged);

        DuplicateService.Cancellation = new CancellationTokenSource();
        var token = DuplicateService.Cancellation.Token;

        try
        {
            var files = new List<MediaFile>();
            int refreshCounter = 0;

            foreach (var file in FileScanner.ScanFolder(path))
            {
                Console.WriteLine(
                    $"{file.FileName} | {file.MainCategory} | {file.SubCategory} | {file.CreatedAt}");
                token.ThrowIfCancellationRequested();
                switch (file.MainCategory)
                {
                    case MediaMainCategory.Image:
                        ImageCategorizer.Categorize(file);
                        break;

                    case MediaMainCategory.Video:
                        VideoCategorizer.Categorize(file);
                        break;

                    case MediaMainCategory.Document:
                        DocumentCategorizer.Categorize(file);
                        break;

                    case MediaMainCategory.Audio:
                        AudioCategorizer.Categorize(file);
                        break;
                        
                }
                Console.WriteLine("===== FILE DEBUG =====");
                Console.WriteLine($"Name: {file.FileName}");
                Console.WriteLine($"Path: {file.FullPath}");
                Console.WriteLine($"MainCategory: {file.MainCategory}");
                Console.WriteLine($"SubCategory: {file.SubCategory}");
                Console.WriteLine($"CreatedAt: {file.CreatedAt}");
                Console.WriteLine($"Year: {file.Year}");
                Console.WriteLine($"Month: {file.Month}");
                Console.WriteLine($"DynamicFolder: {file.DynamicFolder}");
                Console.WriteLine("=======================");
                files.Add(file);
                FilesDiscovered++;

                Progress.Info.WorkDone = FilesDiscovered;
                CurrentFileName = file.FileName;

                refreshCounter++;

                if (refreshCounter % 10 == 0)
                {
                    await InvokeAsync(StateHasChanged);
                    await Task.Yield();
                }
            }

            await InvokeAsync(StateHasChanged);

            DuplicateService.AllFiles = files;

            Progress.SetStage("Building duplicate groups...");
            await InvokeAsync(StateHasChanged);

            await Task.Run(() => DuplicateService.BuildDuplicateGroups());

            Progress.Complete();
        }
        catch (OperationCanceledException)
        {
            Progress.SetStage("Cancelled");
        }
        finally
        {
            IsScanning = false;
            await InvokeAsync(StateHasChanged);
        }
    }
}