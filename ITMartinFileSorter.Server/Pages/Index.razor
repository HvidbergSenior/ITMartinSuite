@page "/"
@page "/filesorter"

@inject DuplicateService DuplicateService
@inject IFileScanner FileScanner
@inject ProgressService Progress
@inject NavigationManager Navigation
@inject ImageCategorizer ImageCategorizer
@inject VideoCategorizer VideoCategorizer
@inject DocumentCategorizer DocumentCategorizer
@inject AudioCategorizer AudioCategorizer

<PageLayout Title="📂 Scan & Organize Files">
    <div class="filesorter-app">
    <ContentCard CssClass="scan-hero-card">
        <p class="hero-text">
            Scan photos, videos, audio and documents.
        </p>

        <FolderInputPanel
            Value="@FolderPath"
            ValueChanged="OnFolderPathChanged"
            ButtonText="@(IsScanning ? "Scanning..." : "Scan Folder")"
            Disabled="@IsScanning"
            OnAction="ScanFolder" />
    </ContentCard>

    @if (ShowScanning)
    {
        <ProgressPanel
            Title="@Progress.Info.Stage"
            Current="@Progress.Info.WorkDone"
            Total="@Progress.Info.TotalWork"
            Percent="@ProgressPercent"
            CurrentItem="@CurrentFileName" />
    }

    @if (ShowSummary)
    {
        <SectionTitle Title="File Summary" />

        <div class="main-category-row mt-3">
            @foreach (var cat in CategoryOrder)
            {
                var filesInCat = cat switch
                {
                    "Screenshots" => DuplicateService.AllFiles
                        .Where(f => f.SubCategory == MediaSubCategory.Screenshot),

                    "Memes" => DuplicateService.AllFiles
                        .Where(f => f.SubCategory == MediaSubCategory.Meme),

                    _ => DuplicateService.AllFiles
                        .Where(f => f.MainCategory.ToString() == cat)
                };

                var allFiles = filesInCat.ToList();

// 🔥 ONLY files requiring user input
                var needsReview = allFiles.Count(f =>
                    f.RequiresReview &&
                    f.Status == MediaFileStatus.Initial);

// 🔥 ALL handled files (keep + delete)
                var processedCount = allFiles.Count(f =>
                    f.Status == MediaFileStatus.ToKeep ||
                    f.Status == MediaFileStatus.ToDelete);

                var total = allFiles.Count;

                var totalSize = allFiles
                    .Where(f => f.Status != MediaFileStatus.ToDelete) // 👈 only visible size
                    .Sum(f => f.SizeBytes);

                var isAuto = cat is "Screenshots" or "Memes";
                <CategorySummaryCard
                    Title="@(isAuto ? $"{cat} (Auto)" : cat)"
                    ReviewCount="@needsReview"
                    ProcessedCount="@processedCount"
                    Total="@total"
                    SizeText="@FormatSize(totalSize)"
                    CssClass="@GetCategoryCssClass(cat)"
                    OnClick="@(e => OpenCategory(cat))" />
            }
        </div>

        <ContentCard CssClass="mt-4 text-center">

            @if (!IsCompleted)
            {
                <div class="mb-2 text-muted">
                    Complete all categories to enable export
                </div>
            }
            else
            {
                <div class="mb-2 text-success">
                    ✔ All files processed — ready to export
                </div>
            }

            <button class="btn btn-success btn-lg"
                    disabled="@(!IsCompleted)"
                    @onclick="GoToExport">
                📦 Export Files
            </button>

        </ContentCard>
    }
    </div>

</PageLayout>
@code {

    string FolderPath
    {
        get => DuplicateService.FolderPath;
        set => DuplicateService.FolderPath = value;
    }

    bool IsScanning = false;
    string CurrentFileName = "";
    int FilesDiscovered = 0;

    bool IsCompleted =>
        DuplicateService.AllFiles
            .Any(f => f.RequiresReview && f.Status == MediaFileStatus.Initial) == false;
    int ProgressPercent =>
        Progress.Info.TotalWork == 0
            ? 1 // 🔥 ensures progress bar renders
            : (int)((double)Progress.Info.WorkDone / Progress.Info.TotalWork * 100);

    readonly string[] CategoryOrder =
    {
        "Audio",
        "Document",
        "Image",
        "Video",
        "Screenshots",
        "Memes"
    };

    bool ShowScanning => IsScanning;
    bool ShowSummary => !IsScanning && DuplicateService.AllFiles.Any();

    void OnFolderPathChanged(string value)
    {
        FolderPath = value;
    }

    string GetCategoryCssClass(string cat) => cat switch
    {
        "Audio" => "category-audio",
        "Document" => "category-document",
        "Image" => "category-image",
        "Video" => "category-video",
        "Screenshots" => "category-auto",
        "Memes" => "category-auto",
        _ => ""
    };

    async Task ScanFolder()
    {
        if (IsScanning) return;

        var path = FolderPath;
        if (string.IsNullOrWhiteSpace(path) || !Directory.Exists(path))
            return;

        IsScanning = true;
        FilesDiscovered = 0;
        CurrentFileName = "";

        DuplicateService.Reset();
        DuplicateService.FolderPath = path;

        var allPaths = Directory.GetFiles(path, "*", SearchOption.AllDirectories);

        // ✅ SET PROGRESS FIRST
        Progress.Info.TotalWork = allPaths.Length;
        Progress.Info.WorkDone = 0;
        Progress.SetStage("Scanning files...");

        // 🔥 FORCE UI RENDER BEFORE LOOP
        await InvokeAsync(StateHasChanged);
        await Task.Delay(50);

        var files = new List<MediaFile>();
        int refreshCounter = 0;

        foreach (var file in FileScanner.ScanFolder(path))
        {
            switch (file.MainCategory)
            {
                case MediaMainCategory.Image:
                    ImageCategorizer.Categorize(file);
                    break;
                case MediaMainCategory.Video:
                    VideoCategorizer.Categorize(file);
                    break;
                case MediaMainCategory.Document:
                    DocumentCategorizer.Categorize(file);
                    break;
                case MediaMainCategory.Audio:
                    AudioCategorizer.Categorize(file);
                    break;
            }

            files.Add(file);
            FilesDiscovered++;

            Progress.Info.WorkDone = FilesDiscovered;
            CurrentFileName = file.FileName;

            // 🔥 MORE FREQUENT UI UPDATES
            if (++refreshCounter % 5 == 0)
            {
                try
                {
                    await InvokeAsync(StateHasChanged);
                }
                catch (Microsoft.JSInterop.JSDisconnectedException)
                {
                    return;
                }
            }
        }

        DuplicateService.AllFiles = files;

        Progress.SetStage("Building duplicate groups...");
        await InvokeAsync(StateHasChanged);

        await Task.Run(() => DuplicateService.BuildDuplicateGroups());

        DuplicateService.NotifyStateChanged();

        // 🔥 GIVE USER TIME TO SEE RESULT BEFORE NAVIGATION
        if (DuplicateService.DuplicateGroups.Any())
        {
            Progress.SetStage("Duplicates found...");
            await InvokeAsync(StateHasChanged);
            await Task.Delay(400);

            IsScanning = false;
            Navigation.NavigateTo("/duplicates");
            return;
        }

        Progress.SetStage("Done");
        IsScanning = false;

        await InvokeAsync(StateHasChanged);
    }

    
    void OpenCategory(string cat)
    {
        Console.WriteLine($"NAVIGATE REQUEST: {cat}");

        if (cat == "Screenshots" || cat == "Memes")
        {
            Console.WriteLine("🚫 Auto category blocked");
            return;
        }

        if (!Enum.TryParse<MediaMainCategory>(cat, true, out _))
        {
            Console.WriteLine("❌ Invalid category");
            return;
        }

        var url = $"/category-step/{cat}";
        Console.WriteLine($"➡️ Navigating to: {url}");

        Navigation.NavigateTo(url);
    }
    void GoToExport()
    {
        Navigation.NavigateTo("/export");
    }

    string FormatSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double len = bytes;
        int order = 0;

        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }

        return $"{len:0.#} {sizes[order]}";
    }
}