@page "/"
@page "/filesorter"

@using ITMartin.Media.Application.Models
@using ITMartin.Media.Application.Pipelines
@using ITMartin.Media.Domain.Entities
@using ITMartin.Media.Enums
@using ITMartin.Media.Helpers
@using ITMartinFileSorter.Application.Services

@implements IDisposable

@inject Package1Pipeline Package1Pipeline
@inject ProgressService Progress
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@inject ILogger<Index> Logger

<PageLayout Title="📦 Package 1 — Cleanup & Structure">

    <div class="filesorter-app">

        <ContentCard CssClass="scan-hero-card">

            <h2 class="mb-3">
                Cleanup & Structure
            </h2>

            <p class="hero-text">
                Scan, deduplicate and organize media files.
            </p>

            <FolderInputPanel
                Value="@FolderPath"
                ValueChanged="OnFolderPathChanged"
                ButtonText="@(IsScanning
                    ? Progress.Info.Stage
                    : "Start Cleanup")"
                Disabled="@IsScanning"
                OnAction="ScanFolder" />

            @if (!string.IsNullOrWhiteSpace(ErrorMessage))
            {
                <div class="text-danger mt-2">
                    @ErrorMessage
                </div>
            }

        </ContentCard>

        @if (ShowScanning)
        {
            <ProgressPanel
                Title="@Progress.Info.Stage"
                Current="@Progress.Info.WorkDone"
                Total="@Progress.Info.TotalWork"
                Percent="@ProgressPercent"
                CurrentItem="@CurrentFileName"
                LoadingText="Processing media..."
                Icon="📂" />
        }

        @if (ShowSummary)
        {
            <SectionTitle Title="Cleanup Summary" />

            <div class="main-category-row mt-3">

                @foreach (var cat in CategoryOrder)
                {
                    var filesInCat =
                        ScanResult!.Files
                            .Where(f =>
                                CategoryHelper
                                    .GetCategory(f) == cat)
                            .ToList();

                    var totalSize =
                        filesInCat
                            .Where(f =>
                                f.Status !=
                                MediaFileStatus.ToDelete)
                            .Sum(f =>
                                f.SizeBytes);

                    <CategorySummaryCard
                        Title="@cat"
                        ReviewCount="0"
                        ProcessedCount="@filesInCat.Count"
                        Total="@filesInCat.Count"
                        SizeText="@FormatSize(totalSize)"
                        CssClass="@GetCategoryCssClass(cat)"
                        OnClick="@(e => {})" />
                }

            </div>

            <ContentCard CssClass="mt-4">

                <div class="summary-grid">

                    <div class="summary-box">
                        <div class="summary-title">
                            Total Files
                        </div>

                        <div class="summary-value">
                            @ScanResult!.TotalFiles
                        </div>
                    </div>

                    <div class="summary-box">
                        <div class="summary-title">
                            Files To Keep
                        </div>

                        <div class="summary-value">
                            @ScanResult!.KeepCount
                        </div>
                    </div>

                    <div class="summary-box">
                        <div class="summary-title">
                            Files To Delete
                        </div>

                        <div class="summary-value">
                            @ScanResult!.DeleteCount
                        </div>
                    </div>

                    <div class="summary-box">
                        <div class="summary-title">
                            Duplicate Groups
                        </div>

                        <div class="summary-value">
                            @ScanResult!.DuplicateGroups
                        </div>
                    </div>

                    <div class="summary-box">
                        <div class="summary-title">
                            Total Size
                        </div>

                        <div class="summary-value">
                            @FormatSize(
                                ScanResult!.TotalBytes)
                        </div>
                    </div>

                    <div class="summary-box">
                        <div class="summary-title">
                            Space Saved
                        </div>

                        <div class="summary-value">
                            @FormatSize(
                                ScanResult!.BytesToDelete)
                        </div>
                    </div>

                </div>

            </ContentCard>

            <ActionButtonBar CssClass="bottom export-bar">

                <div class="export-status">

                    <span class="text-success">
                        ✔ Cleanup completed — ready to export
                    </span>

                </div>

                <span class="spacer"></span>

                <button class="btn btn-success btn-lg"
                        @onclick="GoToExport">
                    📦 Export Files
                </button>

            </ActionButtonBar>
        }

    </div>

</PageLayout>

@code {

    private string FolderPath = "";

    private bool IsScanning;

    private string CurrentFileName = "";

    private string ErrorMessage = "";

    private Package1ScanResult? ScanResult;

    private int ProgressPercent =>
        Progress.Info.TotalWork == 0
            ? 1
            : (int)((double)
                Progress.Info.WorkDone /
                Progress.Info.TotalWork * 100);

    private bool ShowScanning =>
        IsScanning ||
        Progress.Info.WorkDone > 0;

    private bool ShowSummary =>
        !IsScanning &&
        ScanResult != null;

    private readonly string[] CategoryOrder =
    [
        "Audio",
        "Documents",
        "Images",
        "Videos",
        "Screenshots",
        "Memes"
    ];

    protected override void OnInitialized()
    {
        Progress.OnChange +=
            HandleProgressChanged;

        var source =
            Configuration[
                "MediaSettings:SourceRoot"];

        if (!string.IsNullOrWhiteSpace(source))
        {
            FolderPath = source;
        }
    }

    private void HandleProgressChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Progress.OnChange -=
            HandleProgressChanged;
    }

    private void OnFolderPathChanged(
        string value)
    {
        FolderPath = value;
    }

    private async Task ScanFolder()
    {
        if (IsScanning)
            return;

        ErrorMessage = "";

        if (string.IsNullOrWhiteSpace(
                FolderPath))
        {
            ErrorMessage =
                "Please enter a folder path.";

            return;
        }

        if (!Directory.Exists(FolderPath))
        {
            ErrorMessage =
                $"Folder not found: {FolderPath}";

            return;
        }

        try
        {
            IsScanning = true;

            ScanResult = null;

            await InvokeAsync(
                StateHasChanged);

            Logger.LogInformation(
                "Starting Package 1 scan");

            var paths =
                Directory
                    .EnumerateFiles(
                        FolderPath,
                        "*.*",
                        SearchOption
                            .AllDirectories)
                    .Count();

            Progress.Start(
                "Scanning files...",
                paths);

            ScanResult =
                await Package1Pipeline
                    .ScanAsync(
                        FolderPath,
                        (done,
                         total,
                         file) =>
                        {
                            CurrentFileName =
                                file;

                            Progress.Update(done);
                        });

            Progress.Complete();

            Logger.LogInformation(
                "Package 1 scan completed");
        }
        catch (Exception ex)
        {
            Logger.LogError(
                ex,
                "Package 1 failed");

            ErrorMessage =
                ex.Message;
        }
        finally
        {
            IsScanning = false;

            await InvokeAsync(
                StateHasChanged);
        }
    }

    private void GoToExport()
    {
        Navigation.NavigateTo(
            "/export");
    }

    private static string FormatSize(
        long bytes)
    {
        string[] sizes =
        [
            "B",
            "KB",
            "MB",
            "GB",
            "TB"
        ];

        double len = bytes;

        var order = 0;

        while (len >= 1024 &&
               order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }

        return
            $"{len:0.#} {sizes[order]}";
    }

    private static string GetCategoryCssClass(
        string cat) =>
        cat switch
        {
            "Audio" =>
                "category-audio",

            "Documents" =>
                "category-document",

            "Images" =>
                "category-image",

            "Videos" =>
                "category-video",

            "Screenshots" =>
                "category-auto",

            "Memes" =>
                "category-auto",

            _ => ""
        };
}