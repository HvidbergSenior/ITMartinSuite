@page "/"
@page "/filesorter"

@using ITMartin.Media.Domain.Entities
@using ITMartin.Media.Enums
@using ITMartin.Media.Helpers
@using ITMartin.Media.Interfaces
@using ITMartinFileSorter.Application.Services

@implements IDisposable

@inject DuplicateService DuplicateService
@inject IFileScanner FileScanner
@inject ProgressService Progress
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@inject IAiEnrichmentService AiEnrichmentService
@inject ILogger<Index> Logger

<PageLayout Title="📂 Scan & Organize Files">

    <div class="filesorter-app">

        <ContentCard CssClass="scan-hero-card">

            <p class="hero-text">
                Scan photos, videos, audio and documents.
            </p>

            <FolderInputPanel
                Value="@FolderPath"
                ValueChanged="OnFolderPathChanged"
                ButtonText="@(IsScanning ? "Scanning..." : "Scan Folder")"
                Disabled="@IsScanning"
                OnAction="ScanFolder" />

            @if (!string.IsNullOrWhiteSpace(ErrorMessage))
            {
                <div class="text-danger mt-2">
                    @ErrorMessage
                </div>
            }

        </ContentCard>

        @if (ShowScanning)
        {
            <ProgressPanel
                Title="@Progress.Info.Stage"
                Current="@Progress.Info.WorkDone"
                Total="@Progress.Info.TotalWork"
                Percent="@ProgressPercent"
                CurrentItem="@CurrentFileName"
                LoadingText="Scanning files..."
                Icon="📂" />
        }

        @if (ShowSummary)
        {
            <SectionTitle Title="File Summary" />

            <div class="main-category-row mt-3">

                @foreach (var cat in CategoryOrder)
                {
                    var filesInCat = DuplicateService.AllFiles
                        .Where(f => CategoryHelper.GetCategory(f) == cat)
                        .ToList();

                    var needsReview = filesInCat.Count(f =>
                        f.RequiresReview &&
                        f.Status == MediaFileStatus.Initial);

                    var processedCount = filesInCat.Count(f =>
                        f.Status == MediaFileStatus.ToKeep ||
                        f.Status == MediaFileStatus.ToDelete);

                    var totalSize = filesInCat
                        .Where(f => f.Status != MediaFileStatus.ToDelete)
                        .Sum(f => f.SizeBytes);

                    var isAuto = cat is "Screenshots" or "Memes";

                    <CategorySummaryCard
                        Title="@(isAuto ? $"{cat} (Auto)" : cat)"
                        ReviewCount="@needsReview"
                        ProcessedCount="@processedCount"
                        Total="@filesInCat.Count"
                        SizeText="@FormatSize(totalSize)"
                        CssClass="@GetCategoryCssClass(cat)"
                        OnClick="@(e => OpenCategory(cat))" />
                }

            </div>

            <ActionButtonBar CssClass="bottom export-bar">

                <div class="export-status">

                    @if (!IsCompleted)
                    {
                        <span class="text-muted">
                            Complete all categories to enable export
                        </span>
                    }
                    else
                    {
                        <span class="text-success">
                            ✔ All files processed — ready to export
                        </span>
                    }

                </div>

                <span class="spacer"></span>

                <button class="btn btn-success btn-lg"
                        disabled="@(!IsCompleted)"
                        @onclick="GoToExport">
                    📦 Export Files
                </button>

            </ActionButtonBar>
        }

    </div>

</PageLayout>

@code {

    private string FolderPath
    {
        get => DuplicateService.FolderPath;
        set => DuplicateService.FolderPath = value;
    }

    private bool IsScanning;

    private string CurrentFileName = "";

    private string ErrorMessage = "";

    private bool IsCompleted =>
        DuplicateService.AllFiles
            .Any(f =>
                f.RequiresReview &&
                f.Status == MediaFileStatus.Initial) == false;

    private int ProgressPercent =>
        Progress.Info.TotalWork == 0
            ? 1
            : (int)((double)Progress.Info.WorkDone /
                    Progress.Info.TotalWork * 100);

    private bool ShowScanning =>
        IsScanning || Progress.Info.WorkDone > 0;

    private bool ShowSummary =>
        !IsScanning &&
        DuplicateService.AllFiles.Any();

    private readonly string[] CategoryOrder =
    [
        "Audio",
        "Documents",
        "Images",
        "Videos",
        "Screenshots",
        "Memes"
    ];

    protected override void OnInitialized()
    {
        Progress.OnChange += HandleProgressChanged;

        var source =
            Configuration["MediaSettings:SourceRoot"];

        if (!string.IsNullOrWhiteSpace(source))
        {
            DuplicateService.FolderPath = source;
        }
    }

    private void HandleProgressChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Progress.OnChange -= HandleProgressChanged;
    }

    private void OnFolderPathChanged(string value)
    {
        FolderPath = value;
    }

    private async Task ScanFolder()
    {
        if (IsScanning)
            return;

        ErrorMessage = "";

        var path = FolderPath;

        Logger.LogInformation(
            "Starting scan for {Path}",
            path);

        if (string.IsNullOrWhiteSpace(path))
        {
            ErrorMessage =
                "Please enter a folder path.";

            return;
        }

        if (!Directory.Exists(path))
        {
            ErrorMessage =
                $"Folder not found: {path}";

            Logger.LogWarning(
                "Folder not found: {Path}",
                path);

            return;
        }

        IsScanning = true;

        await InvokeAsync(StateHasChanged);

        CurrentFileName = "";

        DuplicateService.Reset();

        DuplicateService.FolderPath = path;

        var bag =
            new System.Collections.Concurrent
                .ConcurrentBag<MediaFile>();

        var allPaths =
            FileScanner.EnumerateFiles(path)
                .ToList();

        Progress.Start(
            "Scanning files...",
            allPaths.Count);

        var lastRender = DateTime.UtcNow;

        await Parallel.ForEachAsync(
            allPaths,
            new ParallelOptions
            {
                MaxDegreeOfParallelism =
                    Environment.ProcessorCount
            },
            async (filePath, ct) =>
            {
                try
                {
                    var file =
                        FileScanner.ProcessFile(filePath);

                    if (file == null)
                        return;

                    file.RequiresReview = true;

                    file.Status =
                        MediaFileStatus.Initial;

                    if (file.SubCategory is
                        MediaSubCategory.Meme or
                        MediaSubCategory.Screenshot)
                    {
                        file.RequiresReview = false;

                        file.Status =
                            MediaFileStatus.ToKeep;
                    }

                    bag.Add(file);

                    Progress.Increment();

                    await InvokeAsync(() =>
                    {
                        CurrentFileName =
                            Path.GetFileName(filePath);

                        if ((DateTime.UtcNow - lastRender)
                            .TotalMilliseconds > 100)
                        {
                            lastRender = DateTime.UtcNow;

                            StateHasChanged();
                        }
                    });
                }
                catch (Exception ex)
                {
                    Logger.LogError(
                        ex,
                        "Failed processing file {File}",
                        filePath);
                }
            });

        DuplicateService.AllFiles =
            bag.ToList();

        Progress.SetStage(
            "Removing duplicates...");

        await Task.Run(() =>
            DuplicateService.BuildDuplicateGroups());

        Progress.SetStage(
            "AI enrichment...");

        await AiEnrichmentService.EnrichBatchAsync(
            DuplicateService.AllFiles,
            async () =>
            {
                await InvokeAsync(StateHasChanged);
            });

        Progress.Complete();

        IsScanning = false;

        Logger.LogInformation(
            "Scan completed for {Path}",
            path);

        await InvokeAsync(StateHasChanged);
    }

    private void OpenCategory(string cat)
    {
        if (cat == "Screenshots" ||
            cat == "Memes")
        {
            return;
        }

        var mapped = cat switch
        {
            "Images" => MediaMainCategory.Image,
            "Videos" => MediaMainCategory.Video,
            "Documents" => MediaMainCategory.Document,
            "Audio" => MediaMainCategory.Audio,
            _ => (MediaMainCategory?)null
        };

        if (mapped == null)
            return;

        Navigation.NavigateTo(
            $"/category-step/{mapped}");
    }

    private void GoToExport()
    {
        Navigation.NavigateTo("/export");
    }

    private static string FormatSize(long bytes)
    {
        string[] sizes =
        [
            "B",
            "KB",
            "MB",
            "GB",
            "TB"
        ];

        double len = bytes;

        var order = 0;

        while (len >= 1024 &&
               order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }

        return $"{len:0.#} {sizes[order]}";
    }

    private static string GetCategoryCssClass(
        string cat) =>
        cat switch
        {
            "Audio" => "category-audio",
            "Documents" => "category-document",
            "Images" => "category-image",
            "Videos" => "category-video",
            "Screenshots" => "category-auto",
            "Memes" => "category-auto",
            _ => ""
        };
}