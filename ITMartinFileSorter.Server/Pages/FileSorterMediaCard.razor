@inject ThumbnailService ThumbnailService
<div class="media-clickable"
     @onclick="() => OnKeep.InvokeAsync(File)">
    <MediaCard
        Title="@File.FileName"
        SizeText="@FormatSize(File.SizeBytes)"
        ImageUrl="@GetThumbnail()"
        Icon="@GetIcon()"
        PrimaryText="Keep"
        OnPrimary="() => OnKeep.InvokeAsync(File)" />
</div>
@code {

    [Parameter] public MediaFile File { get; set; } = default!;
    [Parameter] public EventCallback<MediaFile> OnKeep { get; set; }
    [Parameter] public bool ShowThumbnail { get; set; } = false;
    [Parameter] public EventCallback<MediaFile> OnDelete { get; set; }

    protected override void OnParametersSet()
    {
        if (!ShowThumbnail)
            return;

        if (string.IsNullOrEmpty(File.ThumbnailPath) &&
            File.Type == MediaType.Image)
        {
            File.ThumbnailPath = ThumbnailService.GenerateThumbnail(File);
        }
    }

    string? GetThumbnail()
    {
        if (!ShowThumbnail) return null;

        return File.ThumbnailPath;
    }

    string GetIcon() => File.MainCategory switch
    {
        MediaMainCategory.Image => "🖼️",
        MediaMainCategory.Video => "🎬",
        MediaMainCategory.Audio => "🎵",
        _ => "📄"
    };

    string FormatSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double len = bytes;
        int order = 0;

        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }

        return $"{len:0.#} {sizes[order]}";
    }
}