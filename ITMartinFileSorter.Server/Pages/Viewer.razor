@page "/viewer"

@using ITMartin.Media.Infrastructure.FileSystem
@using Microsoft.AspNetCore.WebUtilities

@inject NavigationManager Navigation
@inject IConfiguration Configuration
@inject ILogger<Viewer> Logger

<div class="viewer-root">

    <div class="viewer-page">

        <!-- HEADER -->
        <div class="viewer-header">

            <div class="viewer-title">
                @Path.GetFileName(FilePath)
            </div>

        </div>

        <!-- CONTENT -->
        <div class="viewer-content">

            <div class="viewer-stage"
                 @ref="StageRef"
                 @onclick="HandleStageClick"
                 tabindex="0"
                 @onkeydown="HandleKey">

                @if (!string.IsNullOrWhiteSpace(FilePath))
                {
                    @if (IsVideo)
                    {
                        <video class="viewer-media"
                               controls
                               autoplay
                               playsinline
                               preload="metadata"
                               @onclick:stopPropagation
                               @key="WebPath">

                            <source src="@WebPath" />

                        </video>
                    }
                    else
                    {
                        <img class="viewer-media"
                             src="@WebPath"
                             alt="@Path.GetFileName(FilePath)"
                             @onclick:stopPropagation />
                    }
                }

                @if (IsVideo)
                {
                    <!-- VIDEO NAV -->

                    <button class="nav-video left"
                            @onclick="PlayPrevious">
                        ❮
                    </button>

                    <button class="nav-video right"
                            @onclick="PlayNext">
                        ❯
                    </button>
                }
                else
                {
                    <!-- IMAGE NAV -->

                    <div class="nav-zone left"
                         @onclick="PlayPrevious">
                    </div>

                    <div class="nav-zone right"
                         @onclick="PlayNext">
                    </div>

                    <div class="nav-btn left">
                        ❮
                    </div>

                    <div class="nav-btn right">
                        ❯
                    </div>
                }

            </div>

        </div>

        <!-- CONTROLS -->
        <div class="viewer-controls">

            <button class="btn"
                    @onclick="GoHome">
                🏠
            </button>

            <button class="btn"
                    @onclick="GoToFolder">
                📁
            </button>

        </div>

    </div>

</div>

@code {

    private string FilePath = "";

    private string WebPath = "";

    private bool IsVideo;

    private List<string> Playlist = [];

    private int CurrentIndex;

    private string FolderPath = "";

    private ElementReference StageRef;

    protected override void OnParametersSet()
    {
        var uri =
            Navigation.ToAbsoluteUri(
                Navigation.Uri);

        var query =
            QueryHelpers.ParseQuery(uri.Query);

        if (!query.TryGetValue("path", out var path))
        {
            Logger.LogWarning(
                "Viewer opened without path query");

            return;
        }

        FilePath =
            Uri.UnescapeDataString(path!);

        FolderPath =
            Path.GetDirectoryName(FilePath)
            ?? "";

        if (!Directory.Exists(FolderPath))
        {
            Logger.LogWarning(
                "Viewer folder does not exist: {Folder}",
                FolderPath);

            return;
        }

        Playlist = Directory
            .EnumerateFiles(FolderPath)
            .Where(FileScanner.IsSupportedMedia)
            .OrderBy(x => x)
            .ToList();

        CurrentIndex =
            Playlist.FindIndex(f =>
                f == FilePath);

        if (CurrentIndex < 0)
        {
            CurrentIndex = 0;
        }

        Logger.LogInformation(
            "Loaded viewer for {File}",
            FilePath);

        Load();
    }

    protected override async Task OnAfterRenderAsync(
        bool firstRender)
    {
        if (firstRender)
        {
            await StageRef.FocusAsync();
        }
    }

    private void Load()
    {
        if (!Playlist.Any())
        {
            return;
        }

        FilePath = Playlist[CurrentIndex];

        var root =
            Configuration["MediaSettings:LibraryRoot"];

        if (string.IsNullOrWhiteSpace(root))
        {
            Logger.LogWarning(
                "LibraryRoot missing in configuration");

            return;
        }

        var relative = Path
            .GetRelativePath(root, FilePath)
            .Replace("\\", "/");

        WebPath =
            $"/libraryfiles/{relative}";

        IsVideo =
            FileScanner.IsVideo(FilePath);

        Logger.LogInformation(
            "Viewing file {File}",
            FilePath);

        StateHasChanged();
    }

    private void PlayNext()
    {
        if (!Playlist.Any())
            return;

        CurrentIndex =
            (CurrentIndex + 1) %
            Playlist.Count;

        Load();
    }

    private void PlayPrevious()
    {
        if (!Playlist.Any())
            return;

        CurrentIndex =
            (CurrentIndex - 1 + Playlist.Count) %
            Playlist.Count;

        Load();
    }

    private void GoHome()
    {
        Navigation.NavigateTo(
            "/library",
            true);
    }

    private void GoToFolder()
    {
        Navigation.NavigateTo(
            $"/library?path={Uri.EscapeDataString(FolderPath)}",
            true);
    }

    private void HandleStageClick(
        MouseEventArgs e)
    {
        if (!IsVideo)
        {
            PlayNext();
        }
    }

    private void HandleKey(
        KeyboardEventArgs e)
    {
        if (e.Key == "ArrowRight")
        {
            PlayNext();
        }

        if (e.Key == "ArrowLeft")
        {
            PlayPrevious();
        }

        if (e.Key == "Escape")
        {
            GoToFolder();
        }
    }
}