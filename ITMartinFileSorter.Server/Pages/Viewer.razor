@page "/viewer"

@using ITMartinFileSorter.Application.Helpers
@using Microsoft.AspNetCore.WebUtilities
@using ITMartinFileSorter.Infrastructure.FileSystem

@inject NavigationManager Navigation
@inject IConfiguration Configuration

<div class="viewer-root">

    <div class="viewer-page">

        <!-- HEADER -->
        <div class="viewer-header">
            <div class="viewer-title">
                @Path.GetFileName(FilePath)
            </div>
        </div>

        <!-- CONTENT -->
        <div class="viewer-content">

            <div class="viewer-stage"
                 @ref="StageRef"
                 @onclick="HandleStageClick"
                 tabindex="0"
                 @onkeydown="HandleKey">

                @if (!string.IsNullOrEmpty(FilePath))
                {
                    @if (IsVideo)
                    {
                        <video class="viewer-media"
                               controls
                               autoplay
                               playsinline
                               preload="metadata"
                               @onclick:stopPropagation
                               @key="WebPath">
                            <source src="@WebPath" />
                        </video>
                    }
                    else
                    {
                        <img class="viewer-media"
                             src="@WebPath"
                             @onclick:stopPropagation />
                    }
                }

                @if (IsVideo)
                {
                    <!-- ✅ CLEAN VIDEO NAV -->
                    <button class="nav-video left" @onclick="PlayPrevious">❮</button>
                    <button class="nav-video right" @onclick="PlayNext">❯</button>
                }
                else
                {
                    <!-- ✅ FULL IMAGE UX -->
                    <div class="nav-zone left" @onclick="PlayPrevious"></div>
                    <div class="nav-zone right" @onclick="PlayNext"></div>

                    <div class="nav-btn left">❮</div>
                    <div class="nav-btn right">❯</div>
                }

            </div>

        </div>

        <!-- CONTROLS -->
        <div class="viewer-controls">
            <button class="btn" @onclick="GoHome">🏠</button>
            <button class="btn" @onclick="GoToFolder">📁</button>
        </div>

    </div>
</div>

@code {
    private string FilePath = "";
    private string WebPath = "";
    private bool IsVideo;

    private List<string> Playlist = new();
    private int CurrentIndex = 0;
    private string FolderPath = "";

    private ElementReference StageRef;

    protected override void OnParametersSet()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (!query.TryGetValue("path", out var path))
            return;

        FilePath = Uri.UnescapeDataString(path!);
        FolderPath = Path.GetDirectoryName(FilePath) ?? "";

        if (!Directory.Exists(FolderPath))
            return;

        Playlist = Directory
            .EnumerateFiles(FolderPath)
            .Where(FileScanner.IsSupportedMedia)
            .OrderBy(x => x)
            .ToList();

        CurrentIndex = Playlist.FindIndex(f => f == FilePath);
        if (CurrentIndex < 0) CurrentIndex = 0;

        Load();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await StageRef.FocusAsync();
        }
    }

    private void Load()
    {
        if (!Playlist.Any()) return;

        FilePath = Playlist[CurrentIndex];

        var root = LibraryPathHelper.GetLibraryPath(Configuration);

        var relative = Path.GetRelativePath(root, FilePath)
            .Replace("\\", "/");

        WebPath = $"/libraryfiles/{relative}";
        IsVideo = FileScanner.IsVideo(FilePath);

        StateHasChanged();
    }

    private void PlayNext()
    {
        CurrentIndex = (CurrentIndex + 1) % Playlist.Count;
        Load();
    }

    private void PlayPrevious()
    {
        CurrentIndex = (CurrentIndex - 1 + Playlist.Count) % Playlist.Count;
        Load();
    }

    private void GoHome()
    {
        Navigation.NavigateTo("/library", true);
    }

    private void GoToFolder()
    {
        Navigation.NavigateTo($"/library?path={Uri.EscapeDataString(FolderPath)}", true);
    }

    void HandleStageClick(MouseEventArgs e)
    {
        if (!IsVideo)
            PlayNext();
    }

    void HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "ArrowRight") PlayNext();
        if (e.Key == "ArrowLeft") PlayPrevious();
        if (e.Key == "Escape") GoToFolder();
    }
}