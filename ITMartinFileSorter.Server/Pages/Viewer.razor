@page "/viewer"

@using ITMartinFileSorter.Application.Helpers
@using Microsoft.AspNetCore.WebUtilities
@using ITMartinFileSorter.Infrastructure.FileSystem

@inject NavigationManager Navigation
@inject IConfiguration Configuration

<div class="filesorter-app">
    <div class="page-container stack viewer-page">

        <!-- NAVIGATION -->
        <ActionButtonBar CssClass="bottom">

            <div class="row">
                <button class="btn btn-secondary" @onclick="GoHome">
                    🏠 Home
                </button>

                <button class="btn btn-secondary" @onclick="GoToFolder">
                    📁 Folder
                </button>
            </div>

            <div class="row">
                <button class="btn btn-secondary" @onclick="PlayPrevious">
                    ⬅ Previous
                </button>

                <button class="btn btn-primary" @onclick="PlayNext">
                    Next ➜
                </button>
            </div>

        </ActionButtonBar>

        <!-- MEDIA -->
        @if (!string.IsNullOrEmpty(FilePath))
        {
            <div class="viewer-stage">

                <div class="viewer-title">
                    @Path.GetFileName(FilePath)
                </div>

                @if (IsVideo)
                {
                    <video class="viewer-media"
                           controls
                           autoplay
                           @key="WebPath">
                        <source src="@WebPath" />
                    </video>
                }
                else
                {
                    <img class="viewer-media" src="@WebPath" />
                }

            </div>
        }

    </div>
</div>

@code {
    private string FilePath = "";
    private string WebPath = "";
    private bool IsVideo;

    private List<string> Playlist = new();
    private int CurrentIndex = 0;

    protected override void OnParametersSet()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (!query.TryGetValue("path", out var path))
            return;

        FilePath = Uri.UnescapeDataString(path!);

        var folder = Path.GetDirectoryName(FilePath);

        if (string.IsNullOrWhiteSpace(folder) || !Directory.Exists(folder))
            return;

        Playlist = Directory
            .EnumerateFiles(folder)
            .Where(FileScanner.IsSupportedMedia)
            .OrderBy(x => x)
            .ToList();

        CurrentIndex = Playlist.FindIndex(f =>
            string.Equals(f, FilePath, StringComparison.OrdinalIgnoreCase));

        if (CurrentIndex < 0)
            CurrentIndex = 0;

        LoadCurrentMedia();
    }

    private void LoadCurrentMedia()
    {
        if (!Playlist.Any())
            return;

        FilePath = Playlist[CurrentIndex];

        var libraryRoot = LibraryPathHelper.GetLibraryPath(Configuration);

        var relativePath = Path.GetRelativePath(libraryRoot, FilePath)
            .Replace("\\", "/");

        WebPath = $"/libraryfiles/{relativePath}";

        IsVideo = FileScanner.IsVideo(FilePath);

        StateHasChanged(); // 🔥 FIX: ensures UI updates on next/prev
    }

    private void PlayNext()
    {
        if (Playlist.Count == 0) return;

        CurrentIndex = (CurrentIndex + 1) % Playlist.Count;

        LoadCurrentMedia();
    }

    private void PlayPrevious()
    {
        if (Playlist.Count == 0) return;

        CurrentIndex--;

        if (CurrentIndex < 0)
            CurrentIndex = Playlist.Count - 1;

        LoadCurrentMedia();
    }

    private void GoHome()
    {
        Navigation.NavigateTo("/library", true);
    }

    private void GoToFolder()
    {
        Navigation.NavigateTo("/library", true);
    }
}