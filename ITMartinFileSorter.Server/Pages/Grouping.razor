@page "/grouping"
@using ITMartinFileSorter.Application.Helpers
@using ITMartinFileSorter.Application.Services

@inject DuplicateService DuplicateService
@inject NavigationManager Navigation

<div class="container mt-4">

    <SectionTitle Title="Choose Organization Method" />

    <ContentCard Title="Options">
        <select class="form-select mb-3" @bind="Options.Strategy">
            @foreach (GroupingStrategy s in Enum.GetValues<GroupingStrategy>())
            {
                <option value="@s">@s</option>
            }
        </select>

        <div class="form-check">
            <input type="checkbox"
                   class="form-check-input"
                   @bind="Options.CreateSubfolders" />
            <label>Create subfolders</label>
        </div>

        <div class="form-check mb-3">
            <input type="checkbox"
                   class="form-check-input"
                   @bind="Options.RenameFiles" />
            <label>Rename files</label>
        </div>
    </ContentCard>

    <ActionButtonBar>
        <button class="btn btn-success"
                @onclick="Continue">
            Continue to Export
        </button>
    </ActionButtonBar>

</div>

@code {

    GroupingOptions Options = new();

    void Continue()
    {
        DuplicateService.GroupingOptions = Options;
        Navigation.NavigateTo("/export");
    }
}