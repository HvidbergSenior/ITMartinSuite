@page "/category-step/{CategoryString}"

@inject DuplicateService DuplicateService
@inject NavigationManager Navigation

<div class="page-container">

    <ActionButtonBar>
        <button class="btn btn-primary"
                @onclick="Continue"
                disabled="@(!CanContinue)">
            Continue
        </button>

        <button class="btn btn-success"
                @onclick="AcceptAll"
                disabled="@(!HasPending)">
            Accept All
        </button>
    </ActionButtonBar>

    <SectionTitle Title="@($"Step: {CurrentCategory}")" />

    @foreach (var group in Groups)
    {
        <ContentCard Title="@group.Key.ToString()">
            @foreach (var file in group.Value)
            {
                <MediaCard File="file"
                           OnKeep="Keep"
                           OnDelete="Delete" />

                @RenderStatus(file)
            }
        </ContentCard>
    }

</div>

@code {

    [Parameter] public string CategoryString { get; set; } = "";

    MediaMainCategory CurrentCategory;
    Dictionary<int, List<MediaFile>> Groups = new();

    protected override void OnInitialized()
    {
        CurrentCategory = Enum.Parse<MediaMainCategory>(CategoryString, true);
        Load();
    }

    void Load()
    {
        var activeDuplicateFiles = DuplicateService.DuplicateGroups
            .Where(g => !DuplicateService.IsGroupHandled(g))
            .SelectMany(g => g)
            .ToHashSet();

        var files = DuplicateService.AllFiles
            .Where(f =>
                f.MainCategory == CurrentCategory &&
                !activeDuplicateFiles.Contains(f)) // 🔥 ONLY exclude active duplicates
            .ToList();

        Groups = files
            .GroupBy(f => f.Year)
            .OrderByDescending(g => g.Key)
            .ToDictionary(g => g.Key, g => g.ToList());
    }

    void Keep(MediaFile file)
    {
        var group = DuplicateService.DuplicateGroups
            .FirstOrDefault(g => g.Contains(file));

        if (group is not null)
        {
            foreach (var f in group)
            {
                f.Status = f == file
                    ? MediaFileStatus.ToKeep
                    : MediaFileStatus.ToDelete;
            }
        }
        else
        {
            file.Status = MediaFileStatus.ToKeep;
        }

        DuplicateService.NotifyStateChanged();
        Load();
    }

    void Delete(MediaFile file)
    {
        file.Status = MediaFileStatus.ToDelete;

        DuplicateService.NotifyStateChanged();
        Load();
    }

    void AcceptAll()
    {
        foreach (var file in DuplicateService.AllFiles
                     .Where(f =>
                         f.MainCategory == CurrentCategory &&
                         f.RequiresReview &&                         // 🔥 IMPORTANT
                         f.Status == MediaFileStatus.Initial))
        {
            file.Status = MediaFileStatus.ToKeep;
        }

        DuplicateService.NotifyStateChanged();
        Load();
    }

    bool HasPending =>
        DuplicateService.AllFiles.Any(f =>
            f.MainCategory == CurrentCategory &&
            f.RequiresReview &&
            f.Status == MediaFileStatus.Initial);

    bool CanContinue =>
        !HasPending;

    void Continue()
    {
        Navigation.NavigateTo("/filesorter");
    }

    RenderFragment RenderStatus(MediaFile file) => builder =>
    {
        if (file.Status == MediaFileStatus.ToKeep)
            builder.AddMarkupContent(0, "<span class='badge bg-success'>Kept</span>");
        else if (file.Status == MediaFileStatus.ToDelete)
            builder.AddMarkupContent(1, "<span class='badge bg-danger'>Deleted</span>");
        else
            builder.AddMarkupContent(2, "<span class='badge bg-warning'>Pending</span>");
    };
}