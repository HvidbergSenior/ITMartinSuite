@page "/category-step/{CategoryString}"

@using ITMartin.Media.Domain.Entities
@using ITMartin.Media.Enums
@using ITMartinFileSorter.Application.Services

@inject DuplicateService DuplicateService
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@inject ILogger<CategoryStep> Logger

<div class="filesorter-app">

    <div class="page-container stack category-step-page">

        <SectionTitle Title="@($"Step: {CurrentCategory}")" />

        <ActionButtonBar>

            <button class="btn btn-secondary"
                    @onclick="AcceptAll"
                    disabled="@(!HasPending)">
                Accept All
            </button>

        </ActionButtonBar>

        <ActionButtonBar CssClass="bottom">

            <button class="btn btn-primary btn-lg"
                    @onclick="Continue"
                    disabled="@(!CanContinue)">
                Continue
            </button>

        </ActionButtonBar>

        @if (!Groups.Any())
        {
            <ContentCard Title="No files found">

                <div class="text-muted">
                    No files available in this category.
                </div>

            </ContentCard>
        }

        @foreach (var group in Groups)
        {
            <ContentCard Title="@group.Key.ToString()">

                <div class="grid grid-3">

                    @foreach (var file in group.Value)
                    {
                        <div class="stack">

                            <MediaCard
                                Title="@file.FileName"
                                SizeText="@FormatSize(file.SizeBytes)"
                                ImageUrl="@ToWebPath(file.ExportedPath)"
                                Icon="🖼️"
                                PrimaryText="Keep"
                                OnPrimary="@(() => Keep(file))"
                                OnSecondary="@(() => Delete(file))" />

                            <div class="media-status">
                                @RenderStatus(file)
                            </div>

                        </div>
                    }

                </div>

            </ContentCard>
        }

    </div>

</div>

@code {

    [Parameter]
    public string CategoryString { get; set; } = "";

    private MediaMainCategory CurrentCategory;

    private Dictionary<int, List<MediaFile>> Groups = new();

    protected override void OnParametersSet()
    {
        if (!Enum.TryParse<MediaMainCategory>(
                CategoryString,
                true,
                out CurrentCategory))
        {
            Logger.LogWarning(
                "Invalid category route: {Category}",
                CategoryString);

            Navigation.NavigateTo("/filesorter");

            return;
        }

        Load();
    }

    private void Load()
    {
        var files = DuplicateService.AllFiles
            .Where(f => f.MainCategory == CurrentCategory)
            .ToList();

        Groups = files
            .GroupBy(f => f.Year)
            .OrderByDescending(g => g.Key)
            .ToDictionary(
                g => g.Key,
                g => g.ToList());

        Logger.LogInformation(
            "Loaded {Count} files for category {Category}",
            files.Count,
            CurrentCategory);
    }

    private void Keep(MediaFile file)
    {
        file.Status = MediaFileStatus.ToKeep;

        Logger.LogInformation(
            "File marked as kept: {File}",
            file.FileName);

        Load();
    }

    private void Delete(MediaFile file)
    {
        file.Status = MediaFileStatus.ToDelete;

        Logger.LogInformation(
            "File marked as delete: {File}",
            file.FileName);

        Load();
    }

    private void AcceptAll()
    {
        var files = DuplicateService.AllFiles
            .Where(f =>
                f.MainCategory == CurrentCategory &&
                f.RequiresReview &&
                f.Status == MediaFileStatus.Initial)
            .ToList();

        foreach (var file in files)
        {
            file.Status = MediaFileStatus.ToKeep;
        }

        Logger.LogInformation(
            "Accepted all pending files for category {Category}. Count: {Count}",
            CurrentCategory,
            files.Count);

        Load();
    }

    private bool HasPending =>
        DuplicateService.AllFiles.Any(f =>
            f.MainCategory == CurrentCategory &&
            f.RequiresReview &&
            f.Status == MediaFileStatus.Initial);

    private bool CanContinue => !HasPending;

    private void Continue()
    {
        Logger.LogInformation(
            "Continuing from category {Category}",
            CurrentCategory);

        Navigation.NavigateTo("/filesorter");
    }

    private RenderFragment RenderStatus(MediaFile file) => builder =>
    {
        if (file.Status == MediaFileStatus.ToKeep)
        {
            builder.AddMarkupContent(
                0,
                "<span class='status kept'>✔ Kept</span>");
        }
        else if (file.Status == MediaFileStatus.ToDelete)
        {
            builder.AddMarkupContent(
                1,
                "<span class='status duplicate'>⚠ Duplicate</span>");
        }
        else
        {
            builder.AddMarkupContent(
                2,
                "<span class='status pending'>● Pending</span>");
        }
    };

    private static string FormatSize(long bytes)
    {
        string[] sizes =
        [
            "B",
            "KB",
            "MB",
            "GB",
            "TB"
        ];

        double len = bytes;

        var order = 0;

        while (len >= 1024 &&
               order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }

        return $"{len:0.#} {sizes[order]}";
    }

    private string ToWebPath(string? fullPath)
    {
        if (string.IsNullOrWhiteSpace(fullPath))
            return "";

        var root =
            Configuration["MediaSettings:LibraryRoot"];

        if (string.IsNullOrWhiteSpace(root))
            return "";

        var full =
            Path.GetFullPath(fullPath);

        var baseRoot =
            Path.GetFullPath(root);

        if (!full.StartsWith(
                baseRoot,
                StringComparison.OrdinalIgnoreCase))
        {
            return "";
        }

        var relative = full
            .Substring(baseRoot.Length)
            .TrimStart('\\', '/')
            .Replace("\\", "/");

        return $"/libraryfiles/{relative}";
    }
}