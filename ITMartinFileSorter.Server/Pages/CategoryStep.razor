@page "/category-step/{CategoryString}"

@inject DuplicateService DuplicateService
@inject NavigationManager Navigation

<div class="page-container stack">

    <!-- TITLE -->
    <SectionTitle Title="@($"Step: {CurrentCategory}")" />

    <!-- SECONDARY ACTIONS -->
    <ActionButtonBar>
        <button class="btn btn-secondary"
                @onclick="AcceptAll"
                disabled="@(!HasPending)">
            Accept All
        </button>
    </ActionButtonBar>

    <!-- 🔥 PRIMARY CTA (MOVED UP) -->
    <ActionButtonBar CssClass="bottom">
        <button class="btn btn-primary btn-lg"
                @onclick="Continue"
                disabled="@(!CanContinue)">
            Continue
        </button>
    </ActionButtonBar>

    <!-- EMPTY STATE -->
    @if (!Groups.Any())
    {
        <ContentCard Title="No files found">
            <div class="text-muted">
                No files available in this category.
            </div>
        </ContentCard>
    }

    <!-- FILE GROUPS -->
    @foreach (var group in Groups)
    {
        <ContentCard Title="@group.Key.ToString()">

            <div class="media-grid">
                @foreach (var file in group.Value)
                {
                    <div class="media-item">
                        <FileSorterMediaCard File="file"
                                             OnKeep="Keep"
                                             OnDelete="Delete" />

                        @RenderStatus(file)
                    </div>
                }
            </div>

        </ContentCard>
    }

</div>

@code {

    [Parameter] public string CategoryString { get; set; } = "";

    MediaMainCategory CurrentCategory;
    Dictionary<int, List<MediaFile>> Groups = new();

    protected override void OnInitialized()
    {
        CurrentCategory = Enum.Parse<MediaMainCategory>(CategoryString, true);
        Load();
    }

    void Load()
    {
        // ✅ NO duplicate groups anymore
        var files = DuplicateService.AllFiles
            .Where(f => f.MainCategory == CurrentCategory)
            .ToList();

        Groups = files
            .GroupBy(f => f.Year)
            .OrderByDescending(g => g.Key)
            .ToDictionary(g => g.Key, g => g.ToList());
    }

    void Keep(MediaFile file)
    {
        file.Status = MediaFileStatus.ToKeep;

        DuplicateService.NotifyStateChanged();
        Load();
    }

    void Delete(MediaFile file)
    {
        file.Status = MediaFileStatus.ToDelete;

        DuplicateService.NotifyStateChanged();
        Load();
    }

    void AcceptAll()
    {
        foreach (var file in DuplicateService.AllFiles
                     .Where(f =>
                         f.MainCategory == CurrentCategory &&
                         f.RequiresReview &&
                         f.Status == MediaFileStatus.Initial))
        {
            file.Status = MediaFileStatus.ToKeep;
        }

        DuplicateService.NotifyStateChanged();
        Load();
    }

    bool HasPending =>
        DuplicateService.AllFiles.Any(f =>
            f.MainCategory == CurrentCategory &&
            f.RequiresReview &&
            f.Status == MediaFileStatus.Initial);

    bool CanContinue =>
        !HasPending;

    void Continue()
    {
        Navigation.NavigateTo("/filesorter");
    }

    RenderFragment RenderStatus(MediaFile file) => builder =>
    {
        if (file.Status == MediaFileStatus.ToKeep)
            builder.AddMarkupContent(0, "<span class='status kept'>✔ Kept</span>");
        else if (file.Status == MediaFileStatus.ToDelete)
            builder.AddMarkupContent(1, "<span class='status duplicate'>⚠ Duplicate</span>");
        else
            builder.AddMarkupContent(2, "<span class='status pending'>● Pending</span>");
    };
}