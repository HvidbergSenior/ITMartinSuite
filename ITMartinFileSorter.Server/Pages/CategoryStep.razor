@page "/category-step/{CategoryString}"

@inject DuplicateService DuplicateService
@inject NavigationManager Navigation

<div class="page-container">
    @if (DuplicateService.DuplicateGroups.Any(g =>
             g.Any(f => f.MainCategory == CurrentCategory)))
    {
        <div class="alert alert-warning">
            ⚠ This category contains duplicates — selecting one will delete the others.
        </div>
    }
    <ActionButtonBar>
        <button class="btn btn-primary"
                @onclick="Continue"
                disabled="@(!CanContinue)">
            Continue
        </button>

        <button class="btn btn-success"
                @onclick="AcceptAll"
                disabled="@(!FilesInCategory.Any())">
            Accept All
        </button>
    </ActionButtonBar>

    @if (!HasPending)
    {
        <div class="alert alert-success">
            ✔ Everything already handled — review or continue
        </div>
    }

    <SectionTitle Title="@($"Step: {CurrentCategory}")" />

    @if (!FilesInCategory.Any())
    {
        <EmptyState
            Message="No files in this category."
            Type="info" />
    }
    else if (CurrentCategory == MediaMainCategory.Audio)
    {
        @foreach (var group in AudioGroups)
        {
            <ContentCard Title="@group.Key">
                <div class="file-grid">
                    @foreach (var file in group.Value)
                    {
                        <div>
                            <MediaCard File="file"
                                       OnKeep="Keep"
                                       OnDelete="Delete"
                                       ShowThumbnail="false" />

                            @RenderStatus(file)
                            @RenderDuplicateTag(file)
                        </div>
                    }
                </div>
            </ContentCard>
        }
    }
    else
    {
        @foreach (var yearGroup in YearGroups)
        {
            <ContentCard Title="@yearGroup.Key.ToString()">
                <div class="file-grid">
                    @foreach (var file in yearGroup.Value)
                    {
                        <div>
                            <MediaCard File="file"
                                       OnKeep="Keep"
                                       OnDelete="Delete"
                                       ShowThumbnail="false" />

                            @RenderStatus(file)
                            @RenderDuplicateTag(file)
                        </div>
                    }
                </div>
            </ContentCard>
        }
    }

</div>

@code {

    [Parameter] public string CategoryString { get; set; } = "audio";

    private MediaMainCategory CurrentCategory;
    private List<MediaFile> FilesInCategory = new();
    private Dictionary<string, List<MediaFile>> AudioGroups = new();
    private Dictionary<int, List<MediaFile>> YearGroups = new();

    bool HasPending =>
        FilesInCategory.Any(f =>
            f.Status == MediaFileStatus.Initial &&
            f.SubCategory != MediaSubCategory.Meme &&
            f.SubCategory != MediaSubCategory.Screenshot);
    
    bool CanContinue =>
        !DuplicateService.AllFiles.Any(f =>
            f.MainCategory == CurrentCategory &&
            f.Status == MediaFileStatus.Initial &&
            f.SubCategory != MediaSubCategory.Meme &&
            f.SubCategory != MediaSubCategory.Screenshot);

    protected override void OnInitialized()
    {
        CurrentCategory = CategoryString switch
        {
            "audio" => MediaMainCategory.Audio,
            "document" => MediaMainCategory.Document,
            "image" => MediaMainCategory.Image,
            "video" => MediaMainCategory.Video,
            _ => MediaMainCategory.Audio
        };

        LoadFiles();
    }

    void LoadFiles()
    {
        FilesInCategory = DuplicateService.AllFiles
            .Where(f =>
                f.MainCategory == CurrentCategory &&
                f.SubCategory != MediaSubCategory.Meme &&
                f.SubCategory != MediaSubCategory.Screenshot)
            .ToList();
        
        if (CurrentCategory == MediaMainCategory.Audio)
        {
            AudioGroups = FilesInCategory
                .GroupBy(f => f.Extension.ToLowerInvariant())
                .OrderBy(g => g.Key)
                .ToDictionary(g => g.Key, g => g.ToList());

            YearGroups.Clear();
        }
        else
        {
            YearGroups = FilesInCategory
                .GroupBy(f => f.Year)
                .OrderByDescending(g => g.Key)
                .ToDictionary(g => g.Key, g => g.ToList());

            AudioGroups.Clear();
        }
    }

    void Keep(MediaFile file)
    {
        var group = DuplicateService.DuplicateGroups
            .FirstOrDefault(g => g.Contains(file));

        if (group is not null)
        {
            foreach (var f in group)
            {
                f.Status = f == file
                    ? MediaFileStatus.ToKeep
                    : MediaFileStatus.ToDelete;
            }
        }
        else
        {
            file.Status = MediaFileStatus.ToKeep;
        }

        LoadFiles();                     // 🔥 refresh grouping
        InvokeAsync(StateHasChanged);   // 🔥 force UI update
    }

    void Delete(MediaFile file)
    {
        file.Status = MediaFileStatus.ToDelete;

        LoadFiles();                     // 🔥 refresh
        InvokeAsync(StateHasChanged);   // 🔥 update UI
    }
    void AcceptAll()
    {
        foreach (var file in FilesInCategory
                     .Where(f => f.Status == MediaFileStatus.Initial))
        {
            file.Status = MediaFileStatus.ToKeep;
        }

        LoadFiles();
        InvokeAsync(StateHasChanged);
    }

    void Continue()
    {
        Navigation.NavigateTo("/filesorter");
    }

    RenderFragment RenderStatus(MediaFile file) => builder =>
    {
        if (file.Status == MediaFileStatus.ToKeep)
        {
            builder.AddMarkupContent(0, "<span class='badge bg-success'>Kept</span>");
        }
        else if (file.Status == MediaFileStatus.ToDelete)
        {
            builder.AddMarkupContent(1, "<span class='badge bg-danger'>Deleted</span>");
        }
        else
        {
            builder.AddMarkupContent(2, "<span class='badge bg-warning'>Pending</span>");
        }
    };

    RenderFragment RenderDuplicateTag(MediaFile file) => builder =>
    {
        if (DuplicateService.DuplicateGroups.Any(g => g.Contains(file)))
        {
            builder.AddMarkupContent(0, "<span class='badge bg-warning ms-1'>Duplicate</span>");
        }
    };
}