@page "/library"

@using ITMartinFileSorter.Infrastructure.FileSystem
@using ITMartinFileSorter.Application.Helpers

@inject IConfiguration Configuration
@inject NavigationManager Navigation

<div class="filesorter-app">
    <div class="page-container stack library-page">

        <!-- TITLE -->
        <SectionTitle Title="🎬 My Media Library" />

        <!-- NAVIGATION -->
        <div class="library-actions">

            <button class="btn btn-secondary"
                    @onclick="GoBack"
                    disabled="@(!CanGoBack)">
                ← Back
            </button>

            <button class="btn btn-secondary"
                    @onclick="GoToRoot"
                    disabled="@(CurrentPath == RootPath)">
                📁 Library
            </button>
        </div>

        <!-- FOLDERS -->
        <ContentCard Title="📁 Folders">

            @if (!Folders.Any())
            {
                <div class="library-empty">
                    No folders found
                </div>
            }
            else
            {
                <div class="library-grid">
                    @foreach (var folder in Folders)
                    {
                        <div class="folder-card"
                             @onclick="() => OpenFolder(folder.FullPath)">

                            <div class="folder-title">
                                📁 @folder.Name
                            </div>

                            <div class="folder-count">
                                @folder.FileCount files
                            </div>

                        </div>
                    }
                </div>
            }

        </ContentCard>

        <!-- MEDIA -->
        <ContentCard Title="🎬 Media">

            @if (!Files.Any())
            {
                <div class="library-empty">
                    No media files
                </div>
            }
            else
            {
                <div class="media-grid">
                    @foreach (var file in Files)
                    {
                        <div class="media-card"
                             @onclick="() => OpenFile(file)">

                            <div class="media-name">
                                @GetIcon(file) @Path.GetFileName(file.FullPath)
                            </div>

                            <div class="media-meta">
                                @FormatSize(file.SizeBytes)
                            </div>

                        </div>
                    }
                </div>
            }

        </ContentCard>

    </div>
</div>

@code {
    private string RootPath = "";
    private string CurrentPath = "";

    private List<FolderItem> Folders = new();
    private List<MediaFile> Files = new();

    protected override void OnInitialized()
    {
        RootPath = LibraryPathHelper.GetLibraryPath(Configuration);
        LoadFolder(RootPath);
    }

    // =========================
    // NAVIGATION
    // =========================

    private bool CanGoBack =>
        !string.Equals(CurrentPath, RootPath, StringComparison.OrdinalIgnoreCase);

    private void GoBack()
    {
        var parent = Directory.GetParent(CurrentPath);
        if (parent == null) return;

        LoadFolder(parent.FullName);
    }

    private void GoToRoot()
    {
        LoadFolder(RootPath);
    }

    private void OpenFolder(string path)
    {
        LoadFolder(path);
    }

    private void OpenFile(MediaFile file)
    {
        var index = Files.FindIndex(f => f.FullPath == file.FullPath);

        Navigation.NavigateTo(
            $"/viewer?path={Uri.EscapeDataString(file.FullPath)}&index={index}&folder={Uri.EscapeDataString(CurrentPath)}",
            forceLoad: true);
    }

    // =========================
    // LOAD DATA
    // =========================

    private void LoadFolder(string path)
    {
        try
        {
            CurrentPath = path;

            Folders = Directory
                .EnumerateDirectories(path)
                .Select(CreateFolderItem)
                .OrderBy(x => x.Name)
                .ToList();

            Files = Directory
                .EnumerateFiles(path, "*.*", SearchOption.TopDirectoryOnly)
                .Where(FileScanner.IsSupportedMedia)
                .Select(CreateMediaFile)
                .ToList();

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Load error: {ex}");
        }
    }

    // =========================
    // HELPERS
    // =========================

    private FolderItem CreateFolderItem(string folder) => new()
    {
        Name = Path.GetFileName(folder),
        FullPath = folder,
        FileCount = Directory
            .EnumerateFiles(folder, "*.*", SearchOption.AllDirectories)
            .Count(FileScanner.IsSupportedMedia)
    };

    private MediaFile CreateMediaFile(string file)
    {
        var info = new FileInfo(file);

        var type = FileScanner.IsVideo(file)
            ? MediaType.Video
            : FileScanner.IsImage(file)
                ? MediaType.Image
                : MediaType.Document;

        return new MediaFile(file, info.LastWriteTimeUtc, type, info.Length);
    }

    private string GetBreadcrumb()
    {
        if (string.IsNullOrEmpty(CurrentPath)) return "";

        var relative = CurrentPath.Replace(RootPath, "").Trim('\\');

        if (string.IsNullOrEmpty(relative))
            return "Library";

        return "Library / " + relative.Replace("\\", " / ");
    }

    string GetIcon(MediaFile file) => file.Type switch
    {
        MediaType.Image => "🖼️",
        MediaType.Video => "🎬",
        MediaType.Audio => "🎵",
        _ => "📄"
    };

    string FormatSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;

        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }

        return $"{len:0.#} {sizes[order]}";
    }
}