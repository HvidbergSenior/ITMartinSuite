@page "/library"

@using ITMartin.Media.Entities
@using ITMartin.Media.Enums
@using ITMartin.Media.Helpers
@using ITMartin.Media.Infrastructure.FileSystem

@inject IConfiguration Configuration
@inject NavigationManager Navigation
@inject ILogger<Library> Logger

<div class="filesorter-app">

    <div class="page-container stack library-page">

        <SectionTitle Title="🎬 My Media Library" />

        <!-- ACTIONS -->
        <div class="library-actions">

            <button class="btn btn-secondary"
                    @onclick="GoBack"
                    disabled="@(!CanGoBack)">
                ← Back
            </button>

            <button class="btn btn-secondary"
                    @onclick="GoToRoot">
                📁 Library
            </button>

        </div>

        <!-- FOLDERS -->
        <ContentCard Title="📁 Folders">

            @if (!Folders.Any())
            {
                <div class="library-empty">
                    No folders found
                </div>
            }
            else
            {
                <div class="library-grid">

                    @foreach (var folder in Folders)
                    {
                        <div class="folder-card"
                             @onclick="() => OpenFolder(folder.FullPath)">

                            <div class="folder-title">
                                📁 @folder.Name
                            </div>

                            <div class="folder-count">
                                @folder.FileCount files
                            </div>

                        </div>
                    }

                </div>
            }

        </ContentCard>

        <!-- MEDIA -->
        <ContentCard Title="🎬 Media">

            @if (!Files.Any())
            {
                <div class="library-empty">
                    No media files
                </div>
            }
            else
            {
                <div class="media-grid">

                    @foreach (var file in Files)
                    {
                        <div class="media-card"
                             @onclick="() => OpenFile(file)">

                            @if (file.Type == MediaType.Image)
                            {
                                <img class="media-thumb"
                                     src="@GetPreviewPath(file)"
                                     alt="@file.FileName" />
                            }

                            <div class="media-name">
                                @GetIcon(file)
                                @file.FileName
                            </div>

                            <div class="media-meta">
                                @FormatSize(file.SizeBytes)
                            </div>

                        </div>
                    }

                </div>
            }

        </ContentCard>

    </div>

</div>

@code {

    private string RootPath = "";

    private string CurrentPath = "";

    private List<FolderItem> Folders = [];

    private List<MediaFile> Files = [];

    [Parameter]
    [SupplyParameterFromQuery]
    public string? path { get; set; }

    protected override void OnParametersSet()
    {
        RootPath =
            Configuration["MediaSettings:LibraryRoot"]
            ?? "";

        var initial =
            string.IsNullOrWhiteSpace(path)
                ? RootPath
                : path;

        LoadFolder(initial);
    }

    private bool CanGoBack =>
        !string.Equals(
            CurrentPath,
            RootPath,
            StringComparison.OrdinalIgnoreCase);

    private void GoBack()
    {
        var parent =
            Directory.GetParent(CurrentPath);

        if (parent != null)
        {
            LoadFolder(parent.FullName);
        }
    }

    private void GoToRoot()
    {
        LoadFolder(RootPath);
    }

    private void OpenFolder(string path)
    {
        if (string.Equals(
                CurrentPath,
                path,
                StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        Logger.LogInformation(
            "Opening folder {Folder}",
            path);

        Navigation.NavigateTo(
            $"/library?path={Uri.EscapeDataString(path)}");
    }

    private void OpenFile(MediaFile file)
    {
        var index = Files.FindIndex(f =>
            f.FullPath == file.FullPath);

        Logger.LogInformation(
            "Opening file viewer for {File}",
            file.FileName);

        Navigation.NavigateTo(
            $"/viewer?path={Uri.EscapeDataString(file.FullPath)}&index={index}",
            true);
    }

    private void LoadFolder(string path)
    {
        if (!Directory.Exists(path))
        {
            Logger.LogWarning(
                "Library folder does not exist: {Path}",
                path);

            return;
        }

        CurrentPath = path;

        Logger.LogInformation(
            "Loading library folder {Path}",
            path);

        Folders = Directory
            .EnumerateDirectories(path)
            .Select(CreateFolderItem)
            .OrderBy(x => x.Name)
            .ToList();

        Files = Directory
            .EnumerateFiles(path)
            .Where(MediaDisplayHelper.IsDisplayable)
            .Select(CreateMediaFile)
            .OrderByDescending(f => f.CreatedAt)
            .ToList();

        StateHasChanged();
    }

    private string GetPreviewPath(MediaFile file)
    {
        var root =
            Configuration["MediaSettings:LibraryRoot"];

        if (string.IsNullOrWhiteSpace(root))
        {
            return "";
        }

        var relative = Path
            .GetRelativePath(root, file.FullPath)
            .Replace("\\", "/");

        return $"/libraryfiles/{relative}";
    }

    private FolderItem CreateFolderItem(string folder)
    {
        return new FolderItem
        {
            Name = Path.GetFileName(folder),

            FullPath = folder,

            FileCount = Directory
                .EnumerateFiles(
                    folder,
                    "*.*",
                    SearchOption.AllDirectories)
                .Count(FileScanner.IsSupportedMedia)
        };
    }

    private MediaFile CreateMediaFile(string file)
    {
        var info = new FileInfo(file);

        var type =
            FileScanner.IsImage(file)
                ? MediaType.Image
                : FileScanner.IsVideo(file)
                    ? MediaType.Video
                    : FileScanner.AudioExtensions.Contains(
                        Path.GetExtension(file))
                        ? MediaType.Audio
                        : MediaType.Document;

        return new MediaFile(
            file,
            info.LastWriteTimeUtc,
            type,
            info.Length);
    }

    private static string GetIcon(MediaFile file) =>
        file.Type switch
        {
            MediaType.Image => "🖼️",
            MediaType.Video => "🎬",
            MediaType.Audio => "🎵",
            _ => "📄"
        };

    private static string FormatSize(long bytes)
    {
        string[] sizes =
        [
            "B",
            "KB",
            "MB",
            "GB"
        ];

        double len = bytes;

        var order = 0;

        while (len >= 1024 &&
               order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }

        return $"{len:0.#} {sizes[order]}";
    }

    private sealed class FolderItem
    {
        public string Name { get; set; } = "";

        public string FullPath { get; set; } = "";

        public int FileCount { get; set; }
    }
}