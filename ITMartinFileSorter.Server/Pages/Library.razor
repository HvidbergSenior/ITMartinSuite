@page "/library"

@using ITMartinFileSorter.Domain.Entities
@using ITMartinFileSorter.Domain.Enums
@using ITMartinFileSorter.Infrastructure.FileSystem
@using ITMartinFileSorter.Application.Helpers
@using ITMartinFileSorter.Domain.Helpers

@inject IConfiguration Configuration
@inject NavigationManager Navigation

<div class="filesorter-app">
    <div class="page-container stack library-page">

        <SectionTitle Title="🎬 My Media Library" />

        <div class="library-actions">

            <button class="btn btn-secondary"
                    @onclick="GoBack"
                    disabled="@(!CanGoBack)">
                ← Back
            </button>

            <button class="btn btn-secondary"
                    @onclick="GoToRoot">
                📁 Library
            </button>

        </div>

        <!-- FOLDERS -->
        <ContentCard Title="📁 Folders">
            @if (!Folders.Any())
            {
                <div class="library-empty">No folders found</div>
            }
            else
            {
                <div class="library-grid">
                    @foreach (var folder in Folders)
                    {
                        <div class="folder-card"
                             @onclick="() => OpenFolder(folder.FullPath)">

                            <div class="folder-title">
                                📁 @folder.Name
                            </div>

                            <div class="folder-count">
                                @folder.FileCount files
                            </div>

                        </div>
                    }
                </div>
            }
        </ContentCard>

        <!-- MEDIA -->
        <ContentCard Title="🎬 Media">
            @if (!Files.Any())
            {
                <div class="library-empty">No media files</div>
            }
            else
            {
                <div class="media-grid">
                    @foreach (var file in Files)
                    {
                        <div class="media-card"
                             @onclick="() => OpenFile(file)">

                            @if (file.Type == MediaType.Image)
                            {
                                <img class="media-thumb"
                                     src="@GetPreviewPath(file)" />
                            }

                            <div class="media-name">
                                @GetIcon(file) @file.FileName
                            </div>

                            <div class="media-meta">
                                @FormatSize(file.SizeBytes)
                            </div>

                        </div>
                    }
                </div>
            }
        </ContentCard>

    </div>
</div>

@code {
    private string RootPath = "";
    private string CurrentPath = "";

    private List<FolderItem> Folders = new();
    private List<MediaFile> Files = new();

    [Parameter]
    [SupplyParameterFromQuery]
    public string? path { get; set; }

    protected override void OnParametersSet()
    {
        RootPath = LibraryPathHelper.GetLibraryPath(Configuration);

        var initial = string.IsNullOrWhiteSpace(path)
            ? RootPath
            : path;

        LoadFolder(initial);
    }

    private bool CanGoBack =>
        !string.Equals(CurrentPath, RootPath, StringComparison.OrdinalIgnoreCase);

    private void GoBack()
    {
        var parent = Directory.GetParent(CurrentPath);
        if (parent != null)
            LoadFolder(parent.FullName);
    }

    private void GoToRoot()
    {
        LoadFolder(RootPath);
    }

    private void OpenFolder(string path)
    {
        if (string.Equals(CurrentPath, path, StringComparison.OrdinalIgnoreCase))
            return;

        Navigation.NavigateTo($"/library?path={Uri.EscapeDataString(path)}");
    }

    private void OpenFile(MediaFile file)
    {
        var index = Files.FindIndex(f => f.FullPath == file.FullPath);

        Navigation.NavigateTo(
            $"/viewer?path={Uri.EscapeDataString(file.FullPath)}&index={index}",
            true);
    }

    private void LoadFolder(string path)
    {
        if (!Directory.Exists(path))
            return;

        CurrentPath = path;

        Folders = Directory
            .EnumerateDirectories(path)
            .Select(CreateFolderItem)
            .OrderBy(x => x.Name)
            .ToList();

        Files = Directory
            .EnumerateFiles(path)
            .Where(MediaDisplayHelper.IsDisplayable)
            .Select(CreateMediaFile)
            .ToList();

        StateHasChanged();
    }

    private string GetPreviewPath(MediaFile file)
    {
        var root = LibraryPathHelper.GetLibraryPath(Configuration);

        var relative = Path.GetRelativePath(root, file.FullPath)
            .Replace("\\", "/");

        return $"/libraryfiles/{relative}";
    }

    private FolderItem CreateFolderItem(string folder) => new()
    {
        Name = Path.GetFileName(folder),
        FullPath = folder,
        FileCount = Directory
            .EnumerateFiles(folder, "*.*", SearchOption.AllDirectories)
            .Count(FileScanner.IsSupportedMedia)
    };

    private MediaFile CreateMediaFile(string file)
    {
        var info = new FileInfo(file);

        var type =
            FileScanner.IsImage(file) ? MediaType.Image :
            FileScanner.IsVideo(file) ? MediaType.Video :
            FileScanner.AudioExtensions.Contains(Path.GetExtension(file))
                ? MediaType.Audio
                : MediaType.Document;

        return new MediaFile(file, info.LastWriteTimeUtc, type, info.Length);
    }

    string GetIcon(MediaFile file) => file.Type switch
    {
        MediaType.Image => "🖼️",
        MediaType.Video => "🎬",
        MediaType.Audio => "🎵",
        _ => "📄"
    };

    string FormatSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;

        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }

        return $"{len:0.#} {sizes[order]}";
    }

    private class FolderItem
    {
        public string Name { get; set; } = "";
        public string FullPath { get; set; } = "";
        public int FileCount { get; set; }
    }
}