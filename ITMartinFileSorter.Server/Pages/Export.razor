@page "/export"

@using ITMartin.Media.Application.Services
@using ITMartin.Media.Domain.Entities
@using ITMartin.Media.Domain.Interfaces
@using ITMartin.Media.Enums
@using ITMartinFileSorter.Application.Services

@inject DuplicateService DuplicateService
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@inject LibraryExportService LibraryExportService
@inject ILogger<Export> Logger
@inject IAiEnrichmentService AiEnrichmentService
@inject IMediaNormalizationService MediaNormalizationService
@inject IMediaOcrService MediaOcrService
@inject IMediaVisionService MediaVisionService
@inject IAiCollectionService AiCollectionService

<div class="filesorter-app">

    <div class="page-container stack export-page">

        <SectionTitle Title="📦 Export Organized Files" />

        <ContentCard>

            <div class="text-muted small">

                Source: @SourceRoot

                <br />

                Library: @LibraryRoot

            </div>

        </ContentCard>

        <ContentCard Title="📁 Preview of your organized library">

            @foreach (var cat in Categories)
            {
            <div class="tree">

                <div class="tree-node root"
                     @onclick="() => Toggle(cat.Name)">

                    @(IsExpanded(cat.Name) ? "▼" : "▶")
                    📁 @cat.Name

                    <span class="tree-count">
                            (@cat.Total)
                        </span>

                </div>

                @if (IsExpanded(cat.Name))
                {
                @foreach (var year in cat.Years)
                {
                <div class="tree-node year">

                                <span class="tree-branch">
                                    ├──
                                </span>

                    📂 @year.Year

                    <span class="tree-count">
                                    (@year.Count)
                                </span>

                </div>
                }
                }

            </div>
            }

        </ContentCard>

        @if (IsExporting)
        {
        <ContentCard CssClass="pipeline-card">

            <div class="pipeline-header">
                ⚡ AI Processing Pipeline
            </div>

            <div class="pipeline-stages">

                <div class="@GetStageClass("Normalize")">
                    @GetStageIcon("Normalize")
                    Normalize
                </div>

                <div class="@GetStageClass("OCR")">
                    @GetStageIcon("OCR")
                    OCR
                </div>

                <div class="@GetStageClass("Vision")">
                    @GetStageIcon("Vision")
                    Vision
                </div>

                <div class="@GetStageClass("AI")">
                    @GetStageIcon("AI")
                    AI
                </div>

                <div class="@GetStageClass("Export")">
                    @GetStageIcon("Export")
                    Export
                </div>

            </div>

            <div class="progress-track">

                <div class="progress-fill"
                     style="width:@($"{ProgressPercent}%")">
                </div>

            </div>

            <div class="progress-details">

                <div class="progress-stage">
                    @CurrentStage
                </div>

                <div class="progress-count">
                    @ExportedCount / @TotalToExport
                </div>

                <div class="progress-file">
                    @CurrentExportFile
                </div>

            </div>

        </ContentCard>

        <ContentCard Title="📜 Live Activity">

            <div class="activity-log">

                @foreach (var entry in ActivityLog)
                {
                <div class="activity-entry">
                    @entry
                </div>
                }

            </div>

        </ContentCard>
        }

        <ContentCard Title="Export Summary">

            <div class="summary-item">

                <strong>
                    @FilesToExport.Count()
                </strong>

                <span>
                    Files
                </span>

            </div>

        </ContentCard>

        @if (!IsExporting)
        {
        <ActionButtonBar CssClass="bottom">

            <button class="btn btn-primary btn-lg"
                    @onclick="StartExport">

                Start Export →
                @FilesToExport.Count()

            </button>

        </ActionButtonBar>
        }

    </div>

</div>

@code {

private string SourceRoot =>
Configuration["MediaSettings:SourceRoot"] ?? "";

private string LibraryRoot =>
Configuration["MediaSettings:LibraryRoot"] ?? "";

private IEnumerable<MediaFile> FilesToExport =>
DuplicateService.AllFiles
.Where(f =>
f.Status == MediaFileStatus.ToKeep ||
f.SubCategory == MediaSubCategory.Meme ||
f.SubCategory == MediaSubCategory.Screenshot);

private readonly HashSet<string> Expanded = [];

private readonly List<string> ActivityLog = [];

private bool IsExporting;

private int ExportedCount;

private int TotalToExport;

private string CurrentExportFile = "";

private string CurrentStage = "";

private int ProgressPercent =>
TotalToExport == 0
? 0
: (int)((double)ExportedCount /
TotalToExport * 100);

private List<ExportCategory> Categories =>
FilesToExport
.GroupBy(f => new
{
Category =
f.SubCategory == MediaSubCategory.Screenshot
? "Screenshots"
: f.SubCategory == MediaSubCategory.Meme
? "Memes"
: f.MainCategory.ToString()
})
.Select(cat => new ExportCategory
{
Name = cat.Key.Category,
Total = cat.Count(),

Years = cat
.GroupBy(f => f.Year)
.OrderByDescending(y => y.Key)
.Select(y => new ExportYear
{
Year = y.Key,
Count = y.Count()
})
.ToList()
})
.OrderBy(c => c.Name)
.ToList();

private void Toggle(string name)
{
if (!Expanded.Add(name))
{
Expanded.Remove(name);
}
}

private bool IsExpanded(string name) =>
Expanded.Contains(name);

private string GetStageClass(string stage)
{
if (CurrentStage.Contains(stage,
StringComparison.OrdinalIgnoreCase))
{
return "pipeline-stage active";
}

if (IsStageDone(stage))
{
return "pipeline-stage done";
}

return "pipeline-stage";
}

private string GetStageIcon(string stage)
{
if (CurrentStage.Contains(stage,
StringComparison.OrdinalIgnoreCase))
{
return "⟳";
}

if (IsStageDone(stage))
{
return "✓";
}

return "•";
}

private bool IsStageDone(string stage)
{
return stage switch
{
"Normalize" =>
CurrentStage.Contains("OCR") ||
CurrentStage.Contains("Vision") ||
CurrentStage.Contains("AI") ||
CurrentStage.Contains("Export"),

"OCR" =>
CurrentStage.Contains("Vision") ||
CurrentStage.Contains("AI") ||
CurrentStage.Contains("Export"),

"Vision" =>
CurrentStage.Contains("AI") ||
CurrentStage.Contains("Export"),

"AI" =>
CurrentStage.Contains("Export"),

"Export" =>
CurrentStage.Contains("Opening"),

_ => false
};
}

private async Task UpdateUi()
{
await InvokeAsync(StateHasChanged);

await Task.Delay(25);
}

private async Task AddLog(
string message)
{
ActivityLog.Insert(
0,
$"[{DateTime.Now:HH:mm:ss}] {message}");

if (ActivityLog.Count > 100)
{
ActivityLog.RemoveAt(
ActivityLog.Count - 1);
}

await UpdateUi();
}

private async Task StartExport()
{
if (IsExporting)
return;

try
{
ActivityLog.Clear();

IsExporting = true;

var files =
FilesToExport.ToList();

TotalToExport = files.Count;

Directory.CreateDirectory(
LibraryRoot);

// =========================
// NORMALIZE
// =========================

ExportedCount = 0;

CurrentStage = "Normalize";

await AddLog(
"Starting normalization...");

await MediaNormalizationService.NormalizeAsync(
files,
async (done, total, fileName) =>
{
ExportedCount = done;
TotalToExport = total;
CurrentExportFile = fileName;

await AddLog(
$"Normalizing: {fileName}");

await UpdateUi();
});

// =========================
// OCR
// =========================

ExportedCount = 0;

CurrentStage = "OCR";

await AddLog(
"Starting OCR processing...");

await MediaOcrService.ProcessAsync(
files,
async (done, total, fileName) =>
{
ExportedCount = done;
TotalToExport = total;
CurrentExportFile = fileName;

await AddLog(
$"OCR scanning: {fileName}");

await UpdateUi();
});

// =========================
// VISION
// =========================

ExportedCount = 0;

CurrentStage = "Vision";

await AddLog(
"Starting Vision AI...");

await MediaVisionService.ProcessAsync(
files,
async (done, total, fileName) =>
{
ExportedCount = done;
TotalToExport = total;
CurrentExportFile = fileName;

await AddLog(
$"Vision analyzing: {fileName}");

await UpdateUi();
});

// =========================
// AI
// =========================

ExportedCount = 0;

var aiFiles =
files
.Where(x => x.RequiresReview)
.ToList();

TotalToExport = aiFiles.Count;

CurrentStage =
$"AI ({aiFiles.Count} files)";

await AddLog(
$"Starting AI enrichment for {aiFiles.Count} files...");

await AiEnrichmentService.EnrichBatchAsync(
aiFiles,
async () =>
{
ExportedCount += 5;

if (ExportedCount > TotalToExport)
{
ExportedCount = TotalToExport;
}

CurrentExportFile =
"AI batch processed";

await AddLog(
"AI batch completed");

await UpdateUi();
});

// =========================
// EXPORT
// =========================

ExportedCount = 0;

CurrentStage = "Export";

await AddLog(
"Starting export...");

await LibraryExportService.ExportAsync(
files,
LibraryRoot,
async (done, total, fileName, stage) =>
{
ExportedCount = done;
TotalToExport = total;
CurrentExportFile = fileName;

await AddLog(
$"Exported: {fileName}");

await UpdateUi();
});

// =========================
// COLLECTIONS
// =========================

CurrentStage =
"Building collections";

await AddLog(
"Building AI collections...");

DuplicateService.AiCollections =
AiCollectionService
.BuildCollections(files);

CurrentStage =
"Opening library";

await AddLog(
"Opening media library...");

await Task.Delay(500);

DuplicateService.Reset();

IsExporting = false;

Navigation.NavigateTo(
$"/library?path={Uri.EscapeDataString(LibraryRoot)}",
true);
}
catch (Exception ex)
{
Logger.LogError(
ex,
"Export failed");

await AddLog(
$"ERROR: {ex.Message}");

CurrentStage =
"❌ Export failed";

IsExporting = false;

await UpdateUi();
}
}

public sealed class ExportCategory
{
public string Name { get; set; } = "";

public int Total { get; set; }

public List<ExportYear> Years { get; set; } = [];
}

public sealed class ExportYear
{
public int Year { get; set; }

public int Count { get; set; }
}
}