@page "/export"

@using ITMartin.Media.Entities
@using ITMartin.Media.Enums
@using ITMartinFileSorter.Application.Services

@inject DuplicateService DuplicateService
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@inject LibraryExportService LibraryExportService
@inject ILogger<Export> Logger

<div class="filesorter-app">

    <div class="page-container stack export-page">

        <SectionTitle Title="📦 Export Organized Files" />

        <!-- PATHS -->
        <ContentCard>

            <div class="text-muted small">

                Source: @SourceRoot

                <br />

                Library: @LibraryRoot

            </div>

        </ContentCard>

        <!-- PREVIEW -->
        <ContentCard Title="📁 Preview of your organized library">

            @foreach (var cat in Categories)
            {
                <div class="tree">

                    <div class="tree-node root"
                         @onclick="() => Toggle(cat.Name)">

                        @(IsExpanded(cat.Name) ? "▼" : "▶")
                        📁 @cat.Name

                        <span class="tree-count">
                            (@cat.Total)
                        </span>

                    </div>

                    @if (IsExpanded(cat.Name))
                    {
                        @foreach (var year in cat.Years)
                        {
                            <div class="tree-node year">

                                <span class="tree-branch">
                                    ├──
                                </span>

                                📂 @year.Year

                                <span class="tree-count">
                                    (@year.Count)
                                </span>

                            </div>
                        }
                    }

                </div>
            }

        </ContentCard>

        <!-- EXPORT PROGRESS -->
        @if (IsExporting)
        {
            <ProgressPanel
                Title="@CurrentStage"
                Current="@ExportedCount"
                Total="@TotalToExport"
                Percent="@ProgressPercent"
                CurrentItem="@CurrentExportFile"
                LoadingText="Preparing export..."
                Icon="📦" />
        }

        <!-- SUMMARY -->
        <ContentCard Title="Export Summary">

            <div class="summary-item">

                <strong>
                    @FilesToExport.Count()
                </strong>

                <span>
                    Files
                </span>

            </div>

        </ContentCard>

        <!-- ACTIONS -->
        @if (!IsExporting)
        {
            <ActionButtonBar CssClass="bottom">

                <button class="btn btn-primary btn-lg"
                        @onclick="StartExport">

                    Start Export →
                    @FilesToExport.Count()

                </button>

            </ActionButtonBar>
        }

    </div>

</div>

@code {

    // =========================
    // CONFIG
    // =========================

    private string SourceRoot =>
        Configuration["MediaSettings:SourceRoot"] ?? "";

    private string LibraryRoot =>
        Configuration["MediaSettings:LibraryRoot"] ?? "";

    // =========================
    // DATA
    // =========================

    private IEnumerable<MediaFile> FilesToExport =>
        DuplicateService.AllFiles
            .Where(f =>
                f.Status == MediaFileStatus.ToKeep ||
                f.SubCategory == MediaSubCategory.Meme ||
                f.SubCategory == MediaSubCategory.Screenshot);

    private List<ExportCategory> Categories =>
        FilesToExport
            .GroupBy(f => new
            {
                Category =
                    f.SubCategory == MediaSubCategory.Screenshot
                        ? "Screenshots"
                        : f.SubCategory == MediaSubCategory.Meme
                            ? "Memes"
                            : f.MainCategory.ToString()
            })
            .Select(cat => new ExportCategory
            {
                Name = cat.Key.Category,

                Total = cat.Count(),

                Years = cat
                    .GroupBy(f => f.Year)
                    .OrderByDescending(y => y.Key)
                    .Select(y => new ExportYear
                    {
                        Year = y.Key,
                        Count = y.Count()
                    })
                    .ToList()
            })
            .OrderBy(c => c.Name)
            .ToList();

    private readonly HashSet<string> Expanded = [];

    private void Toggle(string name)
    {
        if (!Expanded.Add(name))
        {
            Expanded.Remove(name);
        }
    }

    private bool IsExpanded(string name) =>
        Expanded.Contains(name);

    // =========================
    // STATE
    // =========================

    private bool IsExporting;

    private int ExportedCount;

    private int TotalToExport;

    private string CurrentExportFile = "";

    private string CurrentStage = "";

    private DateTime LastRender =
        DateTime.UtcNow;

    private int ProgressPercent =>
        TotalToExport == 0
            ? 0
            : (int)((double)ExportedCount /
                    TotalToExport * 100);

    // =========================
    // EXPORT
    // =========================

    private async Task StartExport()
    {
        if (IsExporting)
            return;

        try
        {
            IsExporting = true;

            ExportedCount = 0;

            CurrentStage = "Preparing export...";

            await InvokeAsync(StateHasChanged);

            var files = FilesToExport.ToList();

            TotalToExport = files.Count;

            var exportRoot = LibraryRoot;

            var sourceRoot = SourceRoot;

            // SAFETY CHECKS

            if (string.IsNullOrWhiteSpace(exportRoot))
            {
                throw new Exception(
                    "LibraryRoot missing in configuration.");
            }

            if (string.IsNullOrWhiteSpace(sourceRoot))
            {
                throw new Exception(
                    "SourceRoot missing in configuration.");
            }

            if (Path.GetFullPath(exportRoot)
                .Equals(
                    Path.GetFullPath(sourceRoot),
                    StringComparison.OrdinalIgnoreCase))
            {
                throw new Exception(
                    "Source and Library folders cannot be the same.");
            }

            Directory.CreateDirectory(exportRoot);

            Logger.LogInformation(
                "Starting export. Source: {Source} Export: {Export} Files: {Count}",
                sourceRoot,
                exportRoot,
                files.Count);

            await LibraryExportService.ExportAsync(
                files,
                exportRoot,
                async (done, total, fileName, stage) =>
                {
                    ExportedCount = done;

                    TotalToExport = total;

                    CurrentExportFile = fileName;

                    CurrentStage = stage;

                    if ((DateTime.UtcNow - LastRender)
                        .TotalMilliseconds > 100)
                    {
                        LastRender = DateTime.UtcNow;

                        await InvokeAsync(StateHasChanged);
                    }
                });

            ExportedCount = TotalToExport;

            CurrentStage = "Opening library...";

            await InvokeAsync(StateHasChanged);

            await Task.Delay(400);

            Logger.LogInformation(
                "Export completed successfully to {ExportRoot}",
                exportRoot);

            // RESET SESSION

            DuplicateService.Reset();

            ExportedCount = 0;
            TotalToExport = 0;
            CurrentExportFile = "";
            CurrentStage = "";
            IsExporting = false;

            await InvokeAsync(StateHasChanged);

            Navigation.NavigateTo(
                $"/library?path={Uri.EscapeDataString(exportRoot)}",
                true);
        }
        catch (Exception ex)
        {
            Logger.LogError(
                ex,
                "Export failed");

            CurrentStage = "❌ Export failed";

            IsExporting = false;

            await InvokeAsync(StateHasChanged);
        }
    }

    // =========================
    // DTOs
    // =========================

    public sealed class ExportCategory
    {
        public string Name { get; set; } = "";

        public int Total { get; set; }

        public List<ExportYear> Years { get; set; } = [];
    }

    public sealed class ExportYear
    {
        public int Year { get; set; }

        public int Count { get; set; }
    }
}