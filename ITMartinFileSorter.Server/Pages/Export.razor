@page "/export"
@using ITMartinFileSorter.Application.Helpers
@using ITMartinFileSorter.Application.Services
@using ITMartinFileSorter.Domain.Enums

@inject DuplicateService DuplicateService
@inject NavigationManager Navigation
@inject FastVideoBatchExportService FastVideoBatchExportService
@inject ImageBatchExportService ImageBatchExportService
@inject IConfiguration Configuration
@inject TripGroupingService TripGroupingService
@inject ArchivePathBuilder ArchivePathBuilder
@inject FileRenameService FileRenameService

<div class="export-page">

    <ActionButtonBar>
        <SectionTitle Title="Export Organized Files" />

        <button class="btn btn-outline-secondary"
                @onclick="GoBack"
                disabled="@IsExporting">
            Back
        </button>
    </ActionButtonBar>

    <ContentCard Title="Export Structure Preview">
        <ExportPreviewCard />
    </ContentCard>

    @if (IsExporting)
    {
        <ProgressPanel
            Title="@CurrentStage"
            Current="@ExportedCount"
            Total="@TotalToExport"
            Percent="@ProgressPercent"
            CurrentItem="@CurrentExportFile" />

        @if (ExportLogs.Any())
        {
            <ContentCard Title="Live Export Log">
                <div class="export-log">
                    @foreach (var log in ExportLogs.TakeLast(12))
                    {
                        <div>@log</div>
                    }
                </div>
            </ContentCard>
        }
    }

    @if (!IsExporting)
    {
        <ActionButtonBar>
            <button class="btn btn-success btn-lg"
                    @onclick="StartExport">
                Start Export
            </button>
        </ActionButtonBar>
    }

</div>

@code {
    bool IsExporting = false;
    int ExportedCount = 0;
    int TotalToExport = 0;

    string CurrentExportFile = "";
    string CurrentStage = "";

    List<string> ExportLogs = new();

    int ProgressPercent =>
        TotalToExport <= 0
            ? 0
            : Math.Min(100,
                (int)((double)ExportedCount / TotalToExport * 100));

    void GoBack() => Navigation.NavigateTo("/");

    void AddLog(string message)
    {
        ExportLogs.Add($"{DateTime.Now:HH:mm:ss} - {message}");

        if (ExportLogs.Count > 100)
            ExportLogs.RemoveAt(0);
    }

    async Task StartExport()
    {
        IsExporting = true;
        ExportLogs.Clear();

        CurrentStage = "Preparing export...";
        CurrentExportFile = "Reading files and metadata...";
        ExportedCount = 0;
        TotalToExport = 0;

        AddLog("Export started");
        AddLog("Reading files and building structure...");

        await InvokeAsync(StateHasChanged);
        await Task.Yield();

        var files = DuplicateService.FilesToExport.ToList();

        if (!files.Any())
        {
            AddLog("No files to export");
            IsExporting = false;
            return;
        }

        var exportRoot = Path.Combine(
            Configuration["MediaSettings:LibraryRoot"]!,
            "Library");

        Directory.CreateDirectory(exportRoot);

        try
        {
            AddLog($"Found {files.Count} files");

            var structure = ArchivePathBuilder.BuildStructure(
                files,
                new ArchiveOptions
                {
                    UseTripFolders = true,
                    UseYearFolders = true,
                    UseMonthFolders = true,
                    UseTypeFolders = false
                });

            TotalToExport = structure.Sum(x => x.Value.Count);
            ExportedCount = 0;
            CurrentStage = "Copying files...";
            CurrentExportFile = "";

            AddLog("Folder structure created");
            AddLog("Starting file copy");

            await InvokeAsync(StateHasChanged);
            await Task.Yield();

            int refreshCounter = 0;

            foreach (var folder in structure)
            {
                var targetFolder = Path.Combine(exportRoot, folder.Key);

                Directory.CreateDirectory(targetFolder);

                AddLog($"Created folder: {folder.Key}");

                int index = 1;

                foreach (var file in folder.Value)
                {
                    var newFileName = FileRenameService.BuildName(
                        file,
                        index,
                        RenameStrategy.DateAndType);

                    var destination = Path.Combine(targetFolder, newFileName);

                    File.Copy(file.FullPath, destination, true);

                    index++;
                    ExportedCount++;
                    CurrentExportFile = newFileName;

                    refreshCounter++;

                    if (refreshCounter % 5 == 0)
                    {
                        AddLog($"Copied: {newFileName}");

                        await InvokeAsync(StateHasChanged);
                        await Task.Yield();
                    }
                }
            }

            AddLog("Copy completed");

            var videoFiles = Directory
                .EnumerateFiles(exportRoot, "*.*", SearchOption.AllDirectories)
                .Where(f =>
                {
                    var ext = Path.GetExtension(f).ToLowerInvariant();
                    return ext is ".mov" or ".avi" or ".mkv" or ".wmv";
                })
                .ToList();

            CurrentStage = "Converting videos...";
            ExportedCount = 0;
            TotalToExport = videoFiles.Count;
            CurrentExportFile = "";

            AddLog($"Found {videoFiles.Count} videos");
            AddLog("Starting video conversion");

            await InvokeAsync(StateHasChanged);

            await FastVideoBatchExportService.ConvertAllVideosAsync(
                exportRoot,
                async (done, total, fileName) =>
                {
                    ExportedCount = done;
                    TotalToExport = total;
                    CurrentExportFile = fileName;

                    AddLog($"Video converted: {fileName}");

                    await InvokeAsync(StateHasChanged);
                });

            CurrentStage = "Converting images...";
            ExportedCount = 0;
            CurrentExportFile = "";

            AddLog("Starting image conversion");

            await InvokeAsync(StateHasChanged);

            await ImageBatchExportService.ConvertAllImagesAsync(
                exportRoot,
                async (done, total, fileName) =>
                {
                    ExportedCount = done;
                    TotalToExport = total;
                    CurrentExportFile = fileName;

                    AddLog($"Image converted: {fileName}");

                    await InvokeAsync(StateHasChanged);
                });

            CurrentStage = "Done ✔";
            CurrentExportFile = "";

            AddLog("Export completed successfully");

            await InvokeAsync(StateHasChanged);

            await Task.Delay(1000);

            Navigation.NavigateTo("/library", forceLoad: true);
        }
        finally
        {
            IsExporting = false;
        }
    }
}