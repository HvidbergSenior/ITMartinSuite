@page "/export"

@using ITMartin.Shared.Domain.Dtos
@using ITMartinFileSorter.Domain.Entities
@using ITMartinFileSorter.Domain.Enums

@inject DuplicateService DuplicateService
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@inject LibraryExportService LibraryExportService

<div class="filesorter-app">
    <div class="page-container stack export-page">

        <SectionTitle Title="📦 Export Organized Files" />

        <ContentCard Title="📁 Preview of your organized library" CssClass="export-preview">
            <div class="preview-tree">
                <ExportPreviewCard Items="PreviewItems" />
            </div>
        </ContentCard>

        @if (IsExporting)
        {
            <ProgressPanel
                Title="@CurrentStage"
                Current="@ExportedCount"
                Total="@TotalToExport"
                Percent="@ProgressPercent"
                CurrentItem="@CurrentExportFile"
                LoadingText="Preparing export..."
                Icon="📦" />
        }

        <ContentCard Title="Export Summary">
            <div class="summary-item">
                <strong>@FilesToExport.Count()</strong>
                <span>Files</span>
            </div>
        </ContentCard>

        @if (!IsExporting)
        {
            <ActionButtonBar CssClass="bottom">
                <button class="btn btn-primary btn-lg"
                        @onclick="StartExport">
                    Start Export → @FilesToExport.Count()
                </button>
            </ActionButtonBar>
        }

    </div>
</div>

@code {

    IEnumerable<MediaFile> FilesToExport =>
        DuplicateService.AllFiles
            .Where(f => f.Status == MediaFileStatus.ToKeep ||
                        f.SubCategory == MediaSubCategory.Meme ||
                        f.SubCategory == MediaSubCategory.Screenshot);

    IEnumerable<ExportPreviewItem> PreviewItems =>
        FilesToExport
            .GroupBy(f => new
            {
                f.MainCategory,
                f.Year,
                f.Month
            })
            .Select(g => new ExportPreviewItem
            {
                Category = g.Key.MainCategory.ToString(),
                Year = g.Key.Year,
                Month = g.Key.Month,
                Count = g.Count()
            })
            .ToList();

    bool IsExporting;
    int ExportedCount;
    int TotalToExport;

    string CurrentExportFile = "";
    string CurrentStage = "";

    int ProgressPercent =>
        TotalToExport == 0 ? 0 :
        (int)((double)ExportedCount / TotalToExport * 100);

    async Task StartExport()
    {
        IsExporting = true;

        var files = FilesToExport.ToList();

        var exportRoot = Path.Combine(
            Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments),
            "FileSorterExport");

        Directory.CreateDirectory(exportRoot);

        await LibraryExportService.ExportAsync(
            files,
            exportRoot,
            async (done, total, fileName, stage) =>
            {
                ExportedCount = done;
                TotalToExport = total;
                CurrentExportFile = fileName;
                CurrentStage = stage;

                await InvokeAsync(StateHasChanged);
            });

        Navigation.NavigateTo("/filesorter", true);
    }
}