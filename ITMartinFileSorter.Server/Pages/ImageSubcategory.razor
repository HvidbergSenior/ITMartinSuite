@page "/images/{SubCategory}"

@using ITMartin.Media.Domain.Entities
@using ITMartin.Media.Enums
@using ITMartinFileSorter.Application.Services

@inject DuplicateService DuplicateService

<div class="filesorter-app">

    <div class="page-container stack">

        <SectionTitle Title="@DisplayTitle" />

        <ContentCard Title="Images">

            @if (!Files.Any())
            {
                <div class="text-muted">
                    No images found.
                </div>
            }
            else
            {
                <div class="d-flex flex-wrap gap-2">

                    @foreach (var file in Files)
                    {
                        <FileSorterMediaCard
                            File="file"
                            ShowThumbnail="true" />
                    }

                </div>
            }

        </ContentCard>

    </div>

</div>

@code {

    [Parameter]
    public string? SubCategory { get; set; }

    private string DisplayTitle =>
        string.IsNullOrWhiteSpace(SubCategory)
            ? "Images"
            : SubCategory;

    private List<MediaFile> Files =>
        DuplicateService.AllFiles
            .Where(f =>
                f.MainCategory == MediaMainCategory.Image &&
                string.Equals(
                    f.SubCategory.ToString(),
                    SubCategory,
                    StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(f => f.CreatedAt)
            .ToList();
}