@page "/organize"

@using ITMartinFileSorter.Domain.Entities
@using ITMartinFileSorter.Domain.Enums

@inject DuplicateService DuplicateService
@inject NavigationManager Navigation

<div class="filesorter-app">
    <div class="page-container stack organize-page">

        <!-- TITLE -->
        <SectionTitle Title="🗂 Organize & Rename Files" />

        <!-- BATCH -->
        <ContentCard Title="Batch Apply">

            <div class="organize-toolbar">

                <div class="stack">
                    <label>Folder name</label>
                    <input @bind="BatchFolderName"
                           placeholder="Example: Martin / Thailand / Work" />
                </div>

                <div class="stack">
                    <label>Title</label>
                    <input @bind="BatchTitle"
                           placeholder="Example: Thailand Holiday" />
                </div>

            </div>

            <div class="organize-actions row">
                <button class="btn btn-primary"
                        @onclick="ApplyToSelected">
                    Apply to selected
                </button>

                <button class="btn btn-secondary"
                        @onclick="SelectAllVisible">
                    Select visible
                </button>

                <button class="btn btn-secondary"
                        @onclick="ClearSelection">
                    Clear
                </button>
            </div>

        </ContentCard>

        <!-- FILTER -->
        <ContentCard Title="Filter">
            <select @bind="SelectedCategory">
                <option value="">All categories</option>
                <option value="Image">Images</option>
                <option value="Video">Videos</option>
                <option value="Audio">Audio</option>
                <option value="Document">Documents</option>
            </select>
        </ContentCard>

        <!-- FILES -->
        <div class="organize-grid">
            @foreach (var file in FilteredFiles)
            {
                <div class="organize-file-card">

                    <div class="row space-between">

                        <div class="stack">

                            <div class="item-title">@file.FileName</div>

                            <div class="organize-meta">

                                <div>
                                    <span class="item-label">Type:</span>
                                    @file.MainCategory
                                </div>

                                <div>
                                    <span class="item-label">Date:</span>
                                    @(file.CreatedAt?.ToString("yyyy-MM-dd") ?? "Unknown")
                                </div>

                                <div>
                                    <span class="item-label">Folder:</span>
                                    @(file.UserFolderName ?? "-")
                                </div>

                                <div>
                                    <span class="item-label">Title:</span>
                                    @(file.UserTitle ?? "-")
                                </div>

                            </div>

                        </div>

                        <input type="checkbox"
                               @bind="Selected[file]" />

                    </div>

                </div>
            }
        </div>

        <!-- CTA -->
        <ActionButtonBar CssClass="bottom">
            <button class="btn btn-success btn-lg"
                    @onclick="GoToExport">
                Continue to Export
            </button>
        </ActionButtonBar>

    </div>
</div>
@code {
    string BatchFolderName = "";
    string BatchTitle = "";
    string SelectedCategory = "";

    Dictionary<MediaFile, bool> Selected = new();

    IEnumerable<MediaFile> FilteredFiles =>
        string.IsNullOrWhiteSpace(SelectedCategory)
            ? DuplicateService.FilesToExport
            : DuplicateService.FilesToExport
                .Where(f =>
                    f.MainCategory.ToString() == SelectedCategory);

    protected override void OnInitialized()
    {
        foreach (var file in DuplicateService.FilesToExport)
        {
            if (!Selected.ContainsKey(file))
                Selected[file] = false;
        }
    }

    void ApplyToSelected()
    {
        foreach (var file in FilteredFiles)
        {
            if (!Selected.TryGetValue(file, out var isSelected) ||
                !isSelected)
                continue;

            if (!string.IsNullOrWhiteSpace(BatchFolderName))
                file.UserFolderName = BatchFolderName;

            if (!string.IsNullOrWhiteSpace(BatchTitle))
                file.UserTitle = BatchTitle;
        }

        BatchFolderName = "";
        BatchTitle = "";
    }

    void SelectAllVisible()
    {
        foreach (var file in FilteredFiles)
        {
            Selected[file] = true;
        }
    }

    void ClearSelection()
    {
        foreach (var key in Selected.Keys.ToList())
        {
            Selected[key] = false;
        }
    }

    void GoToExport()
    {
        Navigation.NavigateTo("/export");
    }
}