@page "/duplicates"
@using ITMartinFileSorter.Domain.Entities
@using ITMartinFileSorter.Domain.Enums

@inject DuplicateService DuplicateService
@inject NavigationManager Navigation

<div class="category-page duplicate-page">

    <ActionButtonBar class="duplicate-toolbar">
        <SectionTitle Title="Handle Duplicates" />

        <div class="duplicate-actions">
            <button class="btn btn-success"
                    @onclick="Continue"
                    disabled="@(!AllGroupsHandled)">
                Continue
            </button>

            <button class="btn btn-danger"
                    @onclick="DeleteAllDuplicatesGlobally">
                Delete All (Keep Newest)
            </button>
        </div>
    </ActionButtonBar>

    <div class="duplicate-content">

        @if (!VisibleGroups.Any())
        {
            <EmptyState Message="All duplicates handled ✔" Type="success" />
        }
        else
        {
            @foreach (var group in VisibleGroups)
            {
                var newest = GetNewest(group);

                <ContentCard Title="Duplicate Group">

                    <!-- ✅ BUTTON FIXED -->
                    <div class="mb-3">
                        <button class="btn btn-success"
                                @onclick="async () => await DeleteAllButOne(group)">
                            Keep Newest (Delete Rest)
                        </button>
                    </div>

                    <!-- FILE LIST -->
                    <div class="d-flex flex-column gap-2">

                        @foreach (var file in group.OrderByDescending(f => f.CreatedAt))
                        {
                            var isNewest = file == newest;

                            <div class="duplicate-row @(isNewest ? "newest-file" : "")">

                                <div>
                                    <strong>@file.FileName</strong><br />

                                    <span class="text-muted">
                                        @file.CreatedAt?.ToString("yyyy-MM-dd HH:mm:ss")
                                    </span>

                                    @if (isNewest)
                                    {
                                        <div class="badge bg-success mt-1">
                                            Newest (kept)
                                        </div>
                                    }
                                    else if (file.Status == MediaFileStatus.ToDelete)
                                    {
                                        <div class="badge bg-danger mt-1">
                                            Will be deleted
                                        </div>
                                    }
                                </div>

                            </div>
                        }

                    </div>

                </ContentCard>
            }
        }

    </div>

</div>

@code {

    // ✅ ONLY SHOW UNHANDLED GROUPS
    IEnumerable<List<MediaFile>> VisibleGroups =>
        DuplicateService.DuplicateGroups
            .Where(g => g.Any(f => f.Status == MediaFileStatus.Initial));

    bool AllGroupsHandled =>
        DuplicateService.DuplicateGroups
            .All(g => g.Count(f => f.Status == MediaFileStatus.ToDelete) == g.Count - 1);

    MediaFile GetNewest(List<MediaFile> group)
    {
        return group
            .OrderByDescending(f => f.CreatedAt ?? DateTime.MinValue)
            .First();
    }

    async Task DeleteAllButOne(List<MediaFile> group)
    {
        var newest = GetNewest(group);

        foreach (var f in group)
        {
            f.Status = f == newest
                ? MediaFileStatus.ToKeep
                : MediaFileStatus.ToDelete;
        }

        await InvokeAsync(StateHasChanged);
    }

    async Task DeleteAllDuplicatesGlobally()
    {
        foreach (var group in DuplicateService.DuplicateGroups)
        {
            await DeleteAllButOne(group);
        }
    }

    void Continue()
    {
        DuplicateService.DuplicatesHandled = true;
        Navigation.NavigateTo("/filesorter");
    }
}