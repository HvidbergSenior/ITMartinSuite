@page "/duplicates"

@using ITMartin.Media.Entities
@using ITMartin.Media.Enums
@using ITMartinFileSorter.Application.Services

@inject DuplicateService DuplicateService
@inject NavigationManager Navigation
@inject ILogger<Duplicates> Logger

<div class="category-page duplicate-page">

    <ActionButtonBar CssClass="bottom">

        <SectionTitle Title="Handle Duplicates" />

        <div class="duplicate-actions">

            <button class="btn btn-success"
                    @onclick="Continue"
                    disabled="@(!AllGroupsHandled)">
                Continue
            </button>

            <button class="btn btn-danger"
                    @onclick="DeleteAllDuplicatesGlobally">
                Delete All (Keep Newest)
            </button>

        </div>

    </ActionButtonBar>

    <div class="duplicate-content">

        @if (!VisibleGroups.Any())
        {
            <EmptyState
                Message="All duplicates handled ✔"
                Type="success" />
        }
        else
        {
            @foreach (var group in VisibleGroups)
            {
                var newest = GetNewest(group);

                <ContentCard Title="Duplicate Group">

                    <button class="btn btn-success mb-3"
                            @onclick="@(() => DeleteAllButOne(group))">
                        Keep Newest
                    </button>

                    @foreach (var file in group
                        .OrderByDescending(f => f.CreatedAt))
                    {
                        var isNewest = file == newest;

                        <div class="duplicate-row @(isNewest ? "newest-file" : "")">

                            <strong>@file.FileName</strong>

                            @if (isNewest)
                            {
                                <span class="badge bg-success">
                                    Kept
                                </span>
                            }
                            else if (file.Status ==
                                     MediaFileStatus.ToDelete)
                            {
                                <span class="badge bg-danger">
                                    Deleted
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    Pending
                                </span>
                            }

                        </div>
                    }

                </ContentCard>
            }
        }

    </div>

</div>

@code {

    private IEnumerable<List<MediaFile>> DuplicateGroups =>
        DuplicateService.AllFiles
            .Where(f => !string.IsNullOrWhiteSpace(f.Hash))
            .GroupBy(f => f.Hash)
            .Where(g => g.Count() > 1)
            .Select(g => g.ToList());

    private IEnumerable<List<MediaFile>> VisibleGroups =>
        DuplicateGroups
            .Where(g => !IsGroupHandled(g));

    private bool AllGroupsHandled =>
        DuplicateGroups.All(IsGroupHandled);

    private static bool IsGroupHandled(
        List<MediaFile> group)
    {
        return group.Count(f =>
                   f.Status == MediaFileStatus.ToDelete)
               == group.Count - 1;
    }

    private static MediaFile GetNewest(
        List<MediaFile> group)
    {
        return group
            .OrderByDescending(f => f.CreatedAt)
            .First();
    }

    private void DeleteAllButOne(
        List<MediaFile> group)
    {
        var newest = GetNewest(group);

        foreach (var file in group)
        {
            file.Status =
                file == newest
                    ? MediaFileStatus.ToKeep
                    : MediaFileStatus.ToDelete;

            file.RequiresReview = false;
        }

        Logger.LogInformation(
            "Duplicate group handled. Kept newest file {File}",
            newest.FileName);
    }

    private void DeleteAllDuplicatesGlobally()
    {
        var groups = DuplicateGroups.ToList();

        foreach (var group in groups)
        {
            DeleteAllButOne(group);
        }

        Logger.LogInformation(
            "Handled all duplicate groups globally. Groups: {Count}",
            groups.Count);
    }

    private void Continue()
    {
        Logger.LogInformation(
            "Continuing from duplicate handling");

        Navigation.NavigateTo("/filesorter");
    }
}