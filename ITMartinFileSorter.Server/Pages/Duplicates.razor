@page "/duplicates"

@using ITMartinFileSorter.Domain.Entities
@using ITMartinFileSorter.Domain.Enums

@inject DuplicateService DuplicateService
@inject NavigationManager Navigation

<div class="category-page duplicate-page">

    <ActionButtonBar CssClass="bottom">
        <SectionTitle Title="Handle Duplicates" />

        <div class="duplicate-actions">
            <button class="btn btn-success"
                    @onclick="Continue"
                    disabled="@(!AllGroupsHandled)">
                Continue
            </button>

            <button class="btn btn-danger"
                    @onclick="DeleteAllDuplicatesGlobally">
                Delete All (Keep Newest)
            </button>
        </div>
    </ActionButtonBar>

    <div class="duplicate-content">

        @if (!VisibleGroups.Any())
        {
            <EmptyState Message="All duplicates handled ✔" Type="success" />
        }
        else
        {
            @foreach (var group in VisibleGroups)
            {
                var newest = GetNewest(group);

                <ContentCard Title="Duplicate Group">

                    <button class="btn btn-success mb-3"
                            @onclick="@(() => DeleteAllButOne(group))">
                        Keep Newest
                    </button>

                    @foreach (var file in group.OrderByDescending(f => f.CreatedAt))
                    {
                        var isNewest = file == newest;

                        <div class="duplicate-row @(isNewest ? "newest-file" : "")">
                            <strong>@file.FileName</strong>

                            @if (isNewest)
                            {
                                <span class="badge bg-success">Kept</span>
                            }
                            else if (file.Status == MediaFileStatus.ToDelete)
                            {
                                <span class="badge bg-danger">Deleted</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Pending</span>
                            }
                        </div>
                    }

                </ContentCard>
            }
        }

    </div>

</div>

@code {

    // 🔥 REBUILD GROUPS (since service no longer has DuplicateGroups)
    IEnumerable<List<MediaFile>> DuplicateGroups =>
        DuplicateService.AllFiles
            .Where(f => f.Hash != null)
            .GroupBy(f => f.Hash)
            .Where(g => g.Count() > 1)
            .Select(g => g.ToList());

    IEnumerable<List<MediaFile>> VisibleGroups =>
        DuplicateGroups
            .Where(g => !IsGroupHandled(g));

    bool AllGroupsHandled =>
        DuplicateGroups.All(g => IsGroupHandled(g));

    bool IsGroupHandled(List<MediaFile> group) =>
        group.Count(f => f.Status == MediaFileStatus.ToDelete) == group.Count - 1;

    MediaFile GetNewest(List<MediaFile> group)
        => group.OrderByDescending(f => f.CreatedAt).First();

    void DeleteAllButOne(List<MediaFile> group)
    {
        var newest = GetNewest(group);

        foreach (var f in group)
        {
            f.Status = f == newest
                ? MediaFileStatus.ToKeep
                : MediaFileStatus.ToDelete;

            f.RequiresReview = false;
        }
    }

    void DeleteAllDuplicatesGlobally()
    {
        foreach (var group in DuplicateGroups)
        {
            DeleteAllButOne(group);
        }
    }

    void Continue()
    {
        Navigation.NavigateTo("/filesorter");
    }
}