@page "/scanner"

@using ITMartin.Magic.Application.Interfaces
@using ITMartin.Magic.Application.Models
@using Microsoft.JSInterop

@inject IMagicCardAnalysisService MagicCardAnalysisService
@inject IJSRuntime JS
@inject ICardRecognitionService CardRecognitionService
@inject IScryfallService ScryfallService

<PageTitle>
    MTG Scanner
</PageTitle>

<div class="scanner-page">

    <!-- ========================================= -->
    <!-- HEADER -->
    <!-- ========================================= -->

    <div class="scanner-header">

        <div>

            <h1 class="scanner-title">
                MTG Card Scanner
            </h1>

            <div class="scanner-subtitle">
                OCR + OpenAI + Scryfall Matching
            </div>

        </div>

    </div>

    <!-- ========================================= -->
    <!-- CAMERA -->
    <!-- ========================================= -->

    <div class="scanner-wrapper">

        <video id="video"
               autoplay
               muted
               playsinline
               webkit-playsinline
               class="scanner-video">
        </video>

        <!-- ========================================= -->
        <!-- OCR OVERLAY -->
        <!-- ========================================= -->

        <div class="ocr-overlay">

            <div class="ocr-title-box"></div>

            <div class="ocr-bottom-box"></div>

            <div class="ocr-pt-box"></div>

        </div>

        <!-- ========================================= -->
        <!-- GUIDE -->
        <!-- ========================================= -->

        <div class="scanner-guide">

            <div class="guide-text">

                Keep card centered
                <br />
                avoid blur & glare

            </div>

        </div>

        <!-- ========================================= -->
        <!-- PROCESSING -->
        <!-- ========================================= -->

        @if (_isProcessing)
        {
            <div class="scanner-overlay">

                <div class="scanner-loading">

                    <div class="spinner-border text-light">
                    </div>

                    <div class="mt-3">
                        Scanning card...
                    </div>

                </div>

            </div>
        }

    </div>

    <!-- ========================================= -->
    <!-- BUTTONS -->
    <!-- ========================================= -->

    <div class="scanner-buttons">

        <button class="btn btn-success btn-lg scan-button"
                @onclick="Capture"
                disabled="@_isProcessing">

            @if (_isProcessing)
            {
                <span>
                    Processing...
                </span>
            }
            else
            {
                <span>
                    Capture Card
                </span>
            }

        </button>

    </div>

    <!-- ========================================= -->
    <!-- STATUS -->
    <!-- ========================================= -->

    @if (!string.IsNullOrWhiteSpace(_detectedText))
    {
        <div class="alert alert-dark scanner-alert mt-4">

            @_detectedText

        </div>
    }

    <!-- ========================================= -->
    <!-- OCR DEBUG -->
    <!-- ========================================= -->

    @if (_detection != null)
    {
        <div class="debug-panel mt-4">

            <h4 class="mb-3">
                OCR Debug
            </h4>

            <div class="debug-grid">

                <div class="debug-item">
                    <div class="debug-label">
                        Title
                    </div>

                    <div class="debug-value">
                        @_detection.Name
                    </div>
                </div>

                <div class="debug-item">
                    <div class="debug-label">
                        Set
                    </div>

                    <div class="debug-value">
                        @_detection.SetCode
                    </div>
                </div>

                <div class="debug-item">
                    <div class="debug-label">
                        Collector
                    </div>

                    <div class="debug-value">
                        @_detection.CollectorNumber
                    </div>
                </div>

                <div class="debug-item">
                    <div class="debug-label">
                        Artist
                    </div>

                    <div class="debug-value">
                        @_detection.Artist
                    </div>
                </div>

                <div class="debug-item">
                    <div class="debug-label">
                        Old Border
                    </div>

                    <div class="debug-value">
                        @_detection.IsOldBorder
                    </div>
                </div>

                <div class="debug-item">
                    <div class="debug-label">
                        White Border
                    </div>

                    <div class="debug-value">
                        @_detection.IsWhiteBorder
                    </div>
                </div>

                <div class="debug-item">
                    <div class="debug-label">
                        OCR Confidence
                    </div>

                    <div class="debug-value">
                        @((_detection.Confidence * 100).ToString("0"))%
                    </div>
                </div>

                <div class="debug-item">
                    <div class="debug-label">
                        Exact Printing
                    </div>

                    <div class="debug-value">
                        @_detection.ExactPrintingCertain
                    </div>
                </div>

            </div>

        </div>
    }

    <!-- ========================================= -->
    <!-- MATCHED CARD -->
    <!-- ========================================= -->

    @if (_card != null)
    {
        <div class="result-panel mt-5">

            <div class="card-result">

                <!-- ========================================= -->
                <!-- IMAGE -->
                <!-- ========================================= -->

                <div class="image-panel">

                    <img src="@_card.ImageUrl"
                         class="matched-card-image" />

                </div>

                <!-- ========================================= -->
                <!-- DETAILS -->
                <!-- ========================================= -->

                <div class="card-details">

                    <div class="card-header">

                        <div>

                            <h2 class="card-name">
                                @_card.Name
                            </h2>

                            <div class="set-line">

                                @_card.Set.ToUpperInvariant()
                                ·
                                #@_card.CollectorNumber

                            </div>

                        </div>

                        <div class="score-badge @GetScoreClass()">

                            @_card.MatchScore

                        </div>

                    </div>

                    <hr />

                    <!-- ========================================= -->
                    <!-- GRID -->
                    <!-- ========================================= -->

                    <div class="detail-grid">

                        <div class="detail-item">

                            <div class="detail-label">
                                Mana Cost
                            </div>

                            <div class="detail-value">
                                @_card.ManaCost
                            </div>

                        </div>

                        <div class="detail-item">

                            <div class="detail-label">
                                Rarity
                            </div>

                            <div class="detail-value">
                                @_card.Rarity
                            </div>

                        </div>

                        <div class="detail-item detail-full">

                            <div class="detail-label">
                                Type
                            </div>

                            <div class="detail-value">
                                @_card.TypeLine
                            </div>

                        </div>

                        <div class="detail-item detail-full">

                            <div class="detail-label">
                                Artist
                            </div>

                            <div class="detail-value">
                                @_card.Artist
                            </div>

                        </div>

                    </div>

                    <hr />

                    <!-- ========================================= -->
                    <!-- ORACLE -->
                    <!-- ========================================= -->

                    <div class="oracle-box">

                        @_card.OracleText

                    </div>

                </div>

            </div>

        </div>
    }

</div>

@code {

    private string? _detectedText;

    private ScryfallCard? _card;

    private bool _isProcessing;

    private CardDetectionResult? _detection;

    private decimal _blurScore;

    // =========================================
    // START CAMERA
    // =========================================

    protected override async Task OnAfterRenderAsync(
        bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync(
                "webcam.start");
        }
    }

    // =========================================
    // DISPOSE
    // =========================================

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync(
                "webcam.stop");
        }
        catch
        {
        }
    }

    // =========================================
    // CAPTURE
    // =========================================

    private async Task Capture()
    {
        if (_isProcessing)
        {
            return;
        }

        try
        {
            _isProcessing = true;

            _detectedText = null;

            _card = null;

            _detection = null;

            StateHasChanged();

            // =====================================
            // CAPTURE
            // =====================================

            var capture =
                await JS.InvokeAsync<CaptureResult>(
                    "webcam.capture");

            var clean =
                capture.Image.Replace(
                    "data:image/jpeg;base64,",
                    "");

            var bytes =
                Convert.FromBase64String(clean);

            // =====================================
            // SAVE
            // =====================================

            var folder =
                Path.Combine(
                    Directory.GetCurrentDirectory(),
                    "data",
                    "frames");

            Directory.CreateDirectory(folder);

            var fileName =
                $"{Guid.NewGuid()}.jpg";

            var path =
                Path.Combine(
                    folder,
                    fileName);

            await File.WriteAllBytesAsync(
                path,
                bytes);

            // =====================================
            // OCR DETECTION
            // =====================================

            var detection =
                await CardRecognitionService
                    .DetectAsync(path);

            if (detection == null)
            {
                _detectedText =
                    "OCR failed or image too blurry.";

                return;
            }

            _detection = detection;

            // =====================================
            // OPENAI
            // =====================================

            var magic =
                await MagicCardAnalysisService
                    .AnalyzeMagicCardAsync(
                        path,
                        detection);
            
            if (magic == null)
            {
                _detectedText =
                    "OpenAI could not identify card.";

                return;
            }

            // =====================================
            // MERGE AI RESULT
            // =====================================

            detection.Name =
                magic.CardName;

            detection.SetCode =
                magic.SetCode;

            detection.CollectorNumber =
                magic.CollectorNumber;

            detection.Artist =
                magic.Artist;

            detection.ManaCost =
                magic.ManaCost;

            detection.CardType =
                magic.CardType;

            detection.IsOldBorder =
                magic.IsOldBorder;

            detection.IsWhiteBorder =
                magic.IsWhiteBorder;

            detection.ExactPrintingCertain =
                magic.ExactPrintingCertain;

            detection.Confidence =
                magic.Confidence;

            detection.ReleaseEra =
                magic.ReleaseEra;

            _detectedText =
                $"AI: {magic.CardName} | " +
                $"SET={magic.SetCode} | " +
                $"#{magic.CollectorNumber} | " +
                $"CONF={(magic.Confidence * 100):0}%";

            // =====================================
            // SCRYFALL MATCH
            // =====================================

            _card =
                await ScryfallService
                    .SearchAsync(detection);

            if (_card == null)
            {
                _detectedText =
                    "Could not match printing.";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);

            _detectedText =
                ex.Message;
        }
        finally
        {
            _isProcessing = false;

            StateHasChanged();
        }
    }

    // =========================================
    // SCORE CLASS
    // =========================================

    private string GetScoreClass()
    {
        if (_card == null)
        {
            return "";
        }

        if (_card.MatchScore >= 8000)
        {
            return "score-perfect";
        }

        if (_card.MatchScore >= 4000)
        {
            return "score-good";
        }

        return "score-weak";
    }
}