@page "/scanner"

@using ITMartin.Magic.Application.Interfaces
@using ITMartin.Magic.Application.Models
@using Microsoft.JSInterop

@inject IMagicCardAnalysisService MagicCardAnalysisService
@inject IJSRuntime JS
@inject ICardRecognitionService CardRecognitionService
@inject IScryfallService ScryfallService

@inject ICardBoundaryDetectionService CardBoundaryDetectionService
@inject IPerspectiveCorrectionService PerspectiveCorrectionService
@inject IOcrRegionExtractor OcrRegionExtractor
@inject IBorderDetectionService BorderDetectionService

@implements IAsyncDisposable

<PageTitle>
    MTG Scanner
</PageTitle>

<div class="scanner-page">

    <!-- ========================================= -->
    <!-- HEADER -->
    <!-- ========================================= -->

    <div class="scanner-header">

        <div>

            <h1 class="scanner-title">
                MTG Scanner
            </h1>

            <div class="scanner-subtitle">
                AI powered printing detection
            </div>

        </div>

        <div class="ai-badge">
            GPT + OCR
        </div>

    </div>

    <!-- ========================================= -->
    <!-- CAMERA -->
    <!-- ========================================= -->

    <div class="scanner-wrapper">

        @if (!_cameraStarted)
        {
            <div class="camera-start-panel">

                <button @onclick="StartCamera">
                    Start Camera
                </button>

            </div>
        }
        else
        {
            <video id="video"
                   autoplay
                   muted
                   playsinline
                   webkit-playsinline
                   class="scanner-video">
            </video>

            <!-- ========================================= -->
            <!-- CARD GUIDE -->
            <!-- ========================================= -->

            <div class="scanner-guide">

                <div class="guide-text">
                    Align card inside frame
                </div>

            </div>

            <!-- ========================================= -->
            <!-- OCR VISUALIZATION -->
            <!-- ========================================= -->

            <div class="ocr-overlay">

                <div class="ocr-title-box"></div>

                <div class="ocr-bottom-box"></div>

                <div class="ocr-pt-box"></div>

            </div>
        }

        @if (_isProcessing)
        {
            <div class="scanner-overlay">

                <div class="scanner-loading">

                    <div class="spinner-border text-light">
                    </div>

                    <div class="mt-4 fw-bold">
                        @_detectedText
                    </div>

                </div>

            </div>
        }

    </div>

    <!-- ========================================= -->
    <!-- BUTTON -->
    <!-- ========================================= -->

    <div class="scanner-buttons">

        <button class="btn btn-success btn-lg scan-button"
                @onclick="Capture"
                disabled="@_isProcessing">

            @if (_isProcessing)
            {
                <span>
                    Scanning...
                </span>
            }
            else
            {
                <span>
                    Scan Card
                </span>
            }

        </button>

    </div>

    <!-- ========================================= -->
    <!-- STATUS -->
    <!-- ========================================= -->

    @if (!string.IsNullOrWhiteSpace(_detectedText))
    {
        <div class="alert alert-dark scanner-alert mt-4">

            @_detectedText

        </div>
    }

    <!-- ========================================= -->
    <!-- RESULT -->
    <!-- ========================================= -->

    @if (_searchResult != null)
    {
        <div class="result-panel">

            @if (_searchResult.BestMatch != null)
            {
                <div class="card-result">

                    <!-- ========================================= -->
                    <!-- IMAGE -->
                    <!-- ========================================= -->

                    <div class="image-panel">

                        <img src="@_searchResult.BestMatch.ImageUrl"
                             class="matched-card-image" />

                    </div>

                    <!-- ========================================= -->
                    <!-- DETAILS -->
                    <!-- ========================================= -->

                    <div class="card-details">

                        <div class="card-header">

                            <div>

                                <h2 class="card-name">
                                    @_searchResult.BestMatch.Name
                                </h2>

                                <div class="set-line">

                                    Most likely:
                                    @_searchResult.BestMatch.Set.ToUpperInvariant()
                                    ·
                                    #@_searchResult.BestMatch.CollectorNumber

                                </div>

                            </div>

                            <div class="score-badge @GetScoreClass()">

                                @_searchResult?.Matches?.FirstOrDefault()?.ConfidenceLabel

                            </div>

                        </div>

                        <!-- ========================================= -->
                        <!-- PRICES -->
                        <!-- ========================================= -->

                        <div class="price-grid">

                            <div class="price-box">

                                <div class="price-label">
                                    EUR
                                </div>

                                <div class="price-value">
                                    €@(_searchResult.BestMatch.EurPrice ?? 0)
                                </div>

                            </div>

                            <div class="price-box">

                                <div class="price-label">
                                    USD
                                </div>

                                <div class="price-value">
                                    $@(_searchResult.BestMatch.UsdPrice ?? 0)
                                </div>

                            </div>

                            <div class="price-box">

                                <div class="price-label">
                                    EUR Foil
                                </div>

                                <div class="price-value">
                                    €@(_searchResult.BestMatch.EurFoilPrice ?? 0)
                                </div>

                            </div>

                        </div>

                        <!-- ========================================= -->
                        <!-- DETAILS -->
                        <!-- ========================================= -->

                        <div class="detail-grid">

                            <div class="detail-item">

                                <div class="detail-label">
                                    OCR Confidence
                                </div>

                                <div class="detail-value">
                                    @(((_detection?.Confidence ?? 0) * 100).ToString("0"))%
                                </div>

                            </div>

                            <div class="detail-item">

                                <div class="detail-label">
                                    Border
                                </div>

                                <div class="detail-value">

                                    @if (_detection?.IsWhiteBorder == true)
                                    {
                                        <span>White Border</span>
                                    }
                                    else
                                    {
                                        <span>Black Border</span>
                                    }

                                </div>

                            </div>

                            <div class="detail-item">

                                <div class="detail-label">
                                    Mana Cost
                                </div>

                                <div class="detail-value">
                                    @_searchResult.BestMatch.ManaCost
                                </div>

                            </div>

                            <div class="detail-item">

                                <div class="detail-label">
                                    Rarity
                                </div>

                                <div class="detail-value">
                                    @_searchResult.BestMatch.Rarity
                                </div>

                            </div>

                            <div class="detail-item detail-full">

                                <div class="detail-label">
                                    Type
                                </div>

                                <div class="detail-value">
                                    @_searchResult.BestMatch.TypeLine
                                </div>

                            </div>

                            <div class="detail-item detail-full">

                                <div class="detail-label">
                                    Artist
                                </div>

                                <div class="detail-value">
                                    @_searchResult.BestMatch.Artist
                                </div>

                            </div>

                        </div>

                        <!-- ========================================= -->
                        <!-- ORACLE -->
                        <!-- ========================================= -->

                        <div class="oracle-box">

                            @_searchResult.BestMatch.OracleText

                        </div>

                    </div>

                </div>
            }

            <!-- ========================================= -->
            <!-- ALTERNATIVES -->
            <!-- ========================================= -->

            @if (_searchResult.Matches.Any())
            {
                <div class="top-matches-panel">

                    <h3 class="mb-4">
                        Alternative Printings
                    </h3>

                    <div class="matches-grid">

                        @foreach (var match in _searchResult.Matches)
                        {
                            <div class="match-card">

                                <img src="@match.Card.ImageUrl"
                                     class="match-image" />

                                <div class="match-content">

                                    <div class="match-name">
                                        @match.Card.Name
                                    </div>

                                    <div class="match-set">

                                        @match.Card.Set.ToUpperInvariant()
                                        ·
                                        #@match.Card.CollectorNumber

                                    </div>

                                    <div class="match-score">
                                        Score: @match.Score
                                    </div>

                                    <div class="match-confidence">
                                        @match.ConfidenceLabel
                                    </div>

                                </div>

                                <div class="match-price">

                                    €@(match.Card.EurPrice ?? 0)

                                </div>

                            </div>
                        }

                    </div>

                </div>
            }

            <!-- ========================================= -->
            <!-- DEBUG -->
            <!-- ========================================= -->

            @if (_detection != null)
            {
                <div class="debug-panel">

                    <h4 class="mb-3">
                        OCR Debug
                    </h4>

                    <div class="debug-grid">

                        <div class="debug-item">

                            <div class="debug-label">
                                Title
                            </div>

                            <div class="debug-value">
                                @_detection.Name
                            </div>

                        </div>

                        <div class="debug-item">

                            <div class="debug-label">
                                Set
                            </div>

                            <div class="debug-value">
                                @_detection.SetCode
                            </div>

                        </div>

                        <div class="debug-item">

                            <div class="debug-label">
                                Collector
                            </div>

                            <div class="debug-value">
                                @_detection.CollectorNumber
                            </div>

                        </div>

                        <div class="debug-item">

                            <div class="debug-label">
                                Artist
                            </div>

                            <div class="debug-value">
                                @_detection.Artist
                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>

@code {

    private string? _detectedText;

    private CardSearchResult? _searchResult;

    private bool _isProcessing;

    private CardDetectionResult? _detection;

    private bool _cameraStarted;

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync(
                "webcam.stop");
        }
        catch
        {
        }
    }

    private async Task StartCamera()
    {
        try
        {
            _cameraStarted = true;

            StateHasChanged();

            await Task.Delay(300);

            await JS.InvokeVoidAsync(
                "webcam.start");
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);

            _cameraStarted = false;

            _detectedText = ex.ToString();
        }

        StateHasChanged();
    }

    private async Task Capture()
    {
        if (!_cameraStarted ||
            _isProcessing)
        {
            return;
        }

        try
        {
            _isProcessing = true;

            _detectedText =
                "Capturing card...";

            _searchResult = null;

            _detection = null;

            StateHasChanged();

            var capture =
                await JS.InvokeAsync<CaptureResult>(
                    "webcam.capture");

            var clean =
                capture.Image.Replace(
                    "data:image/jpeg;base64,",
                    "");

            var bytes =
                Convert.FromBase64String(clean);

            var framesFolder =
                Path.Combine(
                    Directory.GetCurrentDirectory(),
                    "data",
                    "frames");

            Directory.CreateDirectory(
                framesFolder);

            var framePath =
                Path.Combine(
                    framesFolder,
                    $"{Guid.NewGuid()}.jpg");

            await File.WriteAllBytesAsync(
                framePath,
                bytes);

            _detectedText =
                "Detecting card edges...";

            StateHasChanged();

            var corners =
                await CardBoundaryDetectionService
                    .DetectAsync(framePath);

            if (corners == null ||
                !corners.Success)
            {
                _detectedText =
                    "Could not detect card.";

                return;
            }

            _detectedText =
                "Correcting perspective...";

            StateHasChanged();

            var normalizedPath =
                await PerspectiveCorrectionService
                    .CorrectAsync(
                        framePath,
                        corners);

            if (normalizedPath == null)
            {
                _detectedText =
                    "Perspective correction failed.";

                return;
            }

            _detectedText =
                "Extracting OCR regions...";

            StateHasChanged();

            var regions =
                await OcrRegionExtractor
                    .ExtractAsync(
                        normalizedPath);

            if (regions == null)
            {
                _detectedText =
                    "OCR extraction failed.";

                return;
            }

            _detectedText =
                "Reading card text...";

            StateHasChanged();

            var detection =
                await CardRecognitionService
                    .DetectAsync(regions);

            if (detection == null)
            {
                _detectedText =
                    "OCR failed.";

                return;
            }

            detection.IsOldBorder =
                BorderDetectionService
                    .IsOldBorder(
                        normalizedPath);

            detection.IsWhiteBorder =
                BorderDetectionService
                    .IsWhiteBorder(
                        normalizedPath);

            _detection =
                detection;

            _detectedText =
                "AI analyzing printing...";

            StateHasChanged();

            var magic =
                await MagicCardAnalysisService
                    .AnalyzeMagicCardAsync(
                        normalizedPath,
                        detection);

            if (magic != null)
            {
                detection.Name =
                    magic.CardName ??
                    detection.Name;

                detection.SetCode =
                    magic.SetCode ??
                    detection.SetCode;

                detection.CollectorNumber =
                    magic.CollectorNumber ??
                    detection.CollectorNumber;

                detection.Artist =
                    magic.Artist ??
                    detection.Artist;

                detection.ManaCost =
                    magic.ManaCost ??
                    detection.ManaCost;

                detection.CardType =
                    magic.CardType ??
                    detection.CardType;

                detection.IsOldBorder =
                    magic.IsOldBorder;

                detection.IsWhiteBorder =
                    magic.IsWhiteBorder;

                detection.ExactPrintingCertain =
                    magic.ExactPrintingCertain;

                detection.Confidence =
                    magic.Confidence;
            }

            _detectedText =
                "Matching edition...";

            StateHasChanged();

            _searchResult =
                await ScryfallService
                    .SearchAsync(
                        detection);

            _detectedText =
                "Scan complete";
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);

            _detectedText =
                ex.ToString();
        }
        finally
        {
            _isProcessing = false;

            StateHasChanged();
        }
    }

    private string GetScoreClass()
    {
        if (_searchResult?.BestMatch == null)
        {
            return "";
        }

        var score =
            _searchResult.Matches
                .FirstOrDefault()?.Score ?? 0;

        if (score >= 30000)
        {
            return "score-perfect";
        }

        if (score >= 15000)
        {
            return "score-good";
        }

        return "score-weak";
    }
}