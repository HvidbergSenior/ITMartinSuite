@page "/scanner"

@using ITMartin.Magic.Application.Interfaces
@using ITMartin.Magic.Application.Models
@using Microsoft.JSInterop

@inject IMagicCardAnalysisService MagicCardAnalysisService
@inject IJSRuntime JS
@inject ICardRecognitionService CardRecognitionService
@inject IScryfallService ScryfallService

@inject ICardBoundaryDetectionService CardBoundaryDetectionService
@inject IPerspectiveCorrectionService PerspectiveCorrectionService
@inject IOcrRegionExtractor OcrRegionExtractor
@inject IBorderDetectionService BorderDetectionService

@implements IAsyncDisposable

<PageTitle>
    MTG Scanner
</PageTitle>

<div class="scanner-page">

    <!-- ========================================= -->
    <!-- HEADER -->
    <!-- ========================================= -->

    <div class="scanner-header">

        <div>

            <h1 class="scanner-title">
                MTG Card Scanner
            </h1>

            <div class="scanner-subtitle">
                Phone Camera + OpenCV + OCR + OpenAI
            </div>

        </div>

    </div>

    <!-- ========================================= -->
    <!-- CAMERA -->
    <!-- ========================================= -->

    <div class="scanner-wrapper">

        @if (!_cameraStarted)
        {
            <div class="camera-start-panel">

                <button class="btn btn-primary btn-lg"
                        @onclick="StartCamera">

                    Start Camera

                </button>

            </div>
        }
        else
        {
            <video id="video"
                   autoplay
                   muted
                   playsinline
                   webkit-playsinline
                   class="scanner-video">
            </video>

            <div class="scanner-guide">

                <div class="guide-text">
                    Point phone at card and tap capture
                </div>

            </div>
        }

        @if (_isProcessing)
        {
            <div class="scanner-overlay">

                <div class="scanner-loading">

                    <div class="spinner-border text-light">
                    </div>

                    <div class="mt-3">
                        @_detectedText
                    </div>

                </div>

            </div>
        }

    </div>

    <!-- ========================================= -->
    <!-- BUTTONS -->
    <!-- ========================================= -->

    <div class="scanner-buttons">

        <button class="btn btn-success btn-lg scan-button"
                @onclick="Capture"
                disabled="@_isProcessing">

            @if (_isProcessing)
            {
                <span>
                    Processing...
                </span>
            }
            else
            {
                <span>
                    Capture Card
                </span>
            }

        </button>

    </div>

    <!-- ========================================= -->
    <!-- STATUS -->
    <!-- ========================================= -->

    @if (!string.IsNullOrWhiteSpace(_detectedText))
    {
        <div class="alert alert-dark scanner-alert mt-4">

            @_detectedText

        </div>
    }

    <!-- ========================================= -->
    <!-- OCR DEBUG -->
    <!-- ========================================= -->

    @if (_detection != null)
    {
        <div class="debug-panel mt-4">

            <h4 class="mb-3">
                OCR Debug
            </h4>

            <div class="debug-grid">

                <div class="debug-item">

                    <div class="debug-label">
                        Title
                    </div>

                    <div class="debug-value">
                        @_detection.Name
                    </div>

                </div>

                <div class="debug-item">

                    <div class="debug-label">
                        Set
                    </div>

                    <div class="debug-value">
                        @_detection.SetCode
                    </div>

                </div>

                <div class="debug-item">

                    <div class="debug-label">
                        Collector
                    </div>

                    <div class="debug-value">
                        @_detection.CollectorNumber
                    </div>

                </div>

                <div class="debug-item">

                    <div class="debug-label">
                        Artist
                    </div>

                    <div class="debug-value">
                        @_detection.Artist
                    </div>

                </div>

                <div class="debug-item">

                    <div class="debug-label">
                        Old Border
                    </div>

                    <div class="debug-value">
                        @_detection.IsOldBorder
                    </div>

                </div>

                <div class="debug-item">

                    <div class="debug-label">
                        White Border
                    </div>

                    <div class="debug-value">
                        @_detection.IsWhiteBorder
                    </div>

                </div>

                <div class="debug-item">

                    <div class="debug-label">
                        OCR Confidence
                    </div>

                    <div class="debug-value">
                        @((_detection.OcrConfidence * 100).ToString("0"))%
                    </div>

                </div>

                <div class="debug-item">

                    <div class="debug-label">
                        Exact Printing
                    </div>

                    <div class="debug-value">
                        @_detection.ExactPrintingCertain
                    </div>

                </div>

            </div>

        </div>
    }

    <!-- ========================================= -->
    <!-- MATCHED CARD -->
    <!-- ========================================= -->

    @if (_card != null)
    {
        <div class="result-panel mt-5">

            <div class="card-result">

                <div class="image-panel">

                    <img src="@_card.ImageUrl"
                         class="matched-card-image" />

                </div>

                <div class="card-details">

                    <div class="card-header">

                        <div>

                            <h2 class="card-name">
                                @_card.Name
                            </h2>

                            <div class="set-line">

                                @_card.Set.ToUpperInvariant()
                                ·
                                #@_card.CollectorNumber

                            </div>

                        </div>

                        <div class="score-badge @GetScoreClass()">

                            @_card.MatchScore

                        </div>

                    </div>

                    <hr />

                    <div class="detail-grid">

                        <div class="detail-item">

                            <div class="detail-label">
                                Mana Cost
                            </div>

                            <div class="detail-value">
                                @_card.ManaCost
                            </div>

                        </div>

                        <div class="detail-item">

                            <div class="detail-label">
                                Rarity
                            </div>

                            <div class="detail-value">
                                @_card.Rarity
                            </div>

                        </div>

                        <div class="detail-item detail-full">

                            <div class="detail-label">
                                Type
                            </div>

                            <div class="detail-value">
                                @_card.TypeLine
                            </div>

                        </div>

                        <div class="detail-item detail-full">

                            <div class="detail-label">
                                Artist
                            </div>

                            <div class="detail-value">
                                @_card.Artist
                            </div>

                        </div>

                    </div>

                    <hr />

                    <div class="oracle-box">

                        @_card.OracleText

                    </div>

                </div>

            </div>

        </div>
    }

</div>

@code {

    private string? _detectedText;

    private ScryfallCard? _card;

    private bool _isProcessing;

    private CardDetectionResult? _detection;
    private bool _cameraStarted;
    // =========================================
    // START CAMERA
    // =========================================

    protected override Task OnAfterRenderAsync(
        bool firstRender)
    {
        return Task.CompletedTask;
    }

    // =========================================
    // DISPOSE
    // =========================================

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync(
                "webcam.stop");
        }
        catch
        {
        }
    }
    private async Task StartCamera()
    {
        try
        {
            // =====================================
            // SHOW VIDEO
            // =====================================

            _cameraStarted = true;

            StateHasChanged();

            // =====================================
            // WAIT FOR RENDER
            // =====================================

            await Task.Delay(300);

            // =====================================
            // START CAMERA
            // =====================================

            await JS.InvokeVoidAsync(
                "webcam.start");
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);

            _cameraStarted = false;

            _detectedText =
                ex.ToString();
        }

        StateHasChanged();
    }
    // =========================================
    // CAPTURE
    // =========================================

    private async Task Capture()
    {
        if (!_cameraStarted)
        {
            _detectedText =
                "Camera not started.";

            return;
        }
        if (_isProcessing)
        {
            return;
        }

        try
        {
            _isProcessing = true;

            _detectedText = "Capturing...";

            _card = null;

            _detection = null;

            StateHasChanged();

            // =====================================
            // CAPTURE
            // =====================================

            var capture =
                await JS.InvokeAsync<CaptureResult>(
                    "webcam.capture");

            var clean =
                capture.Image.Replace(
                    "data:image/jpeg;base64,",
                    "");

            var bytes =
                Convert.FromBase64String(clean);

            // =====================================
            // SAVE FRAME
            // =====================================

            var framesFolder =
                Path.Combine(
                    Directory.GetCurrentDirectory(),
                    "data",
                    "frames");

            Directory.CreateDirectory(
                framesFolder);

            var framePath =
                Path.Combine(
                    framesFolder,
                    $"{Guid.NewGuid()}.jpg");

            await File.WriteAllBytesAsync(
                framePath,
                bytes);

            // =====================================
            // BOUNDARY DETECTION
            // =====================================

            _detectedText =
                "Detecting card...";

            StateHasChanged();

            var corners =
                await CardBoundaryDetectionService
                    .DetectAsync(framePath);

            if (corners == null ||
                !corners.Success)
            {
                _detectedText =
                    "Could not detect card.";

                return;
            }

            // =====================================
            // NORMALIZATION
            // =====================================

            _detectedText =
                "Correcting perspective...";

            StateHasChanged();

            var normalizedPath =
                await PerspectiveCorrectionService
                    .CorrectAsync(
                        framePath,
                        corners);

            if (normalizedPath == null)
            {
                _detectedText =
                    "Perspective correction failed.";

                return;
            }

            // =====================================
            // OCR REGIONS
            // =====================================

            _detectedText =
                "Extracting OCR regions...";

            StateHasChanged();

            var regions =
                await OcrRegionExtractor
                    .ExtractAsync(
                        normalizedPath);

            if (regions == null)
            {
                _detectedText =
                    "OCR region extraction failed.";

                return;
            }

            // =====================================
            // OCR
            // =====================================

            _detectedText =
                "Reading text...";

            StateHasChanged();

            var detection =
                await CardRecognitionService
                    .DetectAsync(
                        regions);

            if (detection == null)
            {
                _detectedText =
                    "OCR failed.";

                return;
            }

            detection.IsOldBorder =
                BorderDetectionService
                    .IsOldBorder(
                        normalizedPath);

            detection.IsWhiteBorder =
                BorderDetectionService
                    .IsWhiteBorder(
                        normalizedPath);

            _detection =
                detection;

            // =====================================
            // AI
            // =====================================

            _detectedText =
                "Analyzing card...";

            StateHasChanged();

            var magic =
                await MagicCardAnalysisService
                    .AnalyzeMagicCardAsync(
                        normalizedPath,
                        detection);

            if (magic != null)
            {
                detection.Name =
                    magic.CardName ??
                    detection.Name;

                detection.SetCode =
                    magic.SetCode ??
                    detection.SetCode;

                detection.CollectorNumber =
                    magic.CollectorNumber ??
                    detection.CollectorNumber;

                detection.Artist =
                    magic.Artist ??
                    detection.Artist;

                detection.ManaCost =
                    magic.ManaCost ??
                    detection.ManaCost;

                detection.CardType =
                    magic.CardType ??
                    detection.CardType;

                detection.IsOldBorder =
                    magic.IsOldBorder;

                detection.IsWhiteBorder =
                    magic.IsWhiteBorder;

                detection.ExactPrintingCertain =
                    magic.ExactPrintingCertain;

                detection.Confidence =
                    magic.Confidence;

                detection.ReleaseEra =
                    magic.ReleaseEra;
            }

            // =====================================
            // SCRYFALL
            // =====================================

            _detectedText =
                "Matching printing...";

            StateHasChanged();

            _card =
                await ScryfallService
                    .SearchAsync(
                        detection);

            // =====================================
            // FINAL STATUS
            // =====================================

            _detectedText =
                $@"NAME: {detection.Name}
SET: {detection.SetCode}
COLLECTOR: {detection.CollectorNumber}
ARTIST: {detection.Artist}
PT: {detection.PowerToughness}
OCR: {(detection.OcrConfidence * 100):0}%";

            if (_card == null)
            {
                _detectedText +=
                    "\n\nNo exact Scryfall match found.";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);

            _detectedText =
                ex.ToString();
        }
        finally
        {
            _isProcessing = false;

            StateHasChanged();
        }
    }

    // =========================================
    // SCORE CLASS
    // =========================================

    private string GetScoreClass()
    {
        if (_card == null)
        {
            return "";
        }

        if (_card.MatchScore >= 8000)
        {
            return "score-perfect";
        }

        if (_card.MatchScore >= 4000)
        {
            return "score-good";
        }

        return "score-weak";
    }
}