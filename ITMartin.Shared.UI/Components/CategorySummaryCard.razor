<div class="category-card @CssClass @(IsLocked ? "locked" : "")"
     @onclick="HandleClick"
     @onclick:preventDefault
     @onclick:stopPropagation>

    <!-- TITLE -->
    <div class="category-title">
        @Title
    </div>

    <!-- STATUS -->
    <div class="category-status">

        @if (Total == 0)
        {
            <span class="text-muted">No files</span>
        }
        else if (ReviewCount == 0)
        {
            <span class="text-success">✔ All done</span>
        }
        else
        {
            <div class="text-warning">
                ⚠ @ReviewCount need review
            </div>

            @if (ProcessedCount > 0)
            {
                <div class="text-muted small">
                    @ProcessedCount processed
                </div>
            }
        }

    </div>

    <!-- META -->
    <div class="category-meta">
        @Total files • @SizeText
    </div>

    <!-- PROGRESS -->
    @if (Total > 0)
    {
        <div class="category-progress">
            <div class="category-progress-fill"
                 style="width:@((double)ProcessedCount / Total * 100)%">
            </div>
        </div>
    }

    <!-- ACTION -->
    @if (!IsLocked && ReviewCount > 0)
    {
        <div class="category-action">
            ▶ Start Review
        </div>
    }

</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public int ReviewCount { get; set; }
    [Parameter] public int ProcessedCount { get; set; }
    [Parameter] public int Total { get; set; }
    [Parameter] public string SizeText { get; set; } = "";
    [Parameter] public string CssClass { get; set; } = "";
    [Parameter] public bool IsLocked { get; set; }

    [Parameter] public EventCallback OnClick { get; set; }

    private async Task HandleClick()
    {
        if (IsLocked) return;

        await OnClick.InvokeAsync();
    }
}