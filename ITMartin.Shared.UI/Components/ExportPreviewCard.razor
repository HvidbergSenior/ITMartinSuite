@using System.Globalization
@using ITMartin.Shared.Domain.Dtos
// or the correct one
@if (!Items.Any())
{
    <div class="preview-empty">No files selected for export</div>
}
else
{
    @foreach (var category in Items.GroupBy(i => i.Category).OrderBy(c => c.Key))
    {
        <div class="tree">

            <!-- CATEGORY -->
            <div class="tree-node root">
                📁 @category.Key
            </div>

            @foreach (var year in category.GroupBy(i => i.Year).OrderByDescending(y => y.Key))
            {
                <div class="tree-node year">
                    <span class="tree-branch">├──</span>
                    📂 @year.Key
                </div>

                @foreach (var month in year.OrderBy(i => i.Month))
                {
                    var monthName = new DateTime(year.Key, month.Month, 1)
                        .ToString("MMMM", new CultureInfo("da-DK"));

                    <div class="tree-node month">
                        <span class="tree-branch">│   ├──</span>

                        <span class="tree-name">📄 @monthName</span>
                        <span class="tree-count">@month.Count files</span>
                    </div>
                }
            }

        </div>
    }
}

    @code {
        [Parameter] public IEnumerable<ExportPreviewItem> Items { get; set; } = [];
    }
