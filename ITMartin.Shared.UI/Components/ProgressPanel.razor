<div class="content-card progress-panel">

    <!-- HEADER -->
    <div class="progress-header">
        <div class="progress-title">
            @if (!string.IsNullOrWhiteSpace(Icon))
            {
                <span class="me-1">@Icon</span>
            }
            @Title
        </div>

        @if (Total > 0)
        {
            <div class="progress-percent">@Percent%</div>
        }
    </div>

    @if (Total == 0)
    {
        <!-- LOADING STATE -->
        <div class="progress-loading">
            <div class="spinner"></div>
            <span>@LoadingText</span>
        </div>
    }
    else
    {
        <!-- PROGRESS BAR -->
        <div class="progress-bar">
            <div class="progress-fill"
                 style="width:@Percent%">
            </div>
        </div>

        <!-- META -->
        <div class="progress-meta">
            <span>@Current / @Total</span>

            @if (!string.IsNullOrWhiteSpace(CurrentItem))
            {
                <span class="progress-file">@CurrentItem</span>
            }
        </div>
    }

</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public int Current { get; set; }
    [Parameter] public int Total { get; set; }
    [Parameter] public int Percent { get; set; }
    [Parameter] public string? CurrentItem { get; set; }

    // 🔥 makes it reusable everywhere
    [Parameter] public string LoadingText { get; set; } = "Working...";
    [Parameter] public string? Icon { get; set; }
}