<div class="media-card card card-hover">

    <!-- THUMB -->
    <div class="media-thumb-wrapper">

        @if (!string.IsNullOrEmpty(ImageUrl))
        {
            <img src="@ImageUrl" class="media-thumb" />
        }
        else
        {
            <div class="media-icon">@Icon</div>
        }

    </div>

    <!-- INFO -->
    <div class="media-info">
        <div class="media-name">@Title</div>
        <div class="media-size">@SizeText</div>
    </div>

    <!-- ACTIONS -->
    <div class="media-actions">

        @if (OnSecondary.HasDelegate)
        {
            <button class="btn btn-danger btn-sm"
                    @onclick:stopPropagation="true"
                    @onclick="OnSecondary">
                Delete
            </button>
        }

        @if (OnPrimary.HasDelegate)
        {
            <button class="btn btn-primary btn-sm"
                    @onclick="OnPrimary">
                @PrimaryText
            </button>
        }

    </div>

</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string SizeText { get; set; } = "";
    [Parameter] public string? ImageUrl { get; set; }
    [Parameter] public string Icon { get; set; } = "📄";

    [Parameter] public string PrimaryText { get; set; } = "Select";
    [Parameter] public EventCallback OnPrimary { get; set; }
    [Parameter] public EventCallback OnSecondary { get; set; }
}