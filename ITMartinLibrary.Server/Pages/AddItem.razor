@page "/library/new"

@using ITMartinLibrary.Application.Services
@using ITMartinLibrary.Domain.Entities

@inject InventoryService InventoryService
@inject NavigationManager Navigation

<div class="library-page">

    <SectionTitle Title="➕ Add New Inventory Item" />

    <ContentCard>
        <input @bind="item.Barcode"
               placeholder="Scan barcode here"
               class="form-control mb-2"
               autofocus />

        <input @bind="item.Title"
               placeholder="Title"
               class="form-control mb-2" />

        <input @bind="item.Type"
               placeholder="Type"
               class="form-control mb-2" />

        <input @bind="item.AuthorOrDirector"
               placeholder="Author / Director"
               class="form-control mb-2" />

        <input @bind="item.ShelfLocation"
               placeholder="Shelf Location"
               class="form-control mb-2" />

        <input @bind="item.Price"
               type="number"
               class="form-control mb-2" />

        <input @bind="item.Quantity"
               type="number"
               class="form-control mb-3" />

        <button class="btn btn-success" @onclick="Save">
            Save Item
        </button>
    </ContentCard>

</div>

@code {
    private InventoryItem item = new();

    private async Task Save()
    {
        await InventoryService.AddAsync(item);
        Navigation.NavigateTo("/library");
    }
}