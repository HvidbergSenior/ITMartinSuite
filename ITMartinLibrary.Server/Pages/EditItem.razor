@page "/library/edit/{Id:int}"

@using ITMartinLibrary.Application.Interfaces
@using ITMartinLibrary.Domain.Entities
@inject InventoryService InventoryService
@inject IBarcodeLookupService BarcodeLookupService
@inject NavigationManager Navigation

<div class="library-page">
    <div class="page-container">

        <div class="scan-hero-card">
            <h1>✏️ Edit Item</h1>
            <p class="hero-text">
                Update inventory details and enrich movie metadata.
            </p>
        </div>

        <div class="content-card form-card">

            @if (item is null)
            {
                <p>Loading...</p>
            }
            else
            {
                <div class="inventory-form-grid">
                    <div>
                        <label>Title</label>
                        <input @bind="item.Title" class="form-control" />
                    </div>

                    <div>
                        <label>Type</label>
                        <input @bind="item.Type" class="form-control" />
                    </div>

                    <div>
                        <label>Author / Director</label>
                        <input @bind="item.AuthorOrDirector" class="form-control" />
                    </div>

                    <div>
                        <label>Genre</label>
                        <input @bind="item.Genre" class="form-control" />
                    </div>

                    <div>
                        <label>Runtime</label>
                        <input @bind="item.Runtime" class="form-control" />
                    </div>

                    <div>
                        <label>Release Year</label>
                        <input @bind="item.ReleaseYear" class="form-control" />
                    </div>

                    <div>
                        <label>Plot</label>
                        <textarea @bind="item.Plot" class="form-control"></textarea>
                    </div>
                </div>

                <div class="form-actions mt-3">
                    <button class="btn btn-primary" @onclick="SearchMovie">
                        🎬 Search Movie Details
                    </button>

                    <button class="btn btn-success" @onclick="Save">
                        💾 Save
                    </button>

                    <a href="/library" class="btn btn-secondary">
                        📚 Back
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }

    private InventoryItem? item;

    protected override async Task OnInitializedAsync()
    {
        item = await InventoryService.GetByIdAsync(Id);
    }

    private async Task SearchMovie()
    {
        if (item is null || string.IsNullOrWhiteSpace(item.Title))
            return;

        var enriched =
            await BarcodeLookupService.LookupMovieByTitleAsync(item.Title);

        if (enriched is null)
            return;

        item.Title = enriched.Title;
        item.AuthorOrDirector = enriched.AuthorOrDirector;
        item.Genre = enriched.Genre;
        item.Runtime = enriched.Runtime;
        item.ReleaseYear = enriched.ReleaseYear;
        item.Plot = enriched.Plot;
        item.CoverUrl = enriched.CoverUrl;
        item.Type = enriched.Type;
        item.LookupStatus = "Completed";

        await InventoryService.UpdateAsync(item);
    }

    private async Task Save()
    {
        if (item is null)
            return;

        await InventoryService.UpdateAsync(item);

        Navigation.NavigateTo("/library");
    }
}