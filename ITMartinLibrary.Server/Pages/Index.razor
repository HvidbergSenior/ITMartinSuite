@page "/"
@page "/library"

@using ITMartinLibrary.Application.Services
@using ITMartin.Shared.UI.Components
@using ITMartinLibrary.Domain.Entities

@inject InventoryService InventoryService

<div class="library-page">

    <SectionTitle Title="📚 Library Inventory" />

    <ContentCard>
        <div class="d-flex justify-content-between align-items-center">
            <p class="mb-0">
                Manage books, films and shop inventory.
            </p>

            <div class="d-flex gap-2">
                <a href="/library/new" class="btn btn-primary">
                    Add New Item
                </a>

                <a href="/library/quick-scan" class="btn btn-outline-light">
                    Quick Scan
                </a>
            </div>
        </div>
    </ContentCard>

    @if (!items.Any())
    {
        <ContentCard>
            <EmptyState Message="No items added yet." />
        </ContentCard>
    }
    else
    {
        <div class="file-grid mt-4">
            @foreach (var item in items)
            {
                <ContentCard>
                    <h4>@(item.Title ?? "Untitled")</h4>

                    <div class="text-muted mt-2">
                        <div><strong>Type:</strong> @(item.Type ?? "Unknown")</div>
                        <div><strong>Quantity:</strong> @item.Quantity</div>
                        <div><strong>Price:</strong> @item.Price</div>
                        <div><strong>Shelf:</strong> @(string.IsNullOrWhiteSpace(item.ShelfLocation) ? "-" : item.ShelfLocation)</div>
                    </div>
                </ContentCard>
            }
        </div>
    }

</div>

@code {
    private List<InventoryItem> items = new();

    protected override async Task OnInitializedAsync()
    {
        items = await InventoryService.GetAllAsync() ?? new();
    }
}