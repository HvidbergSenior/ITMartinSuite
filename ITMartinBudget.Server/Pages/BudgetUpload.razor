@page "/budget/upload"
@layout BudgetMainLayout
@rendermode InteractiveServer

@using ITMartinBudget.Infrastructure
@using ITMartinBudget.Infrastructure.Services
@using Microsoft.EntityFrameworkCore

@inject BudgetDbContext Db
@inject BankTransactionCsvService CsvService
@inject NavigationManager Nav
@inject IJSRuntime Js

<div class="budget-container">

    <ContentCard>
        <div class="stack">

            <div>
                <h2>📁 Upload</h2>
                <div class="meta">Upload your bank CSV</div>
            </div>

            @if (_hasExistingData)
            {
                <div class="alert warning">
                    ⚠ Existing data detected

                    <button class="btn btn-danger" @onclick="ConfirmReset">
                        Delete all
                    </button>
                </div>
            }

            <div class="upload-box">
                <InputFile OnChange="HandleBankCsvUpload" disabled="@_isUploading" />
            </div>

            @if (_isUploading)
            {
                <div class="meta">Uploading...</div>
            }

            @if (!string.IsNullOrWhiteSpace(_message))
            {
                <div class="alert success">@_message</div>
            }

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="alert error">@_error</div>
            }

        </div>
    </ContentCard>

</div>

@code {
    private bool _hasExistingData;
    private bool _isUploading;
    private string? _message;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _hasExistingData = await Db.Transactions.AnyAsync();
    }

    private async Task HandleBankCsvUpload(InputFileChangeEventArgs e)
    {
        if (_isUploading) return;

        try
        {
            _isUploading = true;
            _error = null;
            _message = null;

            var file = e.File;

            if (file == null)
                throw new Exception("No file selected");

            if (!file.Name.EndsWith(".csv", StringComparison.OrdinalIgnoreCase))
                throw new Exception("Only CSV files allowed");

            using var stream = file.OpenReadStream(long.MaxValue);

            var newTransactions = await CsvService.ImportAsync(stream);

            _message = newTransactions.Any()
                ? $"✔ Imported {newTransactions.Count} transactions"
                : "No new transactions (duplicates skipped)";

            await Task.Delay(300);
            Nav.NavigateTo("/budget", true);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isUploading = false;
        }
    }

    private async Task ConfirmReset()
    {
        if (await Js.InvokeAsync<bool>("confirm", "Delete ALL data?"))
            await FullReset();
    }

    private async Task FullReset()
    {
        Db.Transactions.RemoveRange(Db.Transactions);
        Db.UnknownTransactions.RemoveRange(Db.UnknownTransactions);

        await Db.SaveChangesAsync();

        _hasExistingData = false;
        _message = "All data deleted";
    }
}