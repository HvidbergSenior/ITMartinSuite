@page "/budget/upload"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Forms
@using ITMartinBudget.Domain.Entities
@using ITMartinBudget.Application.Services
@using ITMartinBudget.Domain.Enums
@using ITMartinBudget.Infrastructure
@using ITMartinBudget.Infrastructure.Services
@using Microsoft.EntityFrameworkCore

@inject BankTransactionCsvService CsvService
@inject BudgetService BudgetService
@inject BudgetDbContext Db

<div class="page-container">

    <div class="card-primary">
        <h1>💰 Budget Analysis</h1>

        <div class="upload-grid">
            <InputFile OnChange="HandleBankCsvUpload" />

            <select @bind="_selectedYear" @bind:after="Calculate">
                @foreach (var year in _years)
                {
                    <option value="@year">@year</option>
                }
            </select>
        </div>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <div class="text-success">@_message</div>
        }

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="text-danger">@_error</div>
        }
    </div>

    @if (_summary.Any())
    {
        <div class="dashboard-stats-grid">
            <div class="card-secondary stat-card">
                <h3 class="text-success">@_totals?.Income.ToString("N2")</h3>
                <p>Income</p>
            </div>

            <div class="card-secondary stat-card">
                <h3 class="text-danger">@_totals?.Expenses.ToString("N2")</h3>
                <p>Expenses</p>
            </div>

            <div class="card-secondary stat-card">
                <h3>@_totals?.Net.ToString("N2")</h3>
                <p>Net</p>
            </div>
        </div>

        <div class="budget-layout">

            <!-- INCOME -->
            <div class="budget-column">
                <h3 class="text-success">💰 Income</h3>

                @foreach (var group in IncomeCategories().GroupBy(x => x.MainCategory))
                {
                    <div class="category-card income">
                        <div class="category-header">
                            <strong>@group.Key</strong>
                            <span>@group.Sum(x => x.Total).ToString("N2")</span>
                        </div>

                        @foreach (var item in group)
                        {
                            var key = $"{item.MainCategory}-{item.DisplayName}";

                            <div class="subcategory-card @(IsOpen(key) ? "open" : "")"
                                 @onclick="@(() => ToggleCategory(key))">

                                <div class="subcategory-header">
                                    <div>
                                        <div class="title">@item.DisplayName</div>
                                        <div class="meta">
                                            @item.TransactionCount • @item.Frequency
                                        </div>
                                    </div>

                                    <div class="amount text-success">
                                        @item.Total.ToString("N2")
                                    </div>
                                </div>

                                @if (IsOpen(key))
                                {
                                    var all = GetFilteredTransactions(item).Count();

                                    <div class="subcategory-transactions">
                                        @foreach (var t in GetFilteredTransactions(item).Take(GetVisibleCount(key)))
                                        {
                                            <div class="transaction-row">
                                                <div>@t.Date.ToString("dd-MM")</div>
                                                <div>@t.Description</div>
                                                <div class="@GetAmountClass(t.Amount)">
                                                    @t.Amount.ToString("N2")
                                                </div>
                                            </div>
                                        }

                                        @if (GetVisibleCount(key) < all)
                                        {
                                            <button class="btn btn-secondary"
                                                    @onclick="() => IncreaseVisible(key)">
                                                Show more
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- EXPENSES -->
            <div class="budget-column">
                <h3 class="text-danger">💸 Expenses</h3>

                @foreach (var group in ExpenseCategories().GroupBy(x => x.MainCategory))
                {
                    <div class="category-card expense">
                        <div class="category-header">
                            <strong>@group.Key</strong>
                            <span>@Math.Abs(group.Sum(x => x.Total)).ToString("N2")</span>
                        </div>

                        @foreach (var item in group)
                        {
                            var key = $"{item.MainCategory}-{item.DisplayName}";

                            <div class="subcategory-card @(IsOpen(key) ? "open" : "")"
                                 @onclick="@(() => ToggleCategory(key))">

                                <div class="subcategory-header">
                                    <div>
                                        <div class="title">@item.DisplayName</div>
                                        <div class="meta">
                                            @item.TransactionCount • @item.Frequency
                                        </div>
                                    </div>

                                    <div class="amount text-danger">
                                        @Math.Abs(item.Total).ToString("N2")
                                    </div>
                                </div>

                                @if (IsOpen(key))
                                {
                                    <div class="subcategory-transactions">
                                        @foreach (var t in GetFilteredTransactions(item).Take(GetVisibleCount(key)))
                                        {
                                            <div class="transaction-row">
                                                <div>@t.Date.ToString("dd-MM")</div>
                                                <div>@t.Description</div>
                                                <div class="@GetAmountClass(t.Amount)">
                                                    @t.Amount.ToString("N2")
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

        </div>
    }

</div>

@code {
    private List<BankTransaction>? _transactions;
    private List<CategorySummary> _summary = new();
    private YearSummary? _totals;

    private string? _message;
    private string? _error;

    private int _selectedYear;
    private List<int> _years = new();

    private string? _selectedCategoryKey;
    private Dictionary<string, int> _visibleCount = new();

    private bool IsOpen(string key)
        => _selectedCategoryKey == key;

    private string GetGroupKey(BankTransaction t)
        => t.MobilePayName ?? t.SubCategory.ToString();

    private IEnumerable<BankTransaction> GetFilteredTransactions(CategorySummary item)
    {
        return Db.Transactions
            .Where(x =>
                x.Date.Year == _selectedYear &&
                x.MainCategory == item.MainCategory &&
                (x.MobilePayName ?? x.SubCategory.ToString()) == item.DisplayName)
            .OrderByDescending(x => x.Date);
    }

    private int GetVisibleCount(string key)
    {
        if (!_visibleCount.ContainsKey(key))
            _visibleCount[key] = 20;

        return _visibleCount[key];
    }

    private void IncreaseVisible(string key)
    {
        _visibleCount[key] += 20;
    }

    private async Task HandleBankCsvUpload(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            using var stream = file.OpenReadStream(10_000_000);

            _transactions = await CsvService.ImportAsync(stream);

            var existingKeys = await Db.Transactions
                .Select(x => new { x.Date, x.Amount, x.Description })
                .ToListAsync();

            var existingSet = existingKeys
                .Select(x => $"{x.Date:yyyyMMdd}-{x.Amount}-{x.Description}")
                .ToHashSet();

            var newTransactions = _transactions
                .GroupBy(t => $"{t.Date:yyyyMMdd}-{t.Amount}-{t.Description}")
                .Select(g => g.First()) // 👈 removes duplicates in same CSV
                .Where(t => !existingSet.Contains($"{t.Date:yyyyMMdd}-{t.Amount}-{t.Description}"))
                .ToList();
            try
            {
                Db.Transactions.AddRange(newTransactions);
                await Db.SaveChangesAsync();
            }
            catch (DbUpdateException)
            {
                // fallback: ignore duplicates silently
            }
            _years = Db.Transactions
                .Select(x => x.Date.Year)
                .Distinct()
                .OrderByDescending(x => x)
                .ToList();

            _selectedYear = _years.FirstOrDefault();

            _message = $"Saved {newTransactions.Count} new rows (skipped {_transactions.Count - newTransactions.Count})";
            _error = null;

            Calculate();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private void Calculate()
    {
        var data = Db.Transactions
            .Where(x => x.Date.Year == _selectedYear)
            .ToList();

        _summary = BudgetService
            .GetSummary(data, _selectedYear)
            .ToList();

        _totals = BudgetService.GetYearTotals(data, _selectedYear);
    }

    private void ToggleCategory(string key)
    {
        _selectedCategoryKey = _selectedCategoryKey == key ? null : key;
    }

    private IEnumerable<CategorySummary> IncomeCategories()
        => _summary.Where(x => x.Total > 0).OrderByDescending(x => x.Total);

    private IEnumerable<CategorySummary> ExpenseCategories()
        => _summary.Where(x => x.Total < 0).OrderBy(x => x.Total);

    private string GetAmountClass(decimal amount)
        => amount > 0 ? "text-success" : "text-danger";
}