@page "/budget/upload"
@rendermode InteractiveServer

@using ITMartinBudget.Domain.Entities
@using ITMartinBudget.Application.Services
@using ITMartinBudget.Infrastructure
@using ITMartinBudget.Infrastructure.Services
@using Microsoft.EntityFrameworkCore

@inject BankTransactionCsvService CsvService
@inject BudgetDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="budget-upload-page">
    <div class="budget-upload-panel">

        <SectionTitle Title="💰 Budget Upload" Subtitle="Upload your bank CSV" />

        @if (_hasExistingData)
        {
            <div class="alert warning">
                ⚠ Existing data detected. Uploading will merge and skip duplicates.
            </div>

            <button class="btn btn-danger" @onclick="ConfirmReset" disabled="@_isUploading">
                🧹 Delete ALL data
            </button>
        }

        <!-- UPLOAD -->
        <div class="upload-box @( _isUploading ? "disabled" : "" )">
            <div class="upload-icon">📁</div>
            <div class="upload-text">
                @(_isUploading ? "Uploading..." : "Upload CSV file")
            </div>

            <InputFile OnChange="HandleBankCsvUpload" disabled="@_isUploading" />
        </div>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <div class="alert success">@_message</div>
        }

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="alert error">@_error</div>
        }

    </div>
</div>

@code {
    private bool _hasExistingData;
    private bool _isUploading;
    private string? _message;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _hasExistingData = await Db.Transactions.AsNoTracking().AnyAsync();
    }

    private async Task HandleBankCsvUpload(InputFileChangeEventArgs e)
    {
        if (_isUploading)
            return;

        try
        {
            _isUploading = true;
            _error = null;
            _message = null;

            var file = e.File;

            if (file == null)
            {
                _error = "No file selected";
                return;
            }

            // 🔥 basic validation
            if (!file.Name.EndsWith(".csv", StringComparison.OrdinalIgnoreCase))
            {
                _error = "Only CSV files are allowed";
                return;
            }

            if (file.Size == 0)
            {
                _error = "File is empty";
                return;
            }

            using var stream = file.OpenReadStream(long.MaxValue);

            var newTransactions = await CsvService.ImportAsync(stream);

            if (!newTransactions.Any())
            {
                _message = "No new transactions (duplicates skipped)";
            }
            else
            {
                _message = $"✔ Imported {newTransactions.Count} new transactions";
            }

            var hasUnknowns = await Db.UnknownTransactions.AnyAsync();

            await Task.Delay(300);

            if (hasUnknowns)
                Nav.NavigateTo("/budget/rules", forceLoad: true);
            else
                Nav.NavigateTo("/budget", forceLoad: true);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isUploading = false;
        }
    }

    private async Task ConfirmReset()
    {
        if (await JS.InvokeAsync<bool>("confirm", "Delete ALL data?"))
        {
            await FullReset();
        }
    }

    private async Task FullReset()
    {
        Db.Transactions.RemoveRange(Db.Transactions);
        Db.UnknownTransactions.RemoveRange(Db.UnknownTransactions);

        await Db.SaveChangesAsync();

        _hasExistingData = false;
        _message = "All data deleted";
    }
}