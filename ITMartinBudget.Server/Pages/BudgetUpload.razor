@page "/budget/upload"
@rendermode InteractiveServer

@using ITMartinBudget.Domain.Entities
@using ITMartinBudget.Application.Services
@using ITMartinBudget.Infrastructure
@using ITMartinBudget.Infrastructure.Services
@using Microsoft.EntityFrameworkCore

@inject BankTransactionCsvService CsvService
@inject BudgetDbContext Db
@inject NavigationManager Nav

<div class="budget-upload-page">
    <div class="budget-upload-panel">

        <SectionTitle Title="💰 Budget Upload" Subtitle="Upload your bank CSV" />

        @if (_hasExistingData)
        {
            <div class="alert warning">
                ⚠ Existing data detected. Uploading will replace overlapping years.
            </div>

            <button class="btn btn-danger" @onclick="FullReset">
                🧹 Delete ALL data
            </button>
        }

        <!-- UPLOAD -->
        <div class="upload-box">
            <div class="upload-icon">📁</div>
            <div class="upload-text">
                Upload CSV file
            </div>

            <InputFile OnChange="HandleBankCsvUpload" />
        </div>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <div class="alert success">@_message</div>
        }

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="alert error">@_error</div>
        }

    </div>
</div>

@code {
    private bool _hasExistingData;
    private string? _message;
    private string? _error;

    protected override void OnInitialized()
    {
        _hasExistingData = Db.Transactions.Any();
    }

    private async Task HandleBankCsvUpload(InputFileChangeEventArgs e)
    {
        try
        {
            Console.WriteLine("UPLOAD STARTED");

            var file = e.File;

            if (file == null)
            {
                _error = "No file selected";
                return;
            }

            Console.WriteLine($"File: {file.Name}");

            using var stream = file.OpenReadStream(10_000_000);

            var result = await CsvService.ImportAsync(stream);

            Console.WriteLine($"Imported: {result.Count}");

            _message = $"Imported {result.Count} transactions";

            Nav.NavigateTo("/budget", true);
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.ToString()); // 🔥 IMPORTANT
            _error = ex.Message;
        }
    }

    private async Task FullReset()
    {
        Db.Transactions.RemoveRange(Db.Transactions);
        Db.UnknownTransactions.RemoveRange(Db.UnknownTransactions);

        await Db.SaveChangesAsync();

        _hasExistingData = false;
        _message = "All data deleted";
    }
}