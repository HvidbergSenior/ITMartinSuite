@page "/budget/rules"
@layout BudgetMainLayout

@using System.Globalization
@using ITMartinBudget.Application.Services
@using ITMartinBudget.Domain.Entities
@using ITMartinBudget.Domain.Enums
@using ITMartinBudget.Domain.ValueObjects
@using ITMartinBudget.Infrastructure
@using Microsoft.EntityFrameworkCore

@inject BudgetDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime Js

<div class="rules-page">

    <ContentCard>
        <h2>🧠 Rule Engine</h2>
    </ContentCard>

    <ContentCard Title="@($"Unknown ({_unknownGrouped.Count})")">

        @foreach (var item in _unknownGrouped)
        {
            var key = item.Description;

            <div class="rule-item">

                <div @onclick="() => Toggle(key)">
                    <strong>@item.Description</strong>
                    <div>@item.Count</div>
                </div>

                <select value="@GetSelectedValue(item)"
                        @onchange="async (e) => await OnSubCategorySelected(item, e)">
                    
                    <option value="">Select</option>

                    @foreach (var sub in Enum.GetValues<SubCategory>())
                    {
                        if (sub == SubCategory.Ukendt) continue;
                        <option value="@sub">@sub</option>
                    }
                </select>

            </div>

            @if (IsOpen(key))
            {
                <div>

                    @foreach (var tx in _transactions
                        .Where(x => x.NormalizedDescription == key)
                        .Take(10))
                    {
                        <div>
                            @tx.Date.ToString("dd MMM") - @tx.Description
                        </div>
                    }

                </div>
            }
        }

    </ContentCard>

</div>

@code {
    private List<UnknownGroup> _unknownGrouped = new();
    private List<CategoryRule> _rules = new();
    private List<BankTransaction> _transactions = new();

    private string? _openKey;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _transactions = await Db.Transactions.ToListAsync();
        _rules = await Db.CategoryRules.ToListAsync();

        _unknownGrouped = _transactions
            .Where(x => x.SubCategory == SubCategory.Ukendt)
            .GroupBy(x => x.NormalizedDescription)
            .Select(g => new UnknownGroup
            {
                Description = g.Key,
                Count = g.Count()
            })
            .ToList();
    }

    private async Task ApplyRule(string key, SubCategory sub)
    {
        var matches = _transactions
            .Where(x => x.NormalizedDescription == key)
            .ToList();

        foreach (var t in matches)
        {
            t.SubCategory = sub;
            t.Category = CategoryMapper.Map(sub);
        }

        await Db.SaveChangesAsync();
    }

    private async Task OnSubCategorySelected(UnknownGroup item, ChangeEventArgs e)
    {
        if (!Enum.TryParse<SubCategory>(e.Value?.ToString(), out var sub))
            return;

        await ApplyRule(item.Description, sub);

        if (!_rules.Any(r => r.Keyword == item.Description))
        {
            Db.CategoryRules.Add(new CategoryRule
            {
                Keyword = item.Description,
                SubCategory = sub
            });

            await Db.SaveChangesAsync();
        }

        await LoadData();
    }

    private string? GetSelectedValue(UnknownGroup item)
        => _rules.FirstOrDefault(r => r.Keyword == item.Description)?.SubCategory.ToString();

    void Toggle(string key)
        => _openKey = _openKey == key ? null : key;

    bool IsOpen(string key)
        => _openKey == key;
}