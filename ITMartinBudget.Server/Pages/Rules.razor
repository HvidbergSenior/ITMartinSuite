@page "/budget/rules"
@layout BudgetMainLayout

@using ITMartinBudget.Application.Services
@using ITMartinBudget.Domain.Entities
@using ITMartinBudget.Domain.Enums
@using ITMartinBudget.Infrastructure
@using Microsoft.EntityFrameworkCore

@inject BudgetDbContext Db
@inject NavigationManager Nav

<div class="rules-page">

    <!-- HEADER -->
    <ContentCard>
        <div class="rules-header">
            <div>
                <h2>🧠 Rule Engine</h2>
                <div class="meta">Categorize unknown transactions</div>
            </div>

            <div class="rules-actions">
                <button class="btn btn-primary" @onclick="GoToDashboard">📊 Dashboard</button>
                <button class="btn btn-secondary" @onclick="LoadData">🔄 Refresh</button>
            </div>
        </div>
    </ContentCard>

    <!-- GRID -->
    <div class="rules-grid">

        <!-- LEFT -->
        <ContentCard Title="@($"🚨 Unknown ({_unknownGrouped.Count})")">

            <input class="form-input"
                   placeholder="Search..."
                   @bind="_filter" />

            <div class="stack">

                @foreach (var item in FilteredUnknowns())
                {
                    <div class="rule-item">

                        <div class="rule-main">
                            <strong>@item.Description</strong>

                            <div class="meta">@item.Count transactions</div>

                            <div class="meta">
                                <span class="@GetAmountClass(item.TotalAmount)">
                                    @(item.TotalAmount >= 0 ? "+" : "-")
                                    @Math.Abs(item.TotalAmount):N2 kr.
                                </span>

                                <span class="type-badge @(item.TotalAmount >= 0 ? "income" : "expense")">
                                    @(item.TotalAmount >= 0 ? "Income" : "Expense")
                                </span>
                            </div>

                            @if (item.IsSaving)
                            {
                                <div class="meta">Saving...</div>
                            }
                        </div>

                        <div class="rule-action">
                            <select value="@item.SelectedSubCategory"
                                    @onchange="async (e) => await OnCategoryChanged(item, e)">

                                <option value="">Select category</option>

                                @foreach (var cat in Enum.GetValues<Category>())
                                {
                                    <optgroup label="@($"{GetCategoryIcon(cat)} {cat}")">
                                        @foreach (var sub in GetSubCategories(cat))
                                        {
                                            <option value="@sub">@sub</option>
                                        }
                                    </optgroup>
                                }

                            </select>
                        </div>

                    </div>
                }

            </div>

        </ContentCard>

        <!-- RIGHT -->
        <ContentCard Title="@($"📂 Rules ({_rules.Count})")">

            @foreach (var group in _rules
                .GroupBy(x => CategoryMapper.Map(x.SubCategory))
                .OrderBy(x => x.Key))
            {
                <div class="rule-group">

                    <div class="rule-group-header">
                        <span>@GetCategoryIcon(group.Key)</span>
                        <strong>@group.Key (@group.Count())</strong>
                    </div>

                    @foreach (var rule in group)
                    {
                        <div class="rule-row">

                            <div>
                                <strong>@rule.Keyword</strong>
                                <div class="meta">→ @rule.SubCategory</div>
                            </div>

                            <div>@(rule.IsVerified ? "✔" : "⚠")</div>

                            <button class="btn btn-danger"
                                    @onclick="async () => await DeleteRule(rule)">
                                Delete
                            </button>

                        </div>
                    }

                </div>
            }

        </ContentCard>

    </div>

</div>

@code {
    private List<UnknownGroup> _unknownGrouped = new();
    private List<CategoryRule> _rules = new();
    private string _filter = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        // 🔥 IMPORTANT: NO TRACKING OFF HERE
        var transactions = await Db.Transactions
            .Where(x => x.SubCategory == SubCategory.Ukendt)
            .ToListAsync();

        _unknownGrouped = transactions
            .GroupBy(x => x.Description)
            .Select(g => new UnknownGroup
            {
                Description = g.Key,
                Count = g.Count(),
                TotalAmount = g.Sum(x => x.Amount)
            })
            .OrderByDescending(x => Math.Abs(x.TotalAmount))
            .Take(200)
            .ToList();

        _rules = await Db.CategoryRules.ToListAsync();

        StateHasChanged();
    }

    private IEnumerable<UnknownGroup> FilteredUnknowns()
    {
        if (string.IsNullOrWhiteSpace(_filter))
            return _unknownGrouped;

        return _unknownGrouped
            .Where(x => x.Description.Contains(_filter, StringComparison.OrdinalIgnoreCase));
    }

    private async Task OnCategoryChanged(UnknownGroup item, ChangeEventArgs e)
    {
        if (!Enum.TryParse<SubCategory>(e.Value?.ToString(), out var sub))
            return;

        item.IsSaving = true;
        StateHasChanged();

        var keyword = ExtractKeyword(item.Description);

        // 🔥 Add rule if not exists
        if (!Db.CategoryRules.Any(r => r.Keyword == keyword))
        {
            Db.CategoryRules.Add(new CategoryRule
            {
                Keyword = keyword,
                SubCategory = sub,
                Priority = 10,
                IsVerified = true
            });
        }

        // 🔥 Update matching transactions
        var matches = await Db.Transactions
            .Where(x => x.Description.Contains(keyword))
            .ToListAsync();

        foreach (var t in matches)
        {
            t.SubCategory = sub;
            t.Category = CategoryMapper.Map(sub);
        }

        await Db.SaveChangesAsync();

        // 🔥 FULL RELOAD (safe + correct)
        await LoadData();
    }

    private async Task DeleteRule(CategoryRule rule)
    {
        Db.CategoryRules.Remove(rule);
        await Db.SaveChangesAsync();

        await LoadData();
    }

    private void GoToDashboard()
        => Nav.NavigateTo("/budget");

    private IEnumerable<SubCategory> GetSubCategories(Category category)
        => Enum.GetValues<SubCategory>()
            .Where(x => CategoryMapper.Map(x) == category);

    private string GetAmountClass(decimal amount)
        => amount >= 0 ? "text-success" : "text-danger";

    private string ExtractKeyword(string text)
    {
        var words = text.ToLower()
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Where(w => w.Length > 2)
            .ToList();

        return words.OrderByDescending(w => w.Length).FirstOrDefault() ?? text;
    }

    private string GetCategoryIcon(Category cat) => cat switch
    {
        Category.Indkomst => "💰",
        Category.Mad => "🍔",
        Category.Transport => "🚗",
        Category.Bolig => "🏠",
        Category.Fritid => "🎮",
        Category.Shopping => "🛍",
        Category.Sundhed => "🏥",
        Category.Abonnement => "📱",
        _ => "📦"
    };
}