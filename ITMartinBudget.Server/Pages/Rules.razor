@page "/budget/rules"
@layout BudgetMainLayout

@using System.Globalization
@using ITMartinBudget.Application.Services
@using ITMartinBudget.Domain.Entities
@using ITMartinBudget.Domain.Enums
@using ITMartinBudget.Domain.ValueObjects
@using ITMartinBudget.Infrastructure
@using Microsoft.EntityFrameworkCore
@inject BudgetDbContext Db
@inject NavigationManager Nav

<div class="rules-page">

    <ContentCard>
        <div class="rules-header">
            <div>
                <h2>🧠 Rule Engine</h2>
                <div class="meta">Categorize unknown transactions</div>
            </div>

            <div class="rules-actions">
                <button class="btn btn-primary" @onclick="GoToDashboard">📊 Dashboard</button>
                <button class="btn btn-secondary" @onclick="LoadData">🔄 Refresh</button>
            </div>
        </div>
    </ContentCard>

    <div class="rules-grid">

        <!-- LEFT -->
        <ContentCard Title="@($"🚨 Unknown ({_unknownGrouped.Sum(x => x.Count)} transactions / {_unknownGrouped.Count} groups)")">

            <input class="form-input" placeholder="Search..." @bind="_filter" />

            <div class="stack">

                @foreach (var item in FilteredUnknowns())
                {
                    <div class="rule-item">

                        <div class="rule-main">
                            <strong>@GetDisplayName(item.Description)</strong>
                            <div class="meta">@item.Count transactions</div>
                        </div>

                        <div class="rule-action">
                            <select @onchange="async (e) => await OnSubCategorySelected(item, e)">
                                <option value="">Select subcategory</option>

                                @foreach (var sub in Enum.GetValues<SubCategory>())
                                {
                                    if (sub == SubCategory.Ukendt)
                                        continue;

                                    <option value="@sub">@sub</option>
                                }
                            </select>
                        </div>

                    </div>
                }

            </div>

        </ContentCard>

        <!-- RIGHT -->
        <div style="display:flex; flex-direction:column; gap:16px;">

            <!-- RULES -->
            <ContentCard Title="@($"📂 Rules ({_rules.Count})")">

                @foreach (var group in _rules
                    .GroupBy(x => CategoryMapper.Map(x.SubCategory))
                    .OrderByDescending(g => g.Count()))
                {
                    <div class="rule-group">

                        <div class="rule-group-header">
                            <strong>@group.Key (@group.Count())</strong>
                        </div>

                        @foreach (var rule in group)
                        {
                            <div class="rule-row">
                                <div>
                                    <strong>@rule.Keyword</strong>
                                    <div class="meta">→ @rule.SubCategory</div>
                                </div>

                                <button class="btn btn-danger"
                                        @onclick="async () => await DeleteRule(rule)">
                                    Delete
                                </button>
                            </div>
                        }

                    </div>
                }

            </ContentCard>

            <!-- SUGGESTIONS -->
            <ContentCard Title="@($"💡 Suggestions ({_suggestions.Count})")">

                @foreach (var s in _suggestions)
                {
                    <div class="rule-row">
                        <div>
                            <strong>@s.Keyword</strong>
                            <div class="meta">→ @s.SubCategory (@s.Count matches)</div>
                        </div>

                        <button class="btn btn-primary"
                                @onclick="async () => await AcceptSuggestion(s)">
                            Accept
                        </button>
                    </div>
                }

            </ContentCard>

        </div>

    </div>

</div>

@code {
    private List<UnknownGroup> _unknownGrouped = new();
    private List<CategoryRule> _rules = new();
    private List<RuleSuggestion> _suggestions = new();

    private string _filter = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        var transactions = await Db.Transactions.ToListAsync();

        Console.WriteLine("===== LOADING RULES PAGE =====");

        // UNKNOWN GROUPS
        _unknownGrouped = transactions
            .Where(x => x.SubCategory == SubCategory.Ukendt)
            .GroupBy(x => TransactionGroupingService.GetGroupingKey(x))
            .Select(g => new UnknownGroup
            {
                Description = g.Key,
                Count = g.Count(),
                TotalAmount = g.Sum(x => x.Amount)
            })
            .OrderByDescending(x => x.Count)
            .ToList();

        _rules = await Db.CategoryRules.ToListAsync();

        // SUGGESTIONS (safe ones only)
        _suggestions = transactions
            .Where(t => t.SubCategory != SubCategory.Ukendt)
            .GroupBy(x => TransactionGroupingService.GetGroupingKey(x))
            .Where(g => g.Count() >= 3)
            .Select(g => new RuleSuggestion
            {
                Keyword = g.Key,
                SubCategory = g.First().SubCategory,
                Count = g.Count()
            })
            .Where(s => !_rules.Any(r => r.Keyword == s.Keyword))
            .OrderByDescending(x => x.Count)
            .Take(20)
            .ToList();
    }

    private async Task OnSubCategorySelected(UnknownGroup item, ChangeEventArgs e)
    {
        if (!Enum.TryParse<SubCategory>(e.Value?.ToString(), out var sub))
            return;

        Console.WriteLine($"[SET RULE] {item.Description} → {sub}");

        if (!_rules.Any(r => r.Keyword == item.Description))
        {
            Db.CategoryRules.Add(new CategoryRule
            {
                Keyword = item.Description,
                SubCategory = sub,
                IsVerified = true
            });

            await Db.SaveChangesAsync();
        }

        await ApplyRuleToTransactions(item.Description, sub);
        await LoadData();
    }

    private async Task AcceptSuggestion(RuleSuggestion s)
    {
        Console.WriteLine($"[ACCEPT RULE] {s.Keyword} → {s.SubCategory}");

        if (!_rules.Any(r => r.Keyword == s.Keyword))
        {
            Db.CategoryRules.Add(new CategoryRule
            {
                Keyword = s.Keyword,
                SubCategory = s.SubCategory,
                IsVerified = true
            });

            await Db.SaveChangesAsync();
        }

        await ApplyRuleToTransactions(s.Keyword, s.SubCategory);
        await LoadData();
    }

    private async Task ApplyRuleToTransactions(string keyword, SubCategory sub)
    {
        var all = await Db.Transactions.ToListAsync();

        var matches = all
            .Where(x => TransactionGroupingService.GetGroupingKey(x) == keyword)
            .ToList();

        Console.WriteLine($"[APPLY RULE] {keyword} → {sub} ({matches.Count} matches)");

        foreach (var t in matches)
        {
            t.SubCategory = sub;
            t.Category = CategoryMapper.Map(sub);
        }

        await Db.SaveChangesAsync();
    }

    private string GetDisplayName(string description)
        => CultureInfo.CurrentCulture.TextInfo.ToTitleCase(description);

    private IEnumerable<UnknownGroup> FilteredUnknowns()
        => string.IsNullOrWhiteSpace(_filter)
            ? _unknownGrouped
            : _unknownGrouped.Where(x =>
                x.Description.Contains(_filter, StringComparison.OrdinalIgnoreCase));

    private void GoToDashboard()
        => Nav.NavigateTo("/budget");

    [Inject] IJSRuntime Js { get; set; } = default!;

    private async Task DeleteRule(CategoryRule rule)
    {
        var confirm = await Js.InvokeAsync<bool>("confirm", $"Delete rule '{rule.Keyword}'?");

        if (!confirm)
            return;

        Db.CategoryRules.Remove(rule);
        await Db.SaveChangesAsync();

        await LoadData();
    }
}