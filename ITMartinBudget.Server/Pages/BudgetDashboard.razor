@page "/"
@page "/budget"

@layout BudgetMainLayout

@using ITMartinBudget.Application
@using ITMartinBudget.Application.Models
@using ITMartinBudget.Domain.Entities
@using ITMartinBudget.Domain.Enums
@using ITMartinBudget.Infrastructure
@using Microsoft.EntityFrameworkCore

@inject IBudgetService BudgetService
@inject BudgetDbContext Db
@inject NavigationManager Nav

<div class="budget-page">

    <div class="budget-header-row">

        <div>

            <h1 class="page-title">
                💰 Budget Overview
            </h1>

            <div class="page-sub">
                Fixed income & recurring expenses
            </div>

        </div>

        <button class="btn btn-danger"
                @onclick="ResetData">
            Reset
        </button>

    </div>

    <!-- KPI -->
    <div class="kpi-grid">

        <div class="kpi-big income">

            <div class="kpi-label">
                Income
            </div>

            <div class="kpi-value">
                @Format(_totals?.Income)
            </div>

        </div>

        <div class="kpi-big expense">

            <div class="kpi-label">
                Expenses
            </div>

            <div class="kpi-value">
                @Format(_totals?.Expenses)
            </div>

        </div>

        <div class="kpi-big net">

            <div class="kpi-label">
                Net
            </div>

            <div class="kpi-value">
                @Format(_totals?.Net)
            </div>

        </div>

    </div>

    <!-- SUMMARY CARDS -->
    <div class="fixed-grid">

        <div class="fixed-card income @(IsOpen("fixed-income") ? "active" : "")"
             @onclick='() => Toggle("fixed-income")'>

            <div class="fixed-label">
                Fixed Income (Year)
            </div>

            <div class="fixed-value">
                @Format(FixedIncomeTotal)
            </div>

            <div class="fixed-sub">
                Click to view transactions
            </div>

        </div>

        <div class="fixed-card expense @(IsOpen("fixed-expenses") ? "active" : "")"
             @onclick='() => Toggle("fixed-expenses")'>

            <div class="fixed-label">
                Fixed Expenses (Year)
            </div>

            <div class="fixed-value">
                @Format(FixedExpenseTotal)
            </div>

            <div class="fixed-sub">
                Click to view transactions
            </div>

        </div>

        <div class="fixed-card income @(IsOpen("other-income") ? "active" : "")"
             @onclick='() => Toggle("other-income")'>

            <div class="fixed-label">
                Other Income (Year)
            </div>

            <div class="fixed-value">
                @Format(VariableIncomeTotal)
            </div>

            <div class="fixed-sub">
                Click to view transactions
            </div>

        </div>

        <div class="fixed-card expense @(IsOpen("other-expenses") ? "active" : "")"
             @onclick='() => Toggle("other-expenses")'>

            <div class="fixed-label">
                Other Expenses (Year)
            </div>

            <div class="fixed-value">
                @Format(VariableExpenseTotal)
            </div>

            <div class="fixed-sub">
                Click to view transactions
            </div>

        </div>

        @if (ExpenseRefunds > 0)
        {
            <div class="fixed-card net @(IsOpen("expense-refunds") ? "active" : "")"
                 @onclick='() => Toggle("expense-refunds")'>

                <div class="fixed-label">
                    Expense Refunds / Corrections
                </div>

                <div class="fixed-value">
                    @Format(ExpenseRefunds)
                </div>

                <div class="fixed-sub">
                    Click to view transactions
                </div>

            </div>
        }

    </div>

    <!-- EXPENSE REFUNDS -->
    @if (IsOpen("expense-refunds"))
    {
        <div class="transaction-group-section">

            <h2 class="section-title">
                Expense Refunds / Corrections
            </h2>

            <div class="section-note">
                Showing all refund/correction transactions.
            </div>

            @foreach (var tx in ExpenseRefundTransactions
                          .OrderByDescending(x => x.Amount))
            {
                <div class="overview-card"
                     @key="tx.Id">

                    <div class="tx-row">

                        <span class="tx-date">
                            @tx.Date.ToString("dd MMM yyyy")
                        </span>

                        <span class="tx-description">
                            @tx.Description
                        </span>

                        <span class="tx-amount income">
                            @Format(tx.Amount)
                        </span>

                    </div>

                    <div class="tx-row">

                        <small>
                            @tx.Category
                        </small>

                    </div>

                </div>
            }

        </div>
    }

    <!-- FIXED INCOME -->
    @if (IsOpen("fixed-income"))
    {
        <div class="transaction-group-section">

            <h2 class="section-title">
                Fixed Income Transactions
            </h2>

            <div class="section-note">
                Showing latest 20 transactions per category.
                Totals are calculated from ALL transactions.
            </div>

            @foreach (var item in FixedIncomeItems)
            {
                <div class="overview-card"
                     @key="@($"{item.Category}-{item.Title}")">

                    <div class="category-row">

                        <div class="category-left">

                            <div class="category-title">
                                @item.Title
                            </div>

                        </div>

                        <div class="category-right">

                            <div class="category-amount income">
                                @Format(item.Total)
                            </div>

                        </div>

                    </div>

                    <div class="category-details">

                        @foreach (var tx in item.Transactions.Take(20))
                        {
                            <div class="tx-row"
                                 @key="tx.Id">

                                <span class="tx-date">
                                    @tx.Date.ToString("dd MMM")
                                </span>

                                <span class="tx-description">
                                    @tx.Description
                                </span>

                                <span class="tx-amount income">
                                    @Format(tx.Amount)
                                </span>

                            </div>
                        }

                    </div>

                </div>
            }

        </div>
    }

    <!-- FIXED EXPENSES -->
    @if (IsOpen("fixed-expenses"))
    {
        <div class="transaction-group-section">

            <h2 class="section-title">
                Fixed Expense Transactions
            </h2>

            <div class="section-note">
                Showing latest 20 transactions per category.
                Totals are calculated from ALL transactions.
            </div>

            @foreach (var item in FixedExpenseItems)
            {
                <div class="overview-card"
                     @key="@($"{item.Category}-{item.Title}")">

                    <div class="category-row">

                        <div class="category-left">

                            <div class="category-title">
                                @item.Title
                            </div>

                        </div>

                        <div class="category-right">

                            <div class="category-amount expense">
                                @Format(item.Total)
                            </div>

                        </div>

                    </div>

                    <div class="category-details">

                        @foreach (var tx in item.Transactions.Take(20))
                        {
                            <div class="tx-row"
                                 @key="tx.Id">

                                <span class="tx-date">
                                    @tx.Date.ToString("dd MMM")
                                </span>

                                <span class="tx-description">
                                    @tx.Description
                                </span>

                                <span class="tx-amount @(tx.Amount > 0 ? "income" : "expense")">
                                    @Format(tx.Amount)
                                </span>

                            </div>
                        }

                    </div>

                </div>
            }

        </div>
    }

    <!-- OTHER INCOME -->
    @if (IsOpen("other-income"))
    {
        <div class="transaction-group-section">

            <h2 class="section-title">
                Other Income Transactions
            </h2>

            <div class="section-note">
                Showing latest 20 transactions per category.
                Totals are calculated from ALL transactions.
            </div>

            @foreach (var item in VariableIncomeItems)
            {
                <div class="overview-card"
                     @key="@($"{item.Category}-{item.Title}")">

                    <div class="category-row">

                        <div class="category-left">

                            <div class="category-title">
                                @item.Title
                            </div>

                        </div>

                        <div class="category-right">

                            <div class="category-amount income">
                                @Format(item.Total)
                            </div>

                        </div>

                    </div>

                    <div class="category-details">

                        @foreach (var tx in item.Transactions.Take(20))
                        {
                            <div class="tx-row"
                                 @key="tx.Id">

                                <span class="tx-date">
                                    @tx.Date.ToString("dd MMM")
                                </span>

                                <span class="tx-description">
                                    @tx.Description
                                </span>

                                <span class="tx-amount income">
                                    @Format(tx.Amount)
                                </span>

                            </div>
                        }

                    </div>

                </div>
            }

        </div>
    }

    <!-- OTHER EXPENSES -->
    @if (IsOpen("other-expenses"))
    {
        <div class="transaction-group-section">

            <h2 class="section-title">
                Other Expense Transactions
            </h2>

            <div class="section-note">
                Showing latest 20 transactions per category.
                Totals are calculated from ALL transactions.
            </div>

            @foreach (var item in VariableExpenseItems)
            {
                <div class="overview-card"
                     @key="@($"{item.Category}-{item.Title}")">

                    <div class="category-row">

                        <div class="category-left">

                            <div class="category-title">
                                @item.Title
                            </div>

                        </div>

                        <div class="category-right">

                            <div class="category-amount expense">
                                @Format(item.Total)
                            </div>

                        </div>

                    </div>

                    <div class="category-details">

                        @foreach (var tx in item.Transactions.Take(20))
                        {
                            <div class="tx-row"
                                 @key="tx.Id">

                                <span class="tx-date">
                                    @tx.Date.ToString("dd MMM")
                                </span>

                                <span class="tx-description">
                                    @tx.Description
                                </span>

                                <span class="tx-amount expense">
                                    @Format(tx.Amount)
                                </span>

                            </div>
                        }

                    </div>

                </div>
            }

        </div>
    }

</div>

@code {

    private List<BudgetOverviewItem> _overview = new();

    private List<MonthlyBudgetSummary> _monthly = new();

    private List<BankTransaction> _transactions = new();

    private YearSummary? _totals;

    private string? _openCategory;

    private IEnumerable<BudgetOverviewItem> FixedIncomeItems =>
        _overview
            .Where(x => x.Category == Category.FixedIncome);

    private IEnumerable<BudgetOverviewItem> FixedExpenseItems =>
        _overview
            .Where(x => x.Category == Category.FixedExpenses);

    private IEnumerable<BudgetOverviewItem> VariableIncomeItems =>
        _overview
            .Where(x => x.Total > 0)
            .Where(x => x.TransactionType == TransactionType.Indkomst)
            .Where(x => x.Category != Category.FixedIncome)
            .Where(x => x.Category != Category.Transfer)
            .Where(x => x.Category != Category.Savings)
            .Where(x => x.Category != Category.FixedExpenses)
            .OrderByDescending(x => x.Total);

    private IEnumerable<BudgetOverviewItem> VariableExpenseItems =>
        _overview
            .Where(x => x.Total > 0)
            .Where(x => x.TransactionType == TransactionType.Udgift)
            .Where(x => x.Category != Category.FixedExpenses)
            .Where(x => x.Category != Category.Transfer)
            .Where(x => x.Category != Category.Savings)
            .OrderByDescending(x => x.Total);

    private decimal FixedIncomeTotal =>
        FixedIncomeItems.Sum(x => x.Total);

    private decimal FixedExpenseTotal =>
        FixedExpenseItems.Sum(x => x.Total);

    private decimal VariableIncomeTotal =>
        VariableIncomeItems.Sum(x => x.Total);

    private decimal VariableExpenseTotal =>
        VariableExpenseItems.Sum(x => x.Total);

    private List<BankTransaction> ExpenseRefundTransactions =>
        _transactions
            .Where(x => x.Amount > 0)
            .Where(x =>
                x.Category == Category.FixedExpenses
                || x.Category == Category.Food
                || x.Category == Category.Transport
                || x.Category == Category.Shopping
                || x.Category == Category.Health
                || x.Category == Category.Housing
                || x.Category == Category.Travel
                || x.Category == Category.Entertainment
                || x.Category == Category.Bills)
            .ToList();

    private decimal ExpenseRefunds =>
        ExpenseRefundTransactions.Sum(x => x.Amount);

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        var all = await Db.Transactions
            .AsNoTracking()
            .ToListAsync();

        if (!all.Any())
        {
            _transactions = [];
            _overview = [];
            _monthly = [];
            _totals = new YearSummary();

            return;
        }

        var year = all.Max(x => x.Date.Year);

        _transactions = all
            .Where(x => x.Date.Year == year)
            .ToList();

        _overview = BudgetService
            .GetBudgetOverview(_transactions, year)
            .ToList();

        _monthly = BudgetService
            .GetMonthlySummaries(_transactions, year)
            .ToList();

        _totals = BudgetService
            .GetYearTotals(_transactions, year);
    }

    private void Toggle(string key)
    {
        _openCategory =
            _openCategory == key
                ? null
                : key;
    }

    private bool IsOpen(string key)
        => _openCategory == key;

    private string Format(decimal? value)
        => value?.ToString("N2") + " kr."
           ?? "-";

    private void ResetData()
    {
        Db.Transactions.RemoveRange(Db.Transactions);
        
        Db.SaveChanges();

        Nav.NavigateTo("/budget/upload", true);
    }
}