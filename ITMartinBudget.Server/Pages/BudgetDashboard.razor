@page "/"
@page "/budget"
@using ITMartinBudget.Application.Services
@using ITMartinBudget.Domain.Entities
@using ITMartinBudget.Infrastructure

@inject BudgetService BudgetService
@inject BudgetDbContext Db
<div class="library-page">
    <div class="page-container">

        <!-- HERO -->
        <div class="scan-hero-card dashboard-hero">
            <div class="library-row">
                <div>
                    <h1>💰 Budget Dashboard</h1>
                    <p class="hero-text">
                        Upload CSV and analyze your yearly expenses and income.
                    </p>
                </div>

                <div class="form-actions">
                    <a href="/budget/upload" class="btn btn-primary">
                        📂 Upload CSV
                    </a>
                </div>
            </div>
        </div>

        <!-- STATS -->
        <div class="dashboard-stats-grid">
            <div class="content-card stat-card">
                <h3>@_totals?.Income</h3>
                <p>Total Income</p>
            </div>

            <div class="content-card stat-card">
                <h3>@_totals?.Expenses</h3>
                <p>Total Expenses</p>
            </div>

            <div class="content-card stat-card">
                <h3>@_totals?.Net</h3>
                <p>Net</p>
            </div>
        </div>

        <!-- CATEGORY SUMMARY -->
        <div class="content-card recent-section-card">
            <div class="library-row">
                <div>
                    <h3>📊 Category Overview</h3>
                    <p class="text-muted">Top categories</p>
                </div>
            </div>

            @if (!_summary.Any())
            {
                <p>No data loaded yet.</p>
            }
            else
            {
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Category</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var group in _summary.GroupBy(x => x.MainCategory))
                    {
                        <tr class="table-secondary">
                            <td><strong>@group.Key</strong></td>
                            <td>@group.Sum(x => x.Total).ToString("N2")</td>
                        </tr>

                        @foreach (var item in group)
                        {
                            <tr>
                                <td class="ps-4">↳ @item.SubCategory</td>
                                <td>@item.Total.ToString("N2")</td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

@code {
    private List<BankTransaction> _transactions = new();
    private List<CategorySummary> _summary = new();
    private YearSummary? _totals;

    protected override void OnInitialized()
    {
        var year = DateTime.Now.Year;

        var data = Db.Transactions
            .Where(x => x.Date.Year == year)
            .ToList();

        _summary = BudgetService.GetSummary(data, year).ToList();
        _totals = BudgetService.GetYearTotals(data, year);
    }
}