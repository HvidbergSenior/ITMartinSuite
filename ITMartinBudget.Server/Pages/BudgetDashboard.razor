@page "/"
@page "/budget"

@layout BudgetMainLayout

@using ITMartinBudget.Application
@using ITMartinBudget.Application.Models
@using ITMartinBudget.Domain.Entities
@using ITMartinBudget.Domain.Enums
@using ITMartinBudget.Infrastructure
@using ITMartinBudget.Server.Budget
@using Microsoft.EntityFrameworkCore

@inject IBudgetService BudgetService
@inject BudgetDbContext Db
@inject NavigationManager Nav

<div class="budget-container">

    <!-- HEADER -->

    <div class="budget-header">

        <div>
            <h1 class="page-title">
                💰 Budget Overview
            </h1>

            <div class="page-subtitle">
                Real household cashflow overview
            </div>
        </div>

        <button class="btn-reset"
                @onclick="ResetData">
            Reset
        </button>

    </div>

    <!-- KPI -->

    <div class="kpi-grid">

        <div class="kpi-card kpi-income">

            <div class="kpi-label">
                Total Money In
            </div>

            <div class="kpi-value">
                @Format(_totals?.Income)
            </div>

        </div>

        <div class="kpi-card kpi-expense">

            <div class="kpi-label">
                Total Money Out
            </div>

            <div class="kpi-value">
                @Format(Math.Abs(_totals?.Expenses ?? 0))
            </div>

        </div>

        <div class="kpi-card kpi-net">

            <div class="kpi-label">
                Net Cashflow
            </div>

            <div class="kpi-value">
                @Format(_totals?.Net)
            </div>

        </div>

    </div>

    <!-- DASHBOARD -->

    <div class="dashboard-grid">

        <!-- INCOME -->

        <div class="dashboard-column">

            <div class="column-title income">
                Income
            </div>

            @Card(
                "fixed-income",
                "Salary / Fixed Income",
                FixedIncomeItems.Sum(x => x.Total),
                "Recurring income")

            @Card(
                "other-income",
                "Variable Income",
                VariableIncomeItems.Sum(x => x.Total),
                "Extra income")

            @Card(
                "gift-income",
                "Money Gifts",
                GiftIncomeItems
                    .Where(x => x.Total > 0)
                    .Sum(x => x.Total),
                "Family / reimbursements")

        </div>

        <!-- EXPENSES -->

        <div class="dashboard-column">

            <div class="column-title expense">
                Expenses
            </div>

            @Card(
                "fixed-expenses",
                "Fixed Expenses",
                Math.Abs(FixedExpenseItems.Sum(x => x.Total)),
                "Recurring bills")

            @Card(
                "other-expenses",
                "Variable Expenses",
                Math.Abs(VariableExpenseItems.Sum(x => x.Total)),
                "Food / shopping / life")

        </div>

        <!-- OTHER -->

        <div class="dashboard-column">

            <div class="column-title neutral">
                Other
            </div>

            @Card(
                "transfers",
                "Transfers Between Own Accounts",
                Math.Abs(TransferItems.Sum(x => x.Total)),
                "Savings / internal movements")

        </div>

    </div>

    <!-- SECTIONS -->

    @Section(
        "fixed-income",
        "Fixed Income",
        FixedIncomeItems,
        true)

    @Section(
        "other-income",
        "Variable Income",
        VariableIncomeItems,
        true)

    @Section(
        "gift-income",
        "Money Gifts",
        GiftIncomeItems,
        true)

    @Section(
        "fixed-expenses",
        "Fixed Expenses",
        FixedExpenseItems,
        false)

    @Section(
        "other-expenses",
        "Variable Expenses",
        VariableExpenseItems,
        false)

    @Section(
        "transfers",
        "Transfers Between Own Accounts",
        TransferItems,
        false)

</div>

@code {

    private List<BudgetOverviewItem> _overview = [];

    private List<BankTransaction> _transactions = [];

    private YearSummary? _totals;

    private string? _openCategory = "fixed-expenses";

    // =====================================
    // GROUPS
    // =====================================

    private IEnumerable<BudgetOverviewItem> FixedIncomeItems =>
        _overview.Where(x =>
            x.BudgetGroup ==
            BudgetGroup.FixedIncome);

    private IEnumerable<BudgetOverviewItem> VariableIncomeItems =>
        _overview.Where(x =>
            x.BudgetGroup ==
            BudgetGroup.VariableIncome);

    private IEnumerable<BudgetOverviewItem> GiftIncomeItems =>
        _overview.Where(x =>
            x.BudgetGroup ==
            BudgetGroup.GiftIncome);

    private IEnumerable<BudgetOverviewItem> FixedExpenseItems =>
        _overview.Where(x =>
            x.BudgetGroup ==
            BudgetGroup.FixedExpense);

    private IEnumerable<BudgetOverviewItem> VariableExpenseItems =>
        _overview.Where(x =>
            x.BudgetGroup ==
            BudgetGroup.VariableExpense);

    private IEnumerable<BudgetOverviewItem> TransferItems =>
        _overview.Where(x =>
            x.BudgetGroup ==
            BudgetGroup.InternalTransfer);

    // =====================================
    // INIT
    // =====================================

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        var all = await Db.Transactions
            .AsNoTracking()
            .OrderByDescending(x => x.Date)
            .ToListAsync();

        _transactions = all;

        if (!all.Any())
        {
            _overview = [];
            _totals = new YearSummary();
            return;
        }

        var latestYear =
            all.Max(x => x.Date.Year);

        _overview = BudgetService
            .GetBudgetOverview(all, latestYear)
            .ToList();

        _totals = BudgetService
            .GetYearTotals(all, latestYear);
    }

    // =====================================
    // UI
    // =====================================

    private void Toggle(string key)
    {
        _openCategory =
            _openCategory == key
                ? null
                : key;
    }

    private bool IsOpen(string key)
        => _openCategory == key;

    private string Format(decimal? value)
        => value?.ToString("N2") + " kr."
           ?? "-";

    // =====================================
    // CARD
    // =====================================

    private RenderFragment Card(
        string key,
        string title,
        decimal total,
        string subtitle)
        => builder =>
        {
            var seq = 0;

            builder.OpenElement(seq++, "div");

            builder.AddAttribute(
                seq++,
                "class",
                $"summary-card {(IsOpen(key) ? "active" : "")}");

            builder.AddAttribute(
                seq++,
                "onclick",
                EventCallback.Factory.Create(
                    this,
                    () => Toggle(key)));

            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "summary-title");
            builder.AddContent(seq++, title);
            builder.CloseElement();

            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "summary-value");
            builder.AddContent(seq++, Format(Math.Abs(total)));
            builder.CloseElement();

            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "summary-sub");
            builder.AddContent(seq++, subtitle);
            builder.CloseElement();

            builder.CloseElement();
        };

    // =====================================
    // SECTION
    // =====================================

    private RenderFragment Section(
        string key,
        string title,
        IEnumerable<BudgetOverviewItem> items,
        bool income)
        => builder =>
        {
            if (!IsOpen(key))
            {
                return;
            }

            var seq = 0;

            builder.OpenElement(seq++, "div");

            builder.AddAttribute(
                seq++,
                "class",
                "transaction-section");

            builder.OpenElement(seq++, "div");

            builder.AddAttribute(
                seq++,
                "class",
                "transaction-section-title");

            builder.AddContent(seq++, title);

            builder.CloseElement();

            foreach (var item in items
                         .OrderByDescending(x =>
                             Math.Abs(x.Total)))
            {
                builder.OpenElement(seq++, "details");

                builder.AddAttribute(
                    seq++,
                    "class",
                    "category-card");

                builder.OpenElement(seq++, "summary");

                builder.AddAttribute(
                    seq++,
                    "class",
                    "category-header");

                builder.OpenElement(seq++, "div");

                builder.AddAttribute(
                    seq++,
                    "class",
                    "category-title");

                builder.AddContent(
                    seq++,
                    item.Title);

                builder.CloseElement();

                builder.OpenElement(seq++, "div");

                builder.AddAttribute(
                    seq++,
                    "class",
                    income
                        ? "category-total income"
                        : "category-total expense");

                builder.AddContent(
                    seq++,
                    Format(Math.Abs(item.Total)));

                builder.CloseElement();

                builder.CloseElement();

                foreach (var tx in item.Transactions
                             .OrderByDescending(x => x.Date))
                {
                    builder.OpenElement(seq++, "div");

                    builder.AddAttribute(
                        seq++,
                        "class",
                        "transaction-row");

                    builder.OpenElement(seq++, "div");

                    builder.AddAttribute(
                        seq++,
                        "class",
                        "transaction-date");

                    builder.AddContent(
                        seq++,
                        tx.Date.ToString("dd MMM"));

                    builder.CloseElement();

                    builder.OpenElement(seq++, "div");

                    builder.AddAttribute(
                        seq++,
                        "class",
                        "transaction-description");

                    builder.AddContent(
                        seq++,
                        tx.Description);

                    builder.CloseElement();

                    builder.OpenElement(seq++, "div");

                    builder.AddAttribute(
                        seq++,
                        "class",
                        income
                            ? "transaction-amount income"
                            : "transaction-amount expense");

                    builder.AddContent(
                        seq++,
                        Format(Math.Abs(tx.Amount)));

                    builder.CloseElement();

                    builder.CloseElement();
                }

                builder.CloseElement();
            }

            builder.CloseElement();
        };

    // =====================================
    // RESET
    // =====================================

    private void ResetData()
    {
        Db.Transactions.RemoveRange(
            Db.Transactions);

        Db.SaveChanges();

        Nav.NavigateTo(
            "/budget/upload",
            true);
    }
}