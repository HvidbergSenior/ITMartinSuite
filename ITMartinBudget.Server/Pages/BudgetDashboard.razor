@page "/"
@page "/budget"

@using ITMartinBudget.Application.Services
@using ITMartinBudget.Domain.Entities
@using ITMartinBudget.Domain.Enums
@using ITMartinBudget.Infrastructure

@inject BudgetService BudgetService
@inject BudgetDbContext Db
@inject NavigationManager Nav

<div class="budget-dashboard-page">
    <div class="budget-dashboard-panel">

        <SectionTitle Title="💰 Budget Dashboard" Subtitle="Overview of your current year" />

        <!-- RESET BUTTON -->
        <div style="margin-bottom:20px;">
            <button class="btn btn-danger" @onclick="ResetData">
                🗑 Reset data & upload new CSV
            </button>
        </div>

        <!-- STATS -->
        <div class="dashboard-stats-grid">
            <SummaryStatCard Title="Income" Value="@_totals?.Income" Type="success" />
            <SummaryStatCard Title="Expenses" Value="@_totals?.Expenses" Type="danger" />
            <SummaryStatCard Title="Net" Value="@_totals?.Net" />
        </div>

        <!-- CATEGORIES -->
        <ContentCard Variant="ContentCard.CardVariant.Primary">
            <SectionTitle Title="📂 Categories" Subtitle="Click to expand" />

            @if (!_summary.Any())
            {
                <EmptyState Text="No data loaded yet. Upload a CSV to get started." />
                
            }
            else
            {
                <div class="budget-layout">

                    <!-- INCOME -->
                    <div class="budget-column">
                        <h3 class="text-success">💰 Income</h3>

                        @foreach (var group in IncomeCategories()
                            .GroupBy(x => x.Category)
                            .OrderBy(x => x.Key))
                        {
                            var key = group.Key;

                            <div class="category-card income">
                                <div class="category-header clickable"
                                     @onclick="() => ToggleIncome(key)">

                                    <strong>@group.Key</strong>
                                    <span>@group.Sum(x => x.Income).ToString("N2")</span>
                                </div>

                                @if (_openIncome == key)
                                {
                                    @foreach (var item in group)
                                    {
                                        <div class="subcategory-card">
                                            <div class="subcategory-header">
                                                <div>
                                                    <div class="title">@item.DisplayName</div>
                                                    <div class="meta">
                                                        @item.TransactionCount • @item.Frequency
                                                    </div>
                                                </div>

                                                <div class="amount text-success">
                                                    @item.Income.ToString("N2")
                                                </div>
                                            </div>

                                            <div class="subcategory-transactions">
                                                @foreach (var t in GetTransactions(item, true).Take(20))
                                                {
                                                    <div class="transaction-row">
                                                        <div>@t.Date.ToString("dd-MM")</div>
                                                        <div>@t.Description</div>
                                                        <div class="@GetAmountClass(t.Amount)">
                                                            @t.Amount.ToString("N2")
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        }
                    </div>

                    <!-- EXPENSES -->
                    <div class="budget-column">
                        <h3 class="text-danger">💸 Expenses</h3>

                        @foreach (var group in ExpenseCategories()
                            .GroupBy(x => x.Category)
                            .OrderBy(x => x.Key))
                        {
                            var key = group.Key;

                            <div class="category-card expense">
                                <div class="category-header clickable"
                                     @onclick="() => ToggleExpense(key)">

                                    <strong>@group.Key</strong>
                                    <span>@group.Sum(x => x.Expenses).ToString("N2")</span>
                                </div>

                                @if (_openExpense == key)
                                {
                                    @foreach (var item in group)
                                    {
                                        <div class="subcategory-card">
                                            <div class="subcategory-header">
                                                <div>
                                                    <div class="title">@item.DisplayName</div>
                                                    <div class="meta">
                                                        @item.TransactionCount • @item.Frequency
                                                    </div>
                                                </div>

                                                <div class="amount text-danger">
                                                    @item.Expenses.ToString("N2")
                                                </div>
                                            </div>

                                            <div class="subcategory-transactions">
                                                @foreach (var t in GetTransactions(item, false).Take(20))
                                                {
                                                    <div class="transaction-row">
                                                        <div>@t.Date.ToString("dd-MM")</div>
                                                        <div>@t.Description</div>
                                                        <div class="@GetAmountClass(t.Amount)">
                                                            @t.Amount.ToString("N2")
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        }
                    </div>

                </div>
            }
        </ContentCard>

    </div>
</div>

@code {
    private List<CategorySummary> _summary = new();
    private YearSummary? _totals;
    private List<BankTransaction> _transactions = new();

    private Category? _openIncome;
    private Category? _openExpense;

    protected override void OnInitialized()
    {
        var all = Db.Transactions.ToList();

        if (!all.Any())
        {
            _summary = new();
            _totals = new YearSummary();
            return;
        }

        var year = all
            .Select(x => x.Date.Year)
            .DefaultIfEmpty(DateTime.Now.Year)
            .Max();

        _transactions = all
            .Where(x => x.Date.Year == year)
            .ToList();

        _summary = BudgetService.GetSummary(_transactions, year).ToList();
        _totals = BudgetService.GetYearTotals(_transactions, year);
    }

    private async Task ResetData()
    {
        Db.Transactions.RemoveRange(Db.Transactions);
        Db.UnknownTransactions.RemoveRange(Db.UnknownTransactions);

        await Db.SaveChangesAsync();

        Nav.NavigateTo("/budget/upload", forceLoad: true);
    }

    private void ToggleIncome(Category key)
        => _openIncome = _openIncome == key ? null : key;

    private void ToggleExpense(Category key)
        => _openExpense = _openExpense == key ? null : key;

    private IEnumerable<BankTransaction> GetTransactions(CategorySummary item, bool isIncome)
    {
        return _transactions
            .Where(x =>
                x.Category == item.Category &&
                x.SubCategory == item.SubCategory &&
                (isIncome ? x.Amount > 0 : x.Amount < 0))
            .OrderByDescending(x => x.Date);
    }

    private IEnumerable<CategorySummary> IncomeCategories()
        => _summary.Where(x => x.Income > 0);

    private IEnumerable<CategorySummary> ExpenseCategories()
        => _summary.Where(x => x.Expenses > 0);
    private string GetAmountClass(decimal amount)
        => amount > 0 ? "text-success" : "text-danger";
}