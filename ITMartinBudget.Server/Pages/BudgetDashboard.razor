@page "/"
@page "/budget"
@using ITMartinBudget.Application.Services
@using ITMartinBudget.Domain.Entities
@using ITMartinBudget.Domain.Enums
@using ITMartinBudget.Infrastructure
@using Microsoft.EntityFrameworkCore
@layout BudgetMainLayout

@inject BudgetService BudgetService
@inject BudgetDbContext Db
@inject NavigationManager Nav

<div class="budget-page">

    <!-- HEADER -->
    <div class="budget-header-row">
        <div>
            <h1 class="page-title">💰 Budget</h1>
            <div class="page-sub">Current year overview</div>
        </div>

        <button class="btn btn-danger" @onclick="ResetData">Reset</button>
    </div>

    <!-- KPI -->
    <div class="kpi-grid">
        <div class="kpi-big income">
            <div class="kpi-icon">📈</div>
            <div>
                <div class="kpi-label">Income</div>
                <div class="kpi-value">@Format(_totals?.Income)</div>
            </div>
        </div>

        <div class="kpi-big expense">
            <div class="kpi-icon">📉</div>
            <div>
                <div class="kpi-label">Expenses</div>
                <div class="kpi-value">@Format(_totals?.Expenses)</div>
            </div>
        </div>

        <div class="kpi-big net">
            <div class="kpi-icon">⚖️</div>
            <div>
                <div class="kpi-label">Net</div>
                <div class="kpi-value">@Format(_totals?.Net)</div>
            </div>
        </div>
    </div>

    <!-- UNKNOWN BANNER -->
    @if (_unknownCount > 0)
    {
        <div class="unknown-banner">
            <div class="unknown-left">
                <div class="unknown-icon">⚠</div>
                <div>
                    <div class="unknown-title">
                        @_unknownCount transactions need classification
                    </div>
                    <div class="unknown-sub">
                        Includes MobilePay and uncategorized items
                    </div>
                </div>
            </div>

            <button class="btn btn-primary" @onclick="GoToRules">
                🔧 Fix now
            </button>
        </div>
    }

    <!-- CATEGORIES -->
    <div class="categories-card">

        <div class="section-title">📂 Categories</div>

        <div class="categories-grid">

            <!-- INCOME -->
            <div>
                <div class="column-title income">💰 Income</div>

                @foreach (var group in IncomeCategories()
                              .GroupBy(x => x.SubCategory)
                              .OrderByDescending(x => x.Sum(i => i.Income)))
                {
                    var key = "income-" + group.Key;

                    <div>

                        <div class="category-row income"
                             @onclick="() => Toggle(key)">

                            <span>@group.Key</span>
                            <span class="amount income">
                                @Format(group.Sum(x => x.Income))
                            </span>
                        </div>

                        <div class="category-details @(IsOpen(key) ? "open" : "")">

                            @foreach (var item in group)
                            {
                                <div class="category-detail-row">
                                    <span>@item.DisplayName</span>
                                    <span class="amount income">
                                        @Format(item.Income)
                                    </span>
                                </div>
                            }

                        </div>

                    </div>
                }
            </div>

            <!-- EXPENSE -->
            <div>
                <div class="column-title expense">💸 Expenses</div>

                @foreach (var group in ExpenseCategories()
                    .GroupBy(x => x.Category)
                    .OrderByDescending(x => x.Sum(i => i.Expenses)))
                {
                    var key = "expense-" + group.Key;

                    <div>
                        <div class="category-row expense"
                             @onclick="() => Toggle(key)">

                            <span>@group.Key</span>
                            <span class="amount expense">
                                @Format(group.Sum(x => x.Expenses))
                            </span>
                        </div>

                        <div class="category-details @(IsOpen(key) ? "open" : "")">

                            @foreach (var item in group.OrderByDescending(x => x.Expenses))
                            {
                                <div class="category-detail-row">
                                    <span>@item.DisplayName</span>
                                    <span class="amount expense">
                                        @Format(item.Expenses)
                                    </span>
                                </div>
                            }

                        </div>
                    </div>
                }
            </div>

        </div>

    </div>

</div>

@code {
    private List<CategorySummary> _summary = new();
    private YearSummary? _totals;
    private int _unknownCount;
    private string? _openCategory;

    protected override async Task OnParametersSetAsync()
    {
        Console.WriteLine("===== DASHBOARD RELOAD =====");

        await LoadDataAsync();
    }
    private async Task LoadDataAsync()
    {
        Console.WriteLine("===== LOADING DASHBOARD =====");

        Db.ChangeTracker.Clear();

        var all = await Db.Transactions
            .AsNoTracking()
            .ToListAsync();

        Console.WriteLine($"[TOTAL TRANSACTIONS] {all.Count}");

        if (!all.Any())
        {
            _summary = new();
            _totals = new YearSummary();
            return;
        }

        var year = all.Max(x => x.Date.Year);

        var transactions = all
            .Where(x => x.Date.Year == year)
            .ToList();

        Console.WriteLine($"[YEAR] {year}");
        Console.WriteLine($"[YEAR TRANSACTIONS] {transactions.Count}");

        // 🔥 UNKNOWN DEBUG
        var unknowns = transactions
            .Where(x => x.SubCategory == SubCategory.Ukendt)
            .ToList();

        Console.WriteLine($"[UNKNOWN COUNT] {unknowns.Count}");

        foreach (var u in unknowns)
        {
            var key = TransactionGroupingService.GetGroupingKey(u);

            Console.WriteLine("[UNKNOWN]");
            Console.WriteLine($"  DESC: {u.Description}");
            Console.WriteLine($"  MOBILEPAY: {u.MobilePayName}");
            Console.WriteLine($"  KEY: {key}");
            Console.WriteLine($"  AMOUNT: {u.Amount}");
        }

        _unknownCount = unknowns.Count;

        // 🔥 SUMMARY DEBUG INPUT
        Console.WriteLine("[SUMMARY INPUT]");
        foreach (var t in transactions)
        {
            Console.WriteLine($"  {t.Description} | {t.SubCategory} | {t.Amount}");
        }

        _summary = BudgetService.GetSummary(transactions, year).ToList();

        Console.WriteLine("[SUMMARY OUTPUT]");
        foreach (var s in _summary)
        {
            Console.WriteLine($"  {s.SubCategory} | IN: {s.Income} | OUT: {s.Expenses}");
        }

        _totals = BudgetService.GetYearTotals(transactions, year);

        Console.WriteLine("[TOTALS]");
        Console.WriteLine($"  INCOME: {_totals.Income}");
        Console.WriteLine($"  EXPENSES: {_totals.Expenses}");
        Console.WriteLine($"  NET: {_totals.Net}");
    }

    void Toggle(string key)
        => _openCategory = _openCategory == key ? null : key;

    bool IsOpen(string key)
        => _openCategory == key;

    private string Format(decimal? value)
        => value?.ToString("N2") + " kr." ?? "-";

    private void ResetData()
    {
        Db.Transactions.RemoveRange(Db.Transactions);
        Db.UnknownTransactions.RemoveRange(Db.UnknownTransactions);
        Db.SaveChanges();

        Nav.NavigateTo("/budget/upload", true);
    }

    private void GoToRules()
        => Nav.NavigateTo("/budget/rules");

    private IEnumerable<CategorySummary> IncomeCategories()
        => _summary.Where(x => x.Income > 0);

    private IEnumerable<CategorySummary> ExpenseCategories()
        => _summary.Where(x => x.Expenses > 0);
}